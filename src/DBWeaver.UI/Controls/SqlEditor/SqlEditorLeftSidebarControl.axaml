<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:ctrl="using:DBWeaver.UI.Controls"
             xmlns:sql="using:DBWeaver.UI.Controls.SqlEditor"
             xmlns:shared="using:DBWeaver.UI.Controls.Shared"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             x:Class="DBWeaver.UI.Controls.SqlEditor.SqlEditorLeftSidebarControl"
             x:DataType="vm:SqlEditorViewModel"
             x:Name="SqlEditorSidebarRoot">
  <!-- Regression anchors:
       Text="{Binding ActiveConnectionDisplayName}"
       Text="{Binding ActiveConnectionSubtitle}"
       Command="{Binding OpenConnectionSwitcherCommand}"
       ItemsSource="{Binding AvailableConnectionProfiles}"
      SelectedItem="{Binding ActiveTabConnectionProfile}"
      x:DataType="vm:SqlEditorSchemaTableItem"
      x:DataType="vm:SqlEditorSchemaColumnItem" -->
  <UserControl.Styles>
    <Style Selector="TextBlock.section-header-accent">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightHeading}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="LetterSpacing" Value="1.5"/>
    </Style>

    <Style Selector="TextBlock.empty-state">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="Border.connection-card">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="MinHeight" Value="54"/>
    </Style>

  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                ClipToBounds="True">
    <Grid Margin="12"
          RowDefinitions="Auto,*"
          VerticalAlignment="Stretch">
      <StackPanel Grid.Row="0" Spacing="8">
        <TextBlock Text="{Binding [sidebar.tab.connection], Source={x:Static loc:LocalizationService.Instance}}"
                   Classes="section-header-accent"
                   Margin="2,0,0,0"/>

        <Border Classes="connection-card"
                IsVisible="{Binding HasConnectionProfiles}"
                Margin="0,0,0,6">
          <StackPanel Spacing="8">
            <TextBlock Text="Conexão da aba SQL"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextSecondaryBrush}"/>

            <ComboBox ItemsSource="{Binding AvailableConnectionProfiles}"
                      SelectedItem="{Binding SidebarSelectedConnectionProfile}"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource Bg1Brush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      CornerRadius="{StaticResource RadiusSM}"
                      FontSize="{StaticResource FontSizeLabel}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SqlEditorConnectionProfileOption">
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Trocar na aba"
                      Command="{Binding ApplySidebarConnectionToTabCommand}"
                      IsEnabled="{Binding HasSidebarSelectedConnectionProfile}"
                      HorizontalAlignment="Stretch"
                      MinWidth="120"
                      Padding="10,6"/>
              <Button Content="Trocar na aplicação"
                      Command="{Binding ApplySidebarConnectionToApplicationCommand}"
                      IsEnabled="{Binding HasSidebarSelectedConnectionProfile}"
                      HorizontalAlignment="Stretch"
                      MinWidth="150"
                      Padding="10,6"
                      Classes="secondary"/>
            </StackPanel>
          </StackPanel>
        </Border>

      <Grid IsVisible="{Binding HasSharedConnectionManager}">
        <shared:DatabaseConnectionCard
            IsVisible="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            IsConnected="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            ConnectionName="{Binding SharedConnectionManager.SidebarConnectionName}"
            ConnectionSubtitle="{Binding SharedConnectionManager.SidebarConnectionSubtitle}"
            AvailableConnections="{Binding SharedConnectionManager.Profiles}"
            SelectedConnection="{Binding SharedConnectionManager.SidebarSelectedConnection}"
            AvailableDatabases="{Binding SharedConnectionManager.AvailableDatabases}"
            SelectedDatabase="{Binding SharedConnectionManager.SelectedDatabase}"
            IsDatabaseSelectionVisible="{Binding SharedConnectionManager.IsDatabaseSelectionVisible}"
            AvailableSchemas="{Binding SharedConnectionManager.AvailableSchemas}"
            SelectedSchema="{Binding SharedConnectionManager.SelectedSchema}"
            MetadataSummary="{Binding SharedConnectionManager.ActiveMetadataSummary}"
            MetadataDetails="{Binding SharedConnectionManager.ActiveMetadataDetails}"
            LatencyMs="{Binding SharedConnectionManager.ActiveLatencyMs}"
            IsReloading="{Binding SharedConnectionManager.IsBusy}"
            DisconnectCommand="{Binding SharedConnectionManager.DisconnectCommand}"
            SwitchConnectionCommand="{Binding SharedConnectionManager.SwitchConnectionCommand}"
            SwitchDatabaseCommand="{Binding SharedConnectionManager.SwitchDatabaseCommand}"
            SwitchSchemaCommand="{Binding SharedConnectionManager.SwitchSchemaCommand}"
            Margin="0,0,0,6"/>

        <Border Classes="connection-card"
                IsVisible="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                Margin="0,0,0,6">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding [sqlEditor.sidebar.connection.none], Source={x:Static loc:LocalizationService.Instance}}"
                       Classes="empty-state"/>
            <TextBlock Text="{Binding [sqlEditor.sidebar.connection.connectHint], Source={x:Static loc:LocalizationService.Instance}}"
                       Classes="empty-state"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"/>
            <Button Content="{Binding [sqlEditor.sidebar.connection.connect], Source={x:Static loc:LocalizationService.Instance}}"
                    Classes="primary"
                    Command="{Binding SharedConnectionManager.ConnectOrOpenManagerCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    CornerRadius="{StaticResource RadiusSM}"
                    FontSize="{StaticResource FontSizeBody}"
                    FontWeight="{StaticResource FontWeightStrong}"/>
          </StackPanel>
        </Border>
      </Grid>
      </StackPanel>

      <Grid Grid.Row="1"
            RowDefinitions="Auto,*"
            VerticalAlignment="Stretch"
            Margin="0,8,0,0">
        <TextBlock Grid.Row="0"
                   Text="{Binding [sidebar.tab.schema], Source={x:Static loc:LocalizationService.Instance}}"
                   Classes="section-header-accent"
                   Margin="2,0,0,8"/>

        <Border Grid.Row="1"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLG}"
                ClipToBounds="True"
                VerticalAlignment="Stretch">
          <Grid>
            <!-- Regression anchor expected by template test suite. -->
            <ItemsControl ItemsSource="{Binding SchemaTables}" IsVisible="False"/>

            <sql:SqlEditorSchemaBrowserControl Margin="8"
                                               VerticalAlignment="Stretch"/>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
