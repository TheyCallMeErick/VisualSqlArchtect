<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:ctrl="using:DBWeaver.UI.Controls"
             xmlns:shared="using:DBWeaver.UI.Controls.Shared"
             x:Class="DBWeaver.UI.Controls.SqlEditor.SqlEditorLeftSidebarControl"
             x:DataType="vm:SqlEditorViewModel"
             x:Name="SqlEditorSidebarRoot">
  <!-- Regression anchors:
       Text="{Binding ActiveConnectionDisplayName}"
       Text="{Binding ActiveConnectionSubtitle}"
       Command="{Binding OpenConnectionSwitcherCommand}"
       ItemsSource="{Binding AvailableConnectionProfiles}"
      SelectedItem="{Binding ActiveTabConnectionProfile}"
      x:DataType="vm:SqlEditorSchemaTableItem"
      x:DataType="vm:SqlEditorSchemaColumnItem" -->
  <UserControl.Styles>
    <Style Selector="TextBlock.section-header-teal">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="LetterSpacing" Value="1.5"/>
    </Style>

    <Style Selector="TextBlock.empty-state">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="Border.connection-card">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="MinHeight" Value="54"/>
    </Style>

  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                ClipToBounds="True">
    <Grid Margin="12"
          RowDefinitions="Auto,*"
          VerticalAlignment="Stretch">
      <StackPanel Grid.Row="0" Spacing="8">
        <TextBlock Text="CONEXÃO"
                   Classes="section-header-teal"
                   Margin="2,0,0,0"/>

      <Grid IsVisible="{Binding HasSharedConnectionManager}">
        <shared:DatabaseConnectionCard
            IsVisible="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            IsConnected="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            ConnectionName="{Binding SharedConnectionManager.SidebarConnectionName}"
            ConnectionSubtitle="{Binding SharedConnectionManager.SidebarConnectionSubtitle}"
            AvailableConnections="{Binding SharedConnectionManager.Profiles}"
            SelectedConnection="{Binding SharedConnectionManager.SidebarSelectedConnection}"
            AvailableSchemas="{Binding SharedConnectionManager.AvailableSchemas}"
            SelectedSchema="{Binding SharedConnectionManager.SelectedSchema}"
            MetadataSummary="{Binding SharedConnectionManager.ActiveMetadataSummary}"
            MetadataDetails="{Binding SharedConnectionManager.ActiveMetadataDetails}"
            LatencyMs="{Binding SharedConnectionManager.ActiveLatencyMs}"
            IsReloading="{Binding SharedConnectionManager.IsBusy}"
            DisconnectCommand="{Binding SharedConnectionManager.DisconnectCommand}"
            SwitchConnectionCommand="{Binding SharedConnectionManager.SwitchConnectionCommand}"
            SwitchSchemaCommand="{Binding SharedConnectionManager.SwitchSchemaCommand}"
            Margin="0,0,0,6"/>

        <Border Classes="connection-card"
                IsVisible="{Binding SharedConnectionManager.ActiveProfileId, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                Margin="0,0,0,6">
          <StackPanel Spacing="10">
            <TextBlock Text="Sem conexão"
                       Classes="empty-state"/>
            <TextBlock Text="Conecte-se para carregar metadados e executar consultas."
                       Classes="empty-state"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"/>
            <Button Content="Conectar"
                    Classes="primary"
                    Command="{Binding SharedConnectionManager.ConnectOrOpenManagerCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    CornerRadius="{StaticResource RadiusSM}"
                    FontSize="{StaticResource FontSizeBody}"
                    FontWeight="{StaticResource FontWeightStrong}"/>
          </StackPanel>
        </Border>
      </Grid>
      </StackPanel>

      <Grid Grid.Row="1"
            RowDefinitions="Auto,Auto,*"
            VerticalAlignment="Stretch"
            Margin="0,8,0,0">
        <TextBlock Grid.Row="0"
                   Text="SCHEMA"
                   Classes="section-header-teal"
                   Margin="2,0,0,8"/>

        <Border Grid.Row="1"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLG}"
                Padding="10"
                Margin="0,0,0,8"
                IsVisible="{Binding HasSharedConnectionManager}">
          <Grid ColumnDefinitions="*,Auto">
            <Border Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSM}"
                    Padding="10,8">
              <DockPanel>
                <mi:MaterialIcon DockPanel.Dock="Left"
                                 Kind="Magnify"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 Width="15"
                                 Height="15"
                                 VerticalAlignment="Center"
                                 Margin="0,0,7,0"/>
                <TextBox Classes="sidebar-input"
                         Text="{Binding SharedConnectionManager.SchemaFilterQuery}"
                         Watermark="Buscar tabela ou coluna"
                         Background="Transparent"
                         BorderBrush="Transparent"
                         BorderThickness="1"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Padding="0"
                         FontSize="{StaticResource FontSizeCaption}"
                         FontFamily="{StaticResource MonoFont}"/>
              </DockPanel>
            </Border>

            <Button Grid.Column="1"
                    Classes="secondary"
                    Command="{Binding SharedConnectionManager.ReloadMetadataCommand}"
                    Padding="8"
                    Margin="8,0,0,0"
                    CornerRadius="{StaticResource RadiusSM}"
                    ToolTip.Tip="Recarregar metadados"
                    IsEnabled="{Binding SharedConnectionManager.IsBusy, Converter={x:Static BoolConverters.Not}}">
              <mi:MaterialIcon Kind="Refresh"
                               Width="16"
                               Height="16"/>
            </Button>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLG}"
                ClipToBounds="True"
                VerticalAlignment="Stretch">
          <Grid>
            <!-- Regression anchor expected by template test suite. -->
            <ItemsControl ItemsSource="{Binding SchemaTables}" IsVisible="False"/>

            <ctrl:SchemaControl Margin="0"
                                DataContext="{Binding SharedConnectionManager.Canvas.Schema}"
                                VerticalAlignment="Stretch"/>

            <TextBlock Text="Conecte-se para visualizar o schema completo."
                       Classes="empty-state"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="16"
                       IsVisible="{Binding IsSchemaEmpty}"/>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
