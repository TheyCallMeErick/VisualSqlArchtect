<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             x:Class="DBWeaver.UI.Controls.SqlEditor.SqlEditorResultPanel"
             x:DataType="vm:SqlEditorViewModel">
  <Border Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusMD}"
          Padding="8"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0" ColumnDefinitions="*,220" Margin="0,0,0,6">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
          <TextBlock Text="{Binding [sqlEditor.results.title], Source={x:Static loc:LocalizationService.Instance}}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontWeight="{StaticResource FontWeightTitle}"
                     FontSize="{StaticResource FontSizeBody}"/>
          <Button Content="{Binding ShowAllColumnsButtonText}"
                  IsVisible="{Binding HasHiddenResultColumns}"
                  Padding="10,2"
                  MinHeight="24"
                  FontSize="{StaticResource FontSizeCaption}"
                  Click="ShowAllColumnsButton_Click"/>
            <Button Content="{Binding UndoHiddenColumnButtonText}"
              IsVisible="{Binding HasHiddenColumnUndo}"
              Padding="10,2"
              MinHeight="24"
              FontSize="{StaticResource FontSizeCaption}"
              Click="UndoHiddenColumnButton_Click"/>
          <TextBlock x:Name="RowsCounterText"
               Foreground="{StaticResource TextMutedBrush}"
               FontSize="{StaticResource FontSizeCaption}"
               VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
             Text="{Binding ResultGridFilterText}"
             Watermark="Filtrar resultados"
             FontSize="{StaticResource FontSizeCaption}"
             HorizontalAlignment="Stretch"
             Background="{StaticResource Bg1Brush}"
             Foreground="{StaticResource TextPrimaryBrush}"
             BorderBrush="{StaticResource BorderSubtleBrush}"/>
          <Button Grid.Column="1"
            Content="Limpar"
              Margin="6,0,0,0"
            Padding="10,2"
            MinHeight="24"
            FontSize="{StaticResource FontSizeCaption}"
            Click="ClearResultFilterButton_Click"/>
        </Grid>
      </Grid>

      <Grid Grid.Row="1">
        <TextBlock Text="{Binding ResultsEmptyText}"
                   IsVisible="{Binding IsResultRowsEmpty}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="{StaticResource FontSizeCaption}"/>

        <DataGrid IsReadOnly="True"
                  IsVisible="{Binding HasResultRows}"
                  AutoGenerateColumns="False"
                  x:Name="ResultGrid"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"/>
      </Grid>
    </Grid>
  </Border>
</UserControl>
