<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:ctrl="using:DBWeaver.UI.Controls.SqlEditor"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             x:Class="DBWeaver.UI.Controls.SqlEditor.MutationConfirmDialog"
             x:DataType="vm:SqlEditorViewModel">
  <Border Padding="10,8"
          Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource StatusWarningBrush}"
          BorderThickness="1">
    <StackPanel Spacing="6">
      <TextBlock Text="{Binding PendingMutationMessage}"
                 FontWeight="{StaticResource FontWeightTitle}"
                 Foreground="{StaticResource TextPrimaryBrush}"/>
      <ItemsControl ItemsSource="{Binding PendingMutationIssues}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:MutationGuardIssue">
            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="{Binding PendingMutationCountQuery}"
                 FontFamily="{StaticResource MonoFont}"
                 Foreground="{StaticResource TextMutedBrush}"
                 TextWrapping="Wrap"/>
      <TextBlock Text="{Binding PendingMutationEstimateText}"
                 Foreground="{StaticResource StatusInfoBrush}"
                 TextWrapping="Wrap"/>
      <ctrl:DiffPreviewControl/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{Binding [sqlEditor.mutation.confirmExecute], Source={x:Static loc:LocalizationService.Instance}}"
                Command="{Binding ConfirmPendingMutationCommand}"/>
        <Button Content="{Binding [common.cancel], Source={x:Static loc:LocalizationService.Instance}}"
                Classes="Danger"
                Command="{Binding CancelPendingMutationCommand}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
