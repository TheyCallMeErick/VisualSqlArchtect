<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.SqlEditor.SqlEditorTabBar"
             x:DataType="vm:SqlEditorViewModel">
  <UserControl.Styles>
    <Style Selector="Button.sql-tabbar-button">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.sql-tabbar-button:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryHoverBrush}"/>
    </Style>
    <Style Selector="Border.sql-tab-chip">
      <Setter Property="CornerRadius" Value="{StaticResource RadiusXS}"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ListBoxItem:selected Border.sql-tab-chip">
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
    </Style>
  </UserControl.Styles>

  <Border Background="{StaticResource Bg1Brush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="0,0,0,1"
          Padding="10,8"
          ClipToBounds="True">
    <DockPanel LastChildFill="True">
      <Button DockPanel.Dock="Right"
              Classes="sql-tabbar-button"
              Width="30"
              Height="26"
              Margin="8,0,0,0"
              Command="{Binding NewTabCommand}">
        <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
      </Button>

      <TextBlock DockPanel.Dock="Right"
                 Margin="10,0,6,0"
                 VerticalAlignment="Center"
                 IsVisible="{Binding HasManyTabsWarning}"
                 Foreground="{StaticResource StatusWarningBrush}"
                 FontSize="{StaticResource FontSizeCaption}"
                 Text="{Binding ManyTabsWarningText}"/>

      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    ClipToBounds="True">
        <ListBox ItemsSource="{Binding EditorTabs}"
                 SelectedIndex="{Binding ActiveEditorTabIndex}"
                 SelectionMode="Single"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SqlEditorTabState">
              <Border Classes="sql-tab-chip">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding FallbackTitle}"
                             FontSize="{StaticResource FontSizeBody}"
                             FontWeight="{StaticResource FontWeightTitle}"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <Button Classes="sql-tabbar-button"
                          Width="18"
                          Height="18"
                          Padding="0"
                          Command="{Binding CloseCommand}"
                          CommandParameter="{Binding Id}">
                    <mi:MaterialIcon Kind="Close" Width="11" Height="11"/>
                  </Button>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </DockPanel>
  </Border>
</UserControl>
