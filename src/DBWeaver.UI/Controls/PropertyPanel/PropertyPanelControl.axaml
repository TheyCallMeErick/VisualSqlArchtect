<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.PropertyPanelControl"
             x:DataType="vm:PropertyPanelViewModel">

  <UserControl.Styles>

    <!-- Section header -->
    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize"      Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight"    Value="Bold"/>
      <Setter Property="Foreground"    Value="{StaticResource TextMutedBrush}"/>
      <Setter Property="LetterSpacing" Value="1.5"/>
      <Setter Property="Margin"        Value="0,0,0,6"/>
    </Style>

    <!-- Parameter label -->
    <Style Selector="TextBlock.param-label">
      <Setter Property="FontSize"   Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Margin"     Value="0,0,0,3"/>
    </Style>

    <!-- Parameter input -->
    <Style Selector="TextBox.param-input">
      <Setter Property="Background"    Value="{StaticResource CanvasBgBrush}"/>
      <Setter Property="BorderBrush"   Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"    Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontFamily"    Value="{StaticResource MonoFont}"/>
      <Setter Property="FontSize"      Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="7,5"/>
    </Style>
    <Style Selector="TextBox.param-input:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox.param-combo">
      <Setter Property="Background"    Value="{StaticResource CanvasBgBrush}"/>
      <Setter Property="BorderBrush"   Value="{StaticResource BorderBrush}"/>
      <Setter Property="Foreground"    Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontSize"      Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="7,5"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Pin row -->
    <Style Selector="Border.pin-info-row">
      <Setter Property="Padding"       Value="8,5"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.pin-info-row:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg3Brush}"/>
    </Style>

    <Style Selector="Button.panel-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.1"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.panel-tab:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.panel-tab.active">
      <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource BtnPrimaryFgBrush}"/>
    </Style>
    <Style Selector="Button.panel-tab:focus-visible">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
    </Style>
    <Style Selector="Button.panel-tab:disabled">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Opacity" Value="0.62"/>
      <Setter Property="Border.BorderBrush" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Panel shell ════════════════════════════════════════════════════════ -->
  <Border Background="Transparent"
          BorderThickness="0"
          ClipToBounds="True">

    <Grid RowDefinitions="42,*">

      <!-- ── Panel header ──────────────────────────────────────────────────── -->
      <Border Grid.Row="0"
              Background="{StaticResource Bg1Brush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Spacing="0">
          <Button Classes="panel-tab"
                  Classes.active="{Binding ShowPropertiesTab}"
                  Command="{Binding SelectPropertiesTabCommand}"
                  Content="{Binding [property.tab.properties], Source={x:Static loc:LocalizationService.Instance}}"/>
          <Button Classes="panel-tab"
                  Classes.active="{Binding ShowProjectSettingsTab}"
                  Command="{Binding SelectProjectSettingsTabCommand}"
                  Content="{Binding [property.tab.projectSettings], Source={x:Static loc:LocalizationService.Instance}}"/>
        </StackPanel>
      </Border>

      <!-- ── Scrollable content ────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            IsVisible="{Binding ShowPropertiesTab}">
        <Grid RowDefinitions="Auto,*">
        <Border Padding="12,10"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding HasNode}">
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
            <Border Grid.Column="0"
              Grid.RowSpan="2"
                    Width="24" Height="24"
                    CornerRadius="{StaticResource RadiusSM}"
                    Background="{Binding HeaderGradient}"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center">
              <mi:MaterialIcon Kind="{Binding CategoryIconKind}"
                               Width="12" Height="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
              <TextBlock Text="{Binding PanelTitle}"
                         FontSize="{StaticResource FontSizeBody}"
                         FontWeight="{StaticResource FontWeightTitle}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding NodeCategory}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Spacing="1">
              <TextBlock Text="{Binding [property.nodeType], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         FontWeight="{StaticResource FontWeightHeading}"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1.4"/>
              <TextBlock Text="{Binding NodeTypeLabel}"
                         FontSize="{StaticResource FontSizeCaption}"
                         FontWeight="{StaticResource FontWeightTitle}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="{Binding NodeTypeSubtitle}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Grid>
        </Border>
        <StackPanel Grid.Row="1" Spacing="0" IsVisible="{Binding HasNode}">

          <!-- ── ALIAS ──────────────────────────────────────────────────────── -->
          <Border Padding="12,12,12,8"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="0,0,0,1"
              IsVisible="{Binding ShowAliasEditor}">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-label" Text="{Binding NodeAliasLabel}"/>
              <TextBox Classes="param-input"
                       Text="{Binding NodeAlias, Mode=TwoWay}"
                       Watermark="{Binding [property.aliasWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"/>
            </StackPanel>
          </Border>

          <!-- ── PARAMETERS ─────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,8"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasParams}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.parameters], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding Parameters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ParameterRowViewModel">
                    <StackPanel Spacing="3" Margin="0,0,0,10">

                      <!-- Param label + dirty indicator -->
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="param-label"
                                   Text="{Binding Name}"/>
                        <Ellipse Grid.Column="1"
                                 Width="5" Height="5"
                                 Fill="{StaticResource StatusWarningBrush}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsDirty}"/>
                      </Grid>

                      <!-- Text / JsonPath input -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding Description}"
                               IsEnabled="{Binding IsEditable}"
                               IsVisible="{Binding IsPlainText}"/>

                      <ComboBox Classes="param-combo"
                                ItemsSource="{Binding SuggestedValues}"
                                SelectedItem="{Binding Value, Mode=TwoWay}"
                                IsEnabled="{Binding IsEditable}"
                                IsVisible="{Binding IsTextWithSuggestions}"/>

                      <!-- Number input -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="0"
                               IsEnabled="{Binding IsEditable}"
                               IsVisible="{Binding IsNumber}"/>

                      <!-- Enum / Cast type picker -->
                      <ComboBox Classes="param-combo"
                                ItemsSource="{Binding EnumValues}"
                                SelectedItem="{Binding Value, Mode=TwoWay}"
                                IsEnabled="{Binding IsEditable}"
                                IsVisible="{Binding IsEnum}"/>

                      <!-- Boolean toggle -->
                      <CheckBox Content="{Binding [property.enabled], Source={x:Static loc:LocalizationService.Instance}}"
                                IsChecked="{Binding Value, Mode=TwoWay, Converter={x:Static BoolConverters.Not}}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="{StaticResource FontSizeCaption}"
                                IsEnabled="{Binding IsEditable}"
                                IsVisible="{Binding IsBoolean}"/>

                      <!-- DateTime picker (ISO 8601) -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding [property.datetimeWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                               IsEnabled="{Binding IsEditable}"
                               IsVisible="{Binding IsDateTime}"/>

                      <!-- Date picker (ISO 8601 date only) -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding [property.dateWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                               IsEnabled="{Binding IsEditable}"
                               IsVisible="{Binding IsDate}"/>

                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Apply button -->
                    <Button Content="{Binding [property.apply], Source={x:Static loc:LocalizationService.Instance}}"
                      HorizontalAlignment="Right"
                      Background="{StaticResource Bg2Brush}"
                      BorderBrush="{StaticResource BorderActiveBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource AccentPrimaryHoverBrush}"
                      FontSize="{StaticResource FontSizeCaption}"
                      CornerRadius="{StaticResource RadiusSM}"
                      Padding="10,4"
                      Name="ApplyBtn">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
                  </Style>
                </Button.Styles>
              </Button>
            </StackPanel>
          </Border>

          <!-- ── INPUT PINS ────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,6"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasInputs}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.inputPins], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding InputPins}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PinInfoRowViewModel">
                    <Border Classes="pin-info-row">
                      <Grid ColumnDefinitions="10,*,Auto,Auto">

                        <!-- Color dot -->
                        <Ellipse Grid.Column="0"
                                 Width="7" Height="7"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"/>

                        <!-- Name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource MonoFont}"/>

                        <!-- Type badge -->
                        <Border Grid.Column="2"
                                Background="{StaticResource CanvasBgBrush}"
                                CornerRadius="{StaticResource RadiusXS}"
                                Padding="4,1"
                                Margin="4,0">
                          <TextBlock Text="{Binding TypeLabel}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{Binding ColorBrush}"/>
                        </Border>

                        <!-- Connected indicator -->
                        <Ellipse Grid.Column="3"
                                 Width="5" Height="5"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"
                                 Opacity="{Binding Connected, Converter={x:Static BoolConverters.Not}}"
                                 IsVisible="{Binding Connected}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── OUTPUT PINS ───────────────────────────────────────────────── -->
          <Border Padding="12,10,12,6"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasOutputs}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.outputPins], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding OutputPins}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PinInfoRowViewModel">
                    <Border Classes="pin-info-row">
                      <Grid ColumnDefinitions="10,*,Auto">

                        <Ellipse Grid.Column="0"
                                 Width="7" Height="7"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource MonoFont}"/>

                        <Border Grid.Column="2"
                                Background="{StaticResource CanvasBgBrush}"
                                CornerRadius="{StaticResource RadiusXS}"
                                Padding="4,1"
                                Margin="4,0">
                          <TextBlock Text="{Binding TypeLabel}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{Binding ColorBrush}"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── SQL TRACE ─────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,12"
                  IsVisible="{Binding HasSqlTrace}">

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="section-label"
                           Text="{Binding [property.sqlTrace], Source={x:Static loc:LocalizationService.Instance}}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Background="{StaticResource BtnSuccessBgBrush}"
                        CornerRadius="{StaticResource RadiusXS}"
                        Padding="5,1">
                  <TextBlock Text="{Binding [property.live], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="{StaticResource FontSizeCaption}"
                             FontWeight="{StaticResource FontWeightHeading}"
                             Foreground="{StaticResource StatusOkBrush}"
                             LetterSpacing="1"/>
                </Border>
              </Grid>

              <!-- Context label -->
              <TextBlock Text="{Binding SqlTraceContext}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"
                         TextWrapping="Wrap"/>

              <!-- Fragment box -->
              <Border Background="{StaticResource Bg0Brush}"
                      BorderBrush="{StaticResource StatusOkBrush}"
                      BorderThickness="0,0,0,2"
                      CornerRadius="{StaticResource RadiusSM}"
                      Padding="10,8">
                <TextBlock Text="{Binding SqlTraceFragment}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource StatusOkBrush}"
                           TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </Border>

        </StackPanel>

        <TextBlock Grid.Row="1"
             Text="{Binding [property.selectNodeHint], Source={x:Static loc:LocalizationService.Instance}}"
                   Margin="12,12,12,0"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextMutedBrush}"
                   IsVisible="{Binding ShowSelectNodeHint}"/>

        <Border Grid.Row="1"
                Margin="12,44,12,0"
                Padding="10"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                IsVisible="{Binding HasSelectedWire}">
          <StackPanel Spacing="6">
            <TextBlock Classes="section-label" Text="Selected wire"/>
            <TextBlock Text="{Binding SelectedWireLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <StackPanel Spacing="4">
              <TextBlock Classes="param-label" Text="Wire routing"/>
              <ComboBox Classes="param-combo"
                        ItemsSource="{Binding WireCurveModeOptions}"
                        SelectedItem="{Binding SelectedWireCurveMode, Mode=TwoWay}"/>
            </StackPanel>
          </StackPanel>
        </Border>
        </Grid>
      </ScrollViewer>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    IsVisible="{Binding ShowProjectSettingsTab}">
        <StackPanel Spacing="12" Margin="12,10,12,12">

          <TextBlock Classes="section-label" Text="{Binding [property.namingConventions], Source={x:Static loc:LocalizationService.Instance}}"/>

          <StackPanel Spacing="4">
            <TextBlock Classes="param-label" Text="{Binding [property.aliasConvention], Source={x:Static loc:LocalizationService.Instance}}"/>
            <ComboBox Classes="param-combo"
                      ItemsSource="{Binding NamingConventionOptions}"
                      SelectedItem="{Binding SelectedNamingConvention, Mode=TwoWay}"/>
          </StackPanel>

          <CheckBox Content="{Binding [property.enforceAliasNaming], Source={x:Static loc:LocalizationService.Instance}}"
                    IsChecked="{Binding EnforceAliasNaming, Mode=TwoWay}"
                    FontSize="{StaticResource FontSizeCaption}"
                    Foreground="{StaticResource TextSecondaryBrush}"/>

          <CheckBox Content="{Binding [property.warnReservedSql], Source={x:Static loc:LocalizationService.Instance}}"
                    IsChecked="{Binding WarnOnReservedKeywords, Mode=TwoWay}"
                    FontSize="{StaticResource FontSizeCaption}"
                    Foreground="{StaticResource TextSecondaryBrush}"/>

          <StackPanel Spacing="4">
            <TextBlock Classes="param-label" Text="{Binding [property.maxAliasLength], Source={x:Static loc:LocalizationService.Instance}}"/>
            <TextBox Classes="param-input"
                     Text="{Binding MaxAliasLength, Mode=TwoWay}"
                     Watermark="64"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Classes="param-label" Text="Default wire style"/>
            <ComboBox Classes="param-combo"
                      ItemsSource="{Binding WireCurveModeOptions}"
                      SelectedItem="{Binding SelectedWireCurveMode, Mode=TwoWay}"/>
          </StackPanel>

          <Border Background="{StaticResource CanvasBgBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="8,7">
            <TextBlock Text="{Binding [property.namingSettingsHint], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
