<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels.Canvas"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.FileVersionHistoryOverlay"
             x:DataType="vm:FileVersionHistoryViewModel">

  <Border MaxWidth="620"
          Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusLG}"
          BoxShadow="{StaticResource ShadowXL}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

      <Border Grid.Row="0" Background="{StaticResource Bg1Brush}" CornerRadius="{StaticResource RadiusLGTop}" Padding="12,10">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Width="22" Height="22" CornerRadius="{StaticResource RadiusSM}"
                  Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderFocusBrush}" BorderThickness="1" Margin="0,0,8,0">
            <mi:MaterialIcon Kind="History" Width="13" Height="13" Foreground="{StaticResource AccentPrimaryHoverBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>

          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [fileHistory.title], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}" FontWeight="{StaticResource FontWeightTitle}" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding CurrentFileLabel}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>

          <Button Grid.Column="2" Name="CloseBtn" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <Border Grid.Row="1" Height="1" Background="{StaticResource BorderSubtleBrush}"/>

      <Border Grid.Row="2" Padding="12,10">
        <Grid ColumnDefinitions="Auto,Auto,*">
          <Button Grid.Column="0" Name="ReloadBtn" Margin="0,0,8,0"
                  Background="{StaticResource BtnInfoBgBrush}" BorderBrush="{StaticResource BorderFocusBrush}" BorderThickness="1"
                  Foreground="{StaticResource AccentPrimaryHoverBrush}" CornerRadius="{StaticResource RadiusXS}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
              <TextBlock Text="{Binding [fileHistory.reload], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
            </StackPanel>
          </Button>

          <Button Grid.Column="1" Name="RestoreBtn"
                  IsEnabled="{Binding CanRestore}"
                  Background="{StaticResource BtnSuccessBgBrush}" BorderBrush="{StaticResource StatusOkBrush}" BorderThickness="1"
                  Foreground="{StaticResource StatusOkBrush}" CornerRadius="{StaticResource RadiusXS}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Restore" Width="12" Height="12"/>
              <TextBlock Text="{Binding [fileHistory.restoreSelected], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
            </StackPanel>
          </Button>

          <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Margin="12,0,0,0"
                     VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
        </Grid>
      </Border>

      <Border Grid.Row="3" Padding="10,0,10,10">
        <Border Background="{StaticResource Bg0Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusSM}" Padding="8">
          <Grid>
            <ListBox ItemsSource="{Binding Versions}"
                     SelectedItem="{Binding SelectedVersion}"
                     IsVisible="{Binding HasVersions}"
                     Name="HistoryList">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,Auto" Margin="2,4">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding CreatedAtLocalLabel}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                      <TextBlock Text="{Binding VersionPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding SizeLabel}" Foreground="{StaticResource AccentPrimaryHoverBrush}" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Right"/>
                      <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding [fileHistory.compressedLabel], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                        <TextBlock Text="{Binding IsCompressed}" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel IsVisible="{Binding HasVersions, Converter={x:Static BoolConverters.Not}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
              <mi:MaterialIcon Kind="History" Width="22" Height="22" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [fileHistory.empty], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [fileHistory.emptyHint], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>
      </Border>
    </Grid>
  </Border>
</UserControl>
