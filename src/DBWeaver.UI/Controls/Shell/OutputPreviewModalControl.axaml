<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:ctrl="using:DBWeaver.UI.Controls"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.Shell.OutputPreviewModalControl"
             x:DataType="vm:OutputPreviewModalViewModel">

  <UserControl.Styles>
    <Style Selector="Button.modal-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.modal-tab:pointerover">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.04)"/>
    </Style>
    <Style Selector="Button.modal-tab.active">
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
    </Style>
    <Style Selector="Button.modal-tab:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="ae|TextEditor.ddl-output">
      <Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>
  </UserControl.Styles>

  <Panel IsVisible="{Binding IsVisible}" ZIndex="90">
    <Border Background="{StaticResource MacroScrimBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

        <Border IsVisible="{Binding ShowShellCard}"
          Width="1180"
            MaxWidth="1180"
            Height="700"
            MaxHeight="700"
            MinHeight="520"
            Background="{StaticResource Bg1Brush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusLG}"
            BoxShadow="{StaticResource PanelShadow}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            RenderTransformOrigin="50%,50%"
            RenderTransform="scale(1)">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="14,12,14,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="EyeOutline" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource AccentBlueBrush}"/>
            <StackPanel Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightTitle}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding [preview.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          <Button Grid.Column="1"
                  Command="{Binding CloseCommand}"
                  Classes="tb"
                  Padding="8,4"
                  ToolTip.Tip="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,2"
                Padding="8,0,8,0"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,1">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="modal-tab"
                    Classes.active="{Binding ShowPrimaryContent}"
                    Command="{Binding ShowPrimaryTabCommand}"
                    Content="{Binding PrimaryTabLabel}"/>
            <Button Classes="modal-tab"
                    Classes.active="{Binding ShowDiagnosticsContent}"
                    IsVisible="{Binding HasDiagnostics}"
                    Command="{Binding ShowDiagnosticsTabCommand}"
                    Content="{Binding [sidebar.tab.diagnostics], Source={x:Static loc:LocalizationService.Instance}}"/>
          </StackPanel>
        </Border>

        <Grid Grid.Row="2">
          <Border IsVisible="{Binding ShowQueryPrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="12">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}">
                  <Run Text="{Binding [preview.providerLabel], Source={x:Static loc:LocalizationService.Instance}}"/>
                  <Run Text=": "/>
                  <Run Text="{Binding QueryProviderLabel}"/>
                </TextBlock>
              </StackPanel>

              <ae:TextEditor Grid.Row="1"
                             Name="QuerySqlEditor"
                             Classes="ddl-output"
                             IsReadOnly="True"
                             ShowLineNumbers="True"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
            </Grid>
          </Border>

          <Border IsVisible="{Binding ShowDdlPrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="12">
            <Grid RowDefinitions="Auto,Auto,2*,3*">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}">
                  <Run Text="{Binding [preview.providerLabel], Source={x:Static loc:LocalizationService.Instance}}"/>
                  <Run Text=": "/>
                  <Run Text="{Binding DdlProviderLabel}"/>
                </TextBlock>
                <TextBlock Text="{Binding [preview.ddlDiagnosticsHint], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextMutedBrush}"/>
              </StackPanel>

              <Border Grid.Row="1"
                      Margin="0,0,0,8"
                      Padding="8"
                      Background="{StaticResource Bg1Brush}"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSM}">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" RowDefinitions="Auto,Auto">
                  <Button Grid.Row="0" Grid.Column="0"
                          Margin="0,0,8,0"
                          Command="{ReflectionBinding DdlTool.RunSchemaAnalysisCommand}"
                      Content="{Binding [preview.schemaAnalysis.run], Source={x:Static loc:LocalizationService.Instance}}"
                          Classes="secondary"/>
                  <Button Grid.Row="0" Grid.Column="1"
                          Margin="0,0,8,0"
                          Command="{ReflectionBinding DdlTool.CancelSchemaAnalysisCommand}"
                      Content="{Binding [preview.schemaAnalysis.cancel], Source={x:Static loc:LocalizationService.Instance}}"
                          Classes="secondary"/>
                  <TextBlock Grid.Row="0" Grid.Column="2"
                             Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.StateMessage}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             FontSize="{StaticResource FontSizeCaption}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Row="0" Grid.Column="3"
                             Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.State}"
                             VerticalAlignment="Center"
                             FontSize="{StaticResource FontSizeCaption}"
                             Foreground="{StaticResource TextMutedBrush}"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                             Margin="0,6,0,0"
                             FontSize="{StaticResource FontSizeCaption}"
                             Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="{Binding [preview.schemaAnalysis.summary.issues], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Run Text=" "/>
                    <Run Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.FilteredTotalIssues}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding [preview.schemaAnalysis.summary.rawPrefix], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Run Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.RawTotalIssues}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding [preview.schemaAnalysis.summary.critical], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Run Text=" "/>
                    <Run Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.FilteredCriticalCount}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding [preview.schemaAnalysis.summary.warning], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Run Text=" "/>
                    <Run Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.FilteredWarningCount}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding [preview.schemaAnalysis.summary.info], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Run Text=" "/>
                    <Run Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.FilteredInfoCount}"/>
                  </TextBlock>
                </Grid>
              </Border>

              <ae:TextEditor Grid.Row="2"
                             Name="DdlSqlEditor"
                             Classes="ddl-output"
                             IsReadOnly="True"
                             ShowLineNumbers="True"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>

              <Border Grid.Row="3"
                      Margin="0,8,0,0"
                      Padding="8"
                      Background="{StaticResource Bg1Brush}"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSM}">
                <Grid ColumnDefinitions="1.2*,1*,1*">
                  <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,0">
                    <TextBlock Text="{Binding [preview.schemaAnalysis.issues], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontWeight="{StaticResource FontWeightTitle}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <StackPanel Spacing="4">
                      <Button HorizontalAlignment="Left"
                              Command="{ReflectionBinding DdlTool.SchemaAnalysisPanel.ClearFiltersCommand}"
                              Classes="secondary"
                              Content="{Binding [preview.schemaAnalysis.clearFilters], Source={x:Static loc:LocalizationService.Instance}}"/>

                            <TextBlock Text="{Binding [preview.schemaAnalysis.severity], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"/>
                      <WrapPanel Orientation="Horizontal" ItemHeight="20" ItemWidth="80">
                        <CheckBox Content="Info"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeInfo, Mode=TwoWay}"/>
                        <CheckBox Content="Warning"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeWarning, Mode=TwoWay}"/>
                        <CheckBox Content="Critical"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeCritical, Mode=TwoWay}"/>
                      </WrapPanel>

                      <TextBlock Text="{Binding [preview.schemaAnalysis.rule], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"/>
                      <WrapPanel Orientation="Horizontal" ItemHeight="20" ItemWidth="150">
                        <CheckBox Content="FK_CATALOG_INCONSISTENT"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeFkCatalogInconsistent, Mode=TwoWay}"/>
                        <CheckBox Content="MISSING_FK"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeMissingFk, Mode=TwoWay}"/>
                        <CheckBox Content="NAMING_CONVENTION_VIOLATION"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeNamingConventionViolation, Mode=TwoWay}"/>
                        <CheckBox Content="LOW_SEMANTIC_NAME"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeLowSemanticName, Mode=TwoWay}"/>
                        <CheckBox Content="MISSING_REQUIRED_COMMENT"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeMissingRequiredComment, Mode=TwoWay}"/>
                        <CheckBox Content="NF1_HINT_MULTI_VALUED"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeNf1HintMultiValued, Mode=TwoWay}"/>
                        <CheckBox Content="NF2_HINT_PARTIAL_DEPENDENCY"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeNf2HintPartialDependency, Mode=TwoWay}"/>
                        <CheckBox Content="NF3_HINT_TRANSITIVE_DEPENDENCY"
                                  IsChecked="{ReflectionBinding DdlTool.SchemaAnalysisPanel.IncludeNf3HintTransitiveDependency, Mode=TwoWay}"/>
                      </WrapPanel>

                      <TextBlock Text="{Binding [preview.schemaAnalysis.minConfidence], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"/>
                            <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0"
                                Minimum="0"
                                Maximum="1"
                                Value="{ReflectionBinding DdlTool.SchemaAnalysisPanel.MinConfidenceFilter, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="1"
                             Margin="6,0,0,0"
                                   Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.MinConfidenceFilter}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                      </Grid>

                      <TextBlock Text="{Binding [preview.schemaAnalysis.tableFilter], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBox Watermark="{Binding [preview.schemaAnalysis.tableFilterWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                               Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.TableTextFilter, Mode=TwoWay}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{ReflectionBinding DdlTool.SchemaAnalysisPanel.VisibleIssues}"
                             SelectedItem="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedIssue, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}">
                              <Run Text="{ReflectionBinding Severity}"/>
                              <Run Text=" | "/>
                              <Run Text="{ReflectionBinding RuleCode}"/>
                              <Run Text=" | "/>
                              <Run Text="{ReflectionBinding Confidence}"/>
                            </TextBlock>
                            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis">
                              <Run Text="{ReflectionBinding SchemaName}"/>
                              <Run Text="."/>
                              <Run Text="{ReflectionBinding TableName}"/>
                              <Run Text="."/>
                              <Run Text="{ReflectionBinding ColumnName}"/>
                            </TextBlock>
                            <TextBlock Text="{ReflectionBinding Title}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6" Margin="0,0,8,0">
                    <TextBlock Text="{Binding [preview.schemaAnalysis.details], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontWeight="{StaticResource FontWeightTitle}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.DetailsMessage}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding [preview.schemaAnalysis.evidence], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ListBox ItemsSource="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedIssueEvidence}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock FontSize="{StaticResource FontSizeCaption}" TextTrimming="CharacterEllipsis">
                            <Run Text="{ReflectionBinding Key}"/>
                            <Run Text=": "/>
                            <Run Text="{ReflectionBinding Value}"/>
                          </TextBlock>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="{Binding [preview.schemaAnalysis.suggestions], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ListBox ItemsSource="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedIssue.Suggestions}"
                             SelectedItem="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedSuggestion, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{ReflectionBinding Title}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="{Binding [preview.schemaAnalysis.ruleDiagnostics], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ListBox ItemsSource="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedIssueDiagnostics}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="1" Margin="0,2">
                            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}">
                              <Run Text="{ReflectionBinding Code}"/>
                              <Run Text=" | "/>
                              <Run Text="{ReflectionBinding State}"/>
                            </TextBlock>
                            <TextBlock Text="{ReflectionBinding Message}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="{Binding [preview.schemaAnalysis.sqlCandidates], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontWeight="{StaticResource FontWeightTitle}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SqlCandidatesMessage}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ListBox ItemsSource="{ReflectionBinding DdlTool.SchemaAnalysisPanel.VisibleCandidates}"
                             SelectedItem="{ReflectionBinding DdlTool.SchemaAnalysisPanel.SelectedSqlCandidate, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Text="{ReflectionBinding Title}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}">
                              <Run Text="{ReflectionBinding Safety}"/>
                              <Run Text=" | "/>
                              <Run Text="{ReflectionBinding Visibility}"/>
                            </TextBlock>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Button Command="{ReflectionBinding DdlTool.SchemaAnalysisPanel.CopySqlCommand}"
                              ToolTip.Tip="{ReflectionBinding DdlTool.SchemaAnalysisPanel.ActionBlockedTooltip}"
                              Classes="secondary"
                              Content="{Binding [preview.schemaAnalysis.copySql], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <Button Command="{ReflectionBinding DdlTool.SchemaAnalysisPanel.ApplyToCanvasCommand}"
                              ToolTip.Tip="{ReflectionBinding DdlTool.SchemaAnalysisPanel.ActionBlockedTooltip}"
                              Classes="secondary"
                              Content="{Binding [preview.schemaAnalysis.applyToCanvas], Source={x:Static loc:LocalizationService.Instance}}"/>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border IsVisible="{Binding ShowDiagnosticsContent}"
                  Background="{StaticResource Bg0Brush}">
            <ctrl:SidebarDiagnosticsControl DataContext="{Binding Diagnostics}"/>
          </Border>

          <Border IsVisible="{Binding ShowUnavailablePrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="16">
            <TextBlock Text="{Binding UnavailableMessage}"
                       TextWrapping="Wrap"
                       FontSize="{StaticResource FontSizeLabel}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource Bg1Brush}"
                CornerRadius="{StaticResource RadiusLGBottom}"
                Padding="14,10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding PrimaryTabLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Command="{Binding CloseCommand}"
                    Classes="secondary"
                    Padding="10,6"
                    Content="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Panel IsVisible="{Binding ShowSqlBenchmarkPrimaryContent}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           ZIndex="91">
      <ctrl:BenchmarkOverlay DataContext="{Binding BenchmarkTool}"/>
    </Panel>

    <Panel IsVisible="{Binding ShowSqlExplainPrimaryContent}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           ZIndex="91">
      <ctrl:ExplainPlanOverlay DataContext="{Binding ExplainPlanTool}"/>
    </Panel>
  </Panel>
</UserControl>
