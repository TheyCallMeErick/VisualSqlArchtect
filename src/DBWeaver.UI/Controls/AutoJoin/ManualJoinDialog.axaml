<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.ManualJoinDialog"
             x:DataType="vm:ManualJoinDialogViewModel">
  <UserControl.Resources>
    <DataTemplate x:Key="PinOptionTemplate" x:DataType="vm:ManualJoinColumnOption">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0">
        <Border Grid.Column="0"
                Width="10"
                Height="10"
                CornerRadius="{StaticResource RadiusPill}"
                Background="{Binding PinColorHex}"
                Margin="0,0,6,0"
                VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1"
                   Text="{Binding Name}"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <Border Grid.Column="2"
                Background="{StaticResource Bg3Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                Padding="5,1"
                Margin="6,0,0,0">
          <TextBlock Text="{Binding DataTypeLabel}"
                     FontSize="{StaticResource FontSizeCaption}"
                     FontFamily="{StaticResource MonoFont}"
                     Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
      </Grid>
    </DataTemplate>
  </UserControl.Resources>

  <Border IsVisible="{Binding IsVisible}"
          Background="{StaticResource MacroScrimBrush}"
          IsHitTestVisible="True">
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="860"
            Background="{StaticResource Bg1Brush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusLG}"
            Padding="14">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <mi:MaterialIcon Kind="SourceBranch" Width="16" Height="16" Foreground="{StaticResource AccentBlueBrush}"/>
          <TextBlock Text="{Binding [autoJoin.manual.title], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeTitle}"
                     FontWeight="{StaticResource FontWeightTitle}"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,10"
                   Text="{Binding [autoJoin.manual.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="{StaticResource TextSecondaryBrush}"/>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,*">
          <Border Grid.Column="0"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusMD}"
                  Padding="10"
                  Margin="0,0,6,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LeftTableLabel}"
                         FontSize="{StaticResource FontSizeBody}"
                         FontWeight="{StaticResource FontWeightTitle}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="{Binding [autoJoin.manual.leftColumn], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
              <ComboBox ItemsSource="{Binding LeftColumns}"
                        SelectedItem="{Binding SelectedLeftColumn}"
                        ItemTemplate="{StaticResource PinOptionTemplate}"
                        MinWidth="220"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Width="180"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusMD}"
                  Padding="10">
            <StackPanel Spacing="8">
              <mi:MaterialIcon Kind="ArrowLeftRightBoldOutline"
                               Width="16"
                               Height="16"
                               Foreground="{StaticResource AccentBlueBrush}"
                               HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [autoJoin.manual.joinType], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
              <ComboBox ItemsSource="{Binding JoinTypes}"
                        SelectedItem="{Binding SelectedJoinType}"/>
              <TextBlock Text="{Binding [autoJoin.manual.operator], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
              <Border Background="{StaticResource Bg3Brush}"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSM}"
                      Padding="10,6">
                <TextBlock Text="="
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource MonoFont}"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusMD}"
                  Padding="10"
                  Margin="6,0,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding RightTableLabel}"
                         FontSize="{StaticResource FontSizeBody}"
                         FontWeight="{StaticResource FontWeightTitle}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="{Binding [autoJoin.manual.rightColumn], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
              <ComboBox ItemsSource="{Binding RightColumns}"
                        SelectedItem="{Binding SelectedRightColumn}"
                        ItemTemplate="{StaticResource PinOptionTemplate}"
                        MinWidth="220"/>
              <TextBlock IsVisible="{Binding HasCompatibleRightColumns, Converter={x:Static BoolConverters.Not}}"
                         Text="{Binding [autoJoin.manual.noCompatible], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource BtnWarningFgBrush}"/>
            </StackPanel>
          </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
          <Button Command="{Binding CancelCommand}"
                  Classes="secondary"
                  Padding="12,6"
                  CornerRadius="{StaticResource RadiusSM}"
                  Content="{Binding [common.cancel], Source={x:Static loc:LocalizationService.Instance}}"/>
          <Button Command="{Binding ConfirmCommand}"
                  Classes="primary"
                  Padding="12,6"
                  CornerRadius="{StaticResource RadiusSM}"
                  Content="{Binding [autoJoin.manual.confirm], Source={x:Static loc:LocalizationService.Instance}}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Border>
</UserControl>
