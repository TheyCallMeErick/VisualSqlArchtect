<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DBWeaver.UI.Controls.AutoJoinOverlay"
             x:DataType="vm:AutoJoinOverlayViewModel">

  <UserControl.Styles>

    <!-- Card -->
    <Style Selector="Border.join-card">
      <Setter Property="Background"    Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush"   Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"  Value="{StaticResource RadiusMD}"/>
      <Setter Property="Padding"       Value="12,10"/>
      <Setter Property="Margin"        Value="0,4"/>
    </Style>

    <!-- Accept button -->
    <Style Selector="Button.accept-btn">
      <Setter Property="Background"     Value="{StaticResource BtnInfoBgBrush}"/>
      <Setter Property="BorderBrush"    Value="{StaticResource BorderFocusBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"     Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="CornerRadius"   Value="{StaticResource RadiusSM}"/>
      <Setter Property="Padding"        Value="8,4"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.accept-btn:pointerover">
      <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
    </Style>

    <!-- Dismiss button -->
    <Style Selector="Button.dismiss-btn">
      <Setter Property="Background"     Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"     Value="{StaticResource TextMutedBrush}"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="Padding"        Value="6,4"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.dismiss-btn:pointerover">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Overlay panel ══════════════════════════════════════════════════════ -->
  <Border MaxWidth="380"
          Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusLG}"
          BoxShadow="{StaticResource ShadowXL}">

    <StackPanel>

      <!-- ── Header ───────────────────────────────────────────────────────── -->
      <Border Background="{StaticResource Bg1Brush}"
              CornerRadius="{StaticResource RadiusLGTop}"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto,Auto">

          <!-- Sparkle icon -->
          <Border Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="{StaticResource RadiusSM}"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderFocusBrush}"
                  BorderThickness="1"
                  Margin="0,0,8,0">
            <mi:MaterialIcon Kind="AutoFix"
                             Width="13" Height="13"
                             Foreground="{StaticResource AccentPrimaryHoverBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [autoJoin.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="{StaticResource FontWeightTitle}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding Title}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>

          <!-- Accept All -->
          <Button Grid.Column="2"
                  Classes="accept-btn"
                  Content="{Binding [autoJoin.acceptAll], Source={x:Static loc:LocalizationService.Instance}}"
                  Command="{Binding AcceptAllCommand}"
                  Margin="0,0,4,0"
                  Name="AcceptAllBtn"/>

          <!-- Close All -->
          <Button Grid.Column="3"
                  Classes="dismiss-btn"
                  Command="{Binding DismissCommand}"
                  Name="DismissAllBtn">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

      <!-- ── Suggestion cards ──────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="360"
                    Margin="8,6"
                    HorizontalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding Cards}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:JoinSuggestionCardViewModel">

              <Border Classes="join-card"
                      IsVisible="{Binding IsVisible}">

                <Grid RowDefinitions="Auto,Auto,Auto">

                  <!-- Row 1: Join type badge + table pair + confidence -->
                  <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,6">

                    <!-- JOIN type badge -->
                    <Border Grid.Column="0"
                            Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource BorderFocusBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2"
                            Margin="0,0,8,0">
                      <TextBlock Text="{Binding JoinType}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 FontWeight="{StaticResource FontWeightHeading}"
                                 Foreground="{StaticResource AccentPrimaryHoverBrush}"
                                 FontFamily="{StaticResource MonoFont}"/>
                    </Border>

                    <!-- Table pair -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding TablePair}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Confidence badge -->
                    <Border Grid.Column="2"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2"
                            Margin="6,0,4,0">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.15"/>
                      </Border.Background>
                      <TextBlock Text="{Binding ConfidenceLabel}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{Binding ConfidenceBrush}"/>
                    </Border>

                    <!-- Score percentage -->
                    <Border Grid.Column="3"
                            Background="{StaticResource Bg0Brush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2">
                      <TextBlock Text="{Binding ScoreLabel}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 FontWeight="{StaticResource FontWeightHeading}"
                                 FontFamily="{StaticResource MonoFont}"
                                 Foreground="{Binding ConfidenceBrush}"
                                 VerticalAlignment="Center"/>
                    </Border>
                  </Grid>

                  <!-- Score bar (thin strip below the header row) -->
                  <Border Grid.Row="0" Height="2" VerticalAlignment="Bottom"
                          Margin="0,0,0,6" CornerRadius="{StaticResource RadiusXS}">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.08"/>
                    </Border.Background>
                    <Border HorizontalAlignment="Left"
                            Width="{Binding ScoreBarWidth}"
                            Height="2"
                            CornerRadius="{StaticResource RadiusXS}">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.7"/>
                      </Border.Background>
                    </Border>
                  </Border>

                  <!-- Row 2: ON clause -->
                  <Border Grid.Row="1"
                          Background="{StaticResource Bg0Brush}"
                          CornerRadius="{StaticResource RadiusXS}"
                          Padding="7,4"
                          Margin="0,0,0,8">
                    <TextBlock Text="{Binding OnClause}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource StatusOkBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </Border>

                  <!-- Row 3: Rationale + action buttons -->
                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">

                    <TextBlock Grid.Column="0"
                               Text="{Binding Rationale}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="1"
                            Classes="accept-btn"
                            Margin="0,0,4,0"
                            Command="{Binding AcceptCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="Check" Width="12" Height="12"/>
                        <TextBlock Text="{Binding [autoJoin.accept], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Classes="dismiss-btn"
                            Content="{Binding [autoJoin.skip], Source={x:Static loc:LocalizationService.Instance}}"
                            Command="{Binding DismissCommand}"/>
                  </Grid>

                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state (all dismissed or accepted) -->
      <Border Padding="16,12"
              IsVisible="{Binding HasCards, Converter={x:Static BoolConverters.Not}}">
        <TextBlock Text="{Binding [autoJoin.allHandled], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"/>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
