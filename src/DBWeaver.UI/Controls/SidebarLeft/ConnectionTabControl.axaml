<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:ctrl="using:DBWeaver.UI.Controls"
             xmlns:shared="using:DBWeaver.UI.Controls.Shared"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             x:Class="DBWeaver.UI.Controls.ConnectionTabControl"
             x:DataType="vm:ConnectionManagerViewModel"
             Background="{StaticResource Bg0Brush}"
             Name="ConnTabControl"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

  <UserControl.Styles>
    <Style Selector="TextBlock.section-header-teal">
      <Setter Property="FontSize"         Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight"       Value="Bold"/>
      <Setter Property="Foreground"       Value="{StaticResource AccentTealLightBrush}"/>
      <Setter Property="LetterSpacing"     Value="1.5"/>
    </Style>

    <Style Selector="Border.connection-card">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="MinHeight" Value="54"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.connection-card:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentTealLightBrush}"/>
    </Style>

    <Style Selector="Border.connection-card.active">
      <Setter Property="BorderBrush" Value="{StaticResource AccentTealLightBrush}"/>
    </Style>

    <Style Selector="TextBlock.empty-state">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
  </UserControl.Styles>

  <Grid Margin="12"
        RowDefinitions="Auto,*"
        VerticalAlignment="Stretch">

    <StackPanel Grid.Row="0" Spacing="0">

      <!-- ── CONEXÃO section ─────────────────────────────────── -->
      <TextBlock Text="CONEXÃO"
                 Classes="section-header-teal"
                 Margin="2,0,0,8"/>

      <!-- Connected card -->
      <shared:DatabaseConnectionCard
          IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
          IsConnected="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
          ConnectionName="{Binding SidebarConnectionName}"
          ConnectionSubtitle="{Binding SidebarConnectionSubtitle}"
          AvailableConnections="{Binding Profiles}"
          SelectedConnection="{Binding SidebarSelectedConnection}"
          AvailableSchemas="{Binding AvailableSchemas}"
          SelectedSchema="{Binding SelectedSchema}"
          MetadataSummary="{Binding ActiveMetadataSummary}"
          MetadataDetails="{Binding ActiveMetadataDetails}"
          LatencyMs="{Binding ActiveLatencyMs}"
          IsReloading="{Binding IsBusy}"
          DisconnectCommand="{Binding DisconnectCommand}"
          SwitchConnectionCommand="{Binding SwitchConnectionCommand}"
          SwitchSchemaCommand="{Binding SwitchSchemaCommand}"
          Margin="0,0,0,6"/>

      <!-- No connection state -->
      <Border Classes="connection-card"
              IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNullOrEmpty}}"
              Margin="0,0,0,6"
              Padding="12">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal"
                Spacing="8"
                IsVisible="{Binding IsConnecting}">
            <ProgressBar Width="120"
             Height="3"
             IsIndeterminate="True"
             Foreground="{StaticResource AccentTealBrush}"
             Background="{StaticResource BorderSubtleBrush}"/>
            <TextBlock Text="Conectando..."
                 Classes="empty-state"
                 VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="{Binding [connectionTab.none], Source={x:Static loc:LocalizationService.Instance}}"
                     Classes="empty-state"
               IsVisible="{Binding IsConnecting, Converter={x:Static BoolConverters.Not}}"
                     VerticalAlignment="Center"/>
          <Button Content="{Binding [connection.connect], Source={x:Static loc:LocalizationService.Instance}}"
                  Classes="primary"
              Command="{Binding ConnectOrOpenManagerCommand}"
            IsEnabled="{Binding IsConnecting, Converter={x:Static BoolConverters.Not}}"
                  HorizontalAlignment="Stretch"
                  Padding="12,8"
                  CornerRadius="{StaticResource RadiusSM}"
                  FontSize="{StaticResource FontSizeBody}"
                  FontWeight="{StaticResource FontWeightStrong}"/>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- ── SCHEMA section ──────────────────────────────────── -->
    <Grid Grid.Row="1"
          RowDefinitions="Auto,Auto,*"
          IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
          VerticalAlignment="Stretch">
      <TextBlock Text="SCHEMA"
                 Classes="section-header-teal"
                 Margin="2,8,0,8"/>

      <Border Grid.Row="1"
              Background="{StaticResource Bg1Brush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource RadiusLG}"
              Padding="10"
              Margin="0,0,0,8">
        <Grid ColumnDefinitions="*,Auto">
          <Border Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="10,8">
            <DockPanel>
              <mi:MaterialIcon DockPanel.Dock="Left"
                               Kind="Magnify"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Width="15"
                               Height="15"
                               VerticalAlignment="Center"
                               Margin="0,0,7,0"/>
              <TextBox Classes="sidebar-input"
                       Text="{Binding SchemaFilterQuery}"
                       Watermark="{Binding [schema.search], Source={x:Static loc:LocalizationService.Instance}}"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       BorderThickness="1"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Padding="0"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontFamily="{StaticResource MonoFont}"/>
            </DockPanel>
          </Border>

          <Button Grid.Column="1"
                  Classes="secondary"
                  Command="{Binding ReloadMetadataCommand}"
                  Padding="8"
              Margin="8,0,0,0"
                  CornerRadius="{StaticResource RadiusSM}"
                  ToolTip.Tip="Recarregar metadados">
            <mi:MaterialIcon Kind="Refresh"
                     Width="16"
                     Height="16"/>
          </Button>
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Background="{StaticResource Bg1Brush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource RadiusLG}"
              ClipToBounds="True"
              VerticalAlignment="Stretch">
        <ctrl:SchemaControl Margin="0"
                            DataContext="{Binding Canvas.Schema}"
                            VerticalAlignment="Stretch"/>
      </Border>
    </Grid>

  </Grid>

</UserControl>
