<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:conv="using:DBWeaver.UI.Converters"
             x:Class="DBWeaver.UI.Controls.SchemaControl"
             x:DataType="vm:SchemaViewModel"
             Background="{StaticResource Bg0Brush}">

  <UserControl.Resources>
    <conv:StringToMaterialIconConverter x:Key="StringToIconConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.schema-title">
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="TextBlock.schema-meta">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="Border.schema-header-card">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.schema-header-card:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentTealLightBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.008)"/>
    </Style>

    <Style Selector="Border.schema-object-card">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.schema-object-card:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentTealLightBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.01)"/>
    </Style>

    <Style Selector="Border.schema-object-card.expanded">
      <Setter Property="BorderBrush" Value="{StaticResource AccentTealLightBrush}"/>
    </Style>

    <Style Selector="StackPanel.schema-empty-state TextBlock">
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*" Margin="0">

    <!-- Content -->
    <ScrollViewer Grid.Row="0"
            VerticalScrollBarVisibility="Auto"
            IsVisible="{Binding HasConnection}">
      <StackPanel Spacing="4" Margin="0,10,0,0">
        <ItemsControl ItemsSource="{Binding Categories}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:SchemaCategoryViewModel">
              <StackPanel Spacing="2" Margin="0,0,0,0">
                <Border Classes="schema-header-card" Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLGTop}" Padding="13,11">
                  <DockPanel LastChildFill="True">
                    <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsExpanded}" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" Padding="4,2" FontSize="{StaticResource FontSizeCaption}" CornerRadius="{StaticResource RadiusSM}" BorderThickness="0">
                      <ToggleButton.Content>
                        <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"/>
                      </ToggleButton.Content>
                    </ToggleButton>
                    <StackPanel Spacing="9" Orientation="Horizontal" VerticalAlignment="Center">
                      <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="18" Height="18" Foreground="{Binding Color}"/>
                      <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Name}" Classes="schema-title"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="︸" Classes="schema-meta" Opacity="0.6"/>
                          <TextBlock Text="{Binding Count}" Classes="schema-meta" Opacity="0.6"/>
                          <TextBlock Text="{Binding [schema.itemsSuffix], Source={x:Static loc:LocalizationService.Instance}}" Classes="schema-meta" Opacity="0.6"/>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding IsExpanded}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SchemaObjectViewModel">
                      <StackPanel Spacing="0">
                        <Border Padding="13,10"
                                MinHeight="46"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1,0,1,0"
                                Cursor="Hand"
                                Classes="schema-object-card"
                                Classes.expanded="{Binding IsExpanded}"
                                PointerPressed="OnSchemaObjectPointerPressed"
                                PointerMoved="OnSchemaObjectPointerMoved"
                                PointerReleased="OnSchemaObjectPointerReleased">
                          <ToolTip.Tip>
                            <Border Background="{StaticResource Bg1Brush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusLG}"
                                    Padding="10"
                                    MaxWidth="360">
                              <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Name}"
                                           Classes="schema-title"/>
                                <TextBlock Text="{Binding SubText}"
                                           Classes="schema-meta"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding [tooltip.tableColumns], Source={x:Static loc:LocalizationService.Instance}}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="{StaticResource FontWeightStrong}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           IsVisible="{Binding IsExpandable}"/>

                                <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpandable}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:SchemaObjectViewModel">
                                      <Grid ColumnDefinitions="Auto,*,Auto">
                                        <mi:MaterialIcon Grid.Column="0"
                                                         Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}"
                                                         Width="14"
                                                         Height="14"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding BadgeColor}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Margin="8,0,0,0"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DataType}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{Binding BadgeColor}"
                                                   VerticalAlignment="Center"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding [tooltip.tableColumns.none], Source={x:Static loc:LocalizationService.Instance}}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           IsVisible="{Binding IsExpandable, Converter={x:Static BoolConverters.Not}}"/>
                              </StackPanel>
                            </Border>
                          </ToolTip.Tip>
                          <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Command="{Binding AddNodeCommand}" IsVisible="{Binding AddNodeCommand, Converter={x:Static ObjectConverters.IsNotNull}}" Classes="success" Padding="6,2" FontSize="{StaticResource FontSizeCaption}" CornerRadius="{StaticResource RadiusSM}" Margin="8,0,0,0" Opacity="0.9">
                              <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                            </Button>
                            <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsExpanded}" IsVisible="{Binding IsExpandable}" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" Padding="4,2" FontSize="{StaticResource FontSizeCaption}" CornerRadius="{StaticResource RadiusSM}" BorderThickness="0">
                              <ToggleButton.Content>
                                <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"/>
                              </ToggleButton.Content>
                            </ToggleButton>
                            <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Center">
                              <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="17" Height="17" Foreground="{StaticResource AccentTealLightBrush}"/>
                              <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Name}" Classes="schema-title"/>
                                <TextBlock Text="{Binding SubText}" Classes="schema-meta" Opacity="0.65"/>
                              </StackPanel>
                            </StackPanel>
                          </DockPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SchemaObjectViewModel">
                              <Border Padding="13,8" MinHeight="40" Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1,0,1,0" Cursor="Hand" Margin="0" Classes="schema-object-card">
                                <DockPanel Margin="18,0,0,0">
                                  <Border DockPanel.Dock="Right" Background="{Binding BadgeColor}" CornerRadius="{StaticResource RadiusSM}" Padding="6,3" Opacity="0.25" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding DataType}" Foreground="{Binding BadgeColor}" FontSize="{StaticResource FontSizeCaption}" FontWeight="{StaticResource FontWeightStrong}" FontFamily="{StaticResource MonoFont}"/>
                                  </Border>
                                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="15" Height="15" VerticalAlignment="Center" Foreground="{Binding BadgeColor}"/>
                                    <TextBlock Text="{Binding Name}" Classes="schema-title" VerticalAlignment="Center"/>
                                  </StackPanel>
                                </DockPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" IsVisible="{Binding IsExpanded}"/>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLGBottom}" Height="1" IsVisible="{Binding IsExpanded}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                IsVisible="{Binding ShowFilterEmptyState}"
                Classes="schema-empty-state">
      <TextBlock Text="{Binding [schema.emptyFiltered], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}" FontWeight="{StaticResource FontWeightStrong}"/>
    </StackPanel>

    <StackPanel Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                IsVisible="{Binding ShowNoTablesState}"
                Classes="schema-empty-state">
      <TextBlock Text="{Binding [schema.emptyNoTables], Source={x:Static loc:LocalizationService.Instance}}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 FontSize="{StaticResource FontSizeBody}"
                 FontWeight="{StaticResource FontWeightStrong}"/>
    </StackPanel>

    <StackPanel Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                IsVisible="{Binding ShowLoadingState}"
                Classes="schema-empty-state">
      <TextBlock Text="{Binding [schema.loading], Source={x:Static loc:LocalizationService.Instance}}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeCaption}"
                 Opacity="0.8"/>
    </StackPanel>

    <!-- No Connection -->
    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" IsVisible="{Binding ShowNoConnectionState}">
      <mi:MaterialIcon Kind="CloudOffOutline" Foreground="{StaticResource TextSecondaryBrush}" Width="52" Height="52"/>
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding [schema.noConnection], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontWeight="{StaticResource FontWeightStrong}"/>
      </StackPanel>
    </StackPanel>

  </Grid>

</UserControl>
