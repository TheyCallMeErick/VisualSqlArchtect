<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ervm="using:DBWeaver.UI.ViewModels.ErDiagram"
             xmlns:erc="using:DBWeaver.UI.Controls.ErDiagram"
             x:Class="DBWeaver.UI.Controls.ErDiagram.ErCanvasControl"
             x:DataType="ervm:ErCanvasViewModel">

  <Grid RowDefinitions="Auto,*" Background="{StaticResource Bg0Brush}">
    <Border Grid.Row="0"
            Background="{StaticResource Bg1Brush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="16">
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding EntityCount, StringFormat=Entidades: {0}}"/>
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding EdgeCount, StringFormat=Relações: {0}}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Classes="txt-body"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Text="Incluir Views"
                     VerticalAlignment="Center"/>
          <CheckBox IsChecked="{Binding IncludeViews}" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <Canvas MinWidth="1000" MinHeight="700" Background="{StaticResource Bg0Brush}">
        <ItemsControl ItemsSource="{Binding Entities}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>

          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="ervm:ErEntityNodeViewModel">
              <erc:ErEntityControl Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Canvas>
    </ScrollViewer>
  </Grid>
</UserControl>
