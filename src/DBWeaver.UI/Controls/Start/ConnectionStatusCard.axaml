<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:startmodels="using:DBWeaver.UI.Services.Start.Models"
             x:Class="DBWeaver.UI.Controls.Start.ConnectionStatusCard"
             x:DataType="startmodels:StartSavedConnectionItem">

  <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,6">
    <Grid Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center">
      <Ellipse Width="8" Height="8" Fill="{StaticResource BtnSuccessFgBrush}" IsVisible="{Binding IsConnected}"/>
      <Ellipse Width="8" Height="8" Fill="{StaticResource TextMutedBrush}" IsVisible="{Binding !IsConnected}"/>
    </Grid>

    <TextBlock Grid.Column="1"
               Margin="8,0,0,0"
               Text="{Binding Name}"
               FontSize="{StaticResource FontSizeCaption}"
               Foreground="{StaticResource TextPrimaryBrush}"/>

    <TextBlock Grid.Column="2"
               Text="{Binding StatusLabel}"
               FontSize="{StaticResource FontSizeCaption}"
               Foreground="{StaticResource TextSecondaryBrush}"/>
  </Grid>
</UserControl>
