<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DBWeaver.UI.ViewModels"
             xmlns:canvas="using:DBWeaver.UI.ViewModels.Canvas"
             xmlns:ctrl="using:DBWeaver.UI.Controls"
             xmlns:loc="using:DBWeaver.UI.Services.Localization"
             x:Class="DBWeaver.UI.Controls.DataPreviewPanel"
             x:DataType="canvas:DataPreviewViewModel"
             x:Name="Root">

  <UserControl.Styles>
    <!-- DataGrid custom dark theme -->
    <Style Selector="DataGrid">
      <Setter Property="Background"          Value="{StaticResource CanvasBgBrush}"/>
      <Setter Property="GridLinesVisibility" Value="All"/>
      <Setter Property="BorderThickness"     Value="0"/>
      <Setter Property="RowBackground"       Value="Transparent"/>
      <!-- AlternatingRowBackground intentionally omitted to reduce visual noise -->
      <Setter Property="Foreground"          Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontSize"            Value="{StaticResource FontSizeBody}"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSoftBrush}"/>
      <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderSoftBrush}"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background"   Value="{StaticResource Bg0Brush}"/>
      <Setter Property="Foreground"   Value="{StaticResource StatusInfoBrush}"/>
      <Setter Property="FontSize"     Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Padding"      Value="10,7"/>
      <Setter Property="BorderBrush"  Value="{StaticResource BorderSoftBrush}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="{StaticResource Bg2Brush}"/>
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Padding" Value="10,5"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Panel shell ════════════════════════════════════════════════════════ -->
  <Border Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource BorderSoftBrush}"
          BorderThickness="0,1,0,0"
          BoxShadow="{StaticResource ShadowLG}">

    <Grid RowDefinitions="Auto,Auto,*">

      <!-- ── Top drag handle + header ──────────────────────────────────────── -->
      <Grid Grid.Row="0"
            ColumnDefinitions="Auto,*,Auto,Auto,Auto"
            Background="{StaticResource CanvasBgBrush}"
            Height="40">

        <!-- Drag handle strip -->
        <Border Grid.Column="0"
                Width="3"
                Background="{StaticResource BorderBrush}"
                Margin="12,8,0,8"
                CornerRadius="{StaticResource RadiusXS}"
                Cursor="Hand"
                Name="DragHandle"/>

        <!-- Title + status -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="6">
            <!-- Colored indicator dot -->
            <Ellipse Width="7" Height="7" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="{StaticResource StatusInfo}"/>
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="{Binding [preview.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="{StaticResource FontWeightTitle}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Row count / status chip (color-coded by state) -->
          <Border Background="{StaticResource Bg2Brush}"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="7,2"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{Binding StatusColor}"/>
          </Border>
        </StackPanel>

        <!-- Shortcut hint -->
        <Border Grid.Column="2"
                Background="{StaticResource Bg3Brush}"
                CornerRadius="{StaticResource RadiusXS}"
                Padding="5,2"
                Margin="0,0,8,0"
                VerticalAlignment="Center">
          <TextBlock Text="F3" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <!-- Run button (hidden while running) -->
        <Button Grid.Column="3"
                FontSize="{StaticResource FontSizeCaption}"
                Foreground="{StaticResource StatusInfoBrush}"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderActiveBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                Padding="8,4"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Name="RunButton"
                IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="↺" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [preview.run], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center"/>
          </StackPanel>
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Cancel button (visible only while running) -->
        <Button Grid.Column="3"
                FontSize="{StaticResource FontSizeCaption}"
                Foreground="{StaticResource StatusWarningBrush}"
                Background="{StaticResource BtnWarningBgBrush}"
                BorderBrush="{StaticResource StatusWarningBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                Padding="8,4"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Name="CancelButton"
                IsVisible="{Binding IsLoading}"
                ToolTip.Tip="{Binding [tooltip.cancelRunningQuery], Source={x:Static loc:LocalizationService.Instance}}"
                AutomationProperties.Name="{Binding [preview.cancel], Source={x:Static loc:LocalizationService.Instance}}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="⏹" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [preview.cancel], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
          </StackPanel>
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Close button -->
        <Button Grid.Column="4"
                Content="✕"
                FontSize="{StaticResource FontSizeCaption}"
                Foreground="{StaticResource TextMutedBrush}"
                Background="Transparent"
                BorderThickness="0"
                Padding="8,4"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowCloseButton, ElementName=Root}"
                Name="CloseButton"
                ToolTip.Tip="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>
          </Button.Styles>
        </Button>
      </Grid>

      <!-- ── Tab bar ───────────────────────────────────────────────────────── -->
      <Border Grid.Row="1"
              Background="{StaticResource Bg0Brush}"
              BorderBrush="{StaticResource BorderSoftBrush}"
              BorderThickness="0,1,0,1"
              Padding="8,0">

        <Border.Styles>
          <Style Selector="Button.tab">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
          </Style>
          <Style Selector="Button.tab:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
          </Style>
          <Style Selector="Button.tab.active">
            <Setter Property="Foreground" Value="{StaticResource StatusInfoBrush}"/>
          </Style>
        </Border.Styles>

        <StackPanel Orientation="Horizontal" Spacing="0">

          <!-- Preview tab -->
          <Panel>
            <Button Classes="tab"
                    Name="TabPreviewButton"
                    Classes.active="{Binding ShowDataPreview}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="⊞" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding [preview.tab.preview], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <!-- active underline -->
            <Border Height="2"
                    Background="{StaticResource StatusInfoBrush}"
                    VerticalAlignment="Bottom"
                    Margin="4,0"
                    IsVisible="{Binding ShowDataPreview}"/>
          </Panel>

          <!-- SQL tab -->
          <Panel>
            <Button Classes="tab"
                    Name="TabSqlButton"
                    Classes.active="{Binding ShowLiveSql}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="&lt;/&gt;" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Foreground="{StaticResource CatStringBrush}"/>
                <TextBlock Text="{Binding [preview.tab.sql], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <!-- active underline -->
            <Border Height="2"
                    Background="{StaticResource CatStringBrush}"
                    VerticalAlignment="Bottom"
                    Margin="4,0"
                    IsVisible="{Binding ShowLiveSql}"/>
          </Panel>

        </StackPanel>
      </Border>

      <!-- ── Content area ───────────────────────────────────────────────────── -->
            <Border Grid.Row="2"
              IsVisible="{Binding ShowDataPreview}"
              CornerRadius="{StaticResource RadiusLGBottom}"
              ClipToBounds="True">
            <Grid>

        <!-- Running state -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
          <ProgressBar IsIndeterminate="True"
                       Width="200"
                       Height="3"
                       Background="{StaticResource BorderSoftBrush}"
                       Foreground="{StaticResource AccentBlueBrush}"
                       CornerRadius="{StaticResource RadiusXS}"/>
          <TextBlock FontSize="{StaticResource FontSizeBody}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center">
            <Run Text="{Binding [preview.running], Source={x:Static loc:LocalizationService.Instance}}"/>
            <Run Text="{Binding ElapsedMs}" Foreground="{StaticResource StatusInfoBrush}"/>
            <Run Text="{Binding [common.ms], Source={x:Static loc:LocalizationService.Instance}}"/>
          </TextBlock>
          <TextBlock Text="{Binding [preview.clickCancel], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Cancelled state -->
        <StackPanel IsVisible="{Binding IsCancelled}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
          <TextBlock Text="⏹" FontSize="{StaticResource FontSizeDisplay}" HorizontalAlignment="Center" Foreground="{StaticResource StatusWarningBrush}"/>
          <TextBlock Text="{Binding [preview.cancelled], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeLabel}" FontWeight="{StaticResource FontWeightTitle}" Foreground="{StaticResource StatusWarningBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding [preview.runAgain], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error state — structured diagnostic card -->
        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource BtnDangerBgBrush}"
                BorderBrush="{StaticResource StatusErrorBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMD}"
                Padding="20,16"
                MaxWidth="520">
          <StackPanel Spacing="12">

            <!-- Header: icon badge + category label -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border CornerRadius="{StaticResource RadiusSM}"
                      Background="{StaticResource BtnDangerBgBrush}"
                      Padding="7,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding DiagnosticIcon}"
                           FontSize="{StaticResource FontSizeTitle}"
                           VerticalAlignment="Center"/>
              </Border>
              <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding DiagnosticLabel}"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="{StaticResource FontWeightHeading}"
                           Foreground="{StaticResource StatusErrorBrush}"/>
                <TextBlock Text="{Binding [preview.failed], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
              </StackPanel>
            </StackPanel>

            <!-- Friendly message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource StatusErrorBrush}"
                       TextWrapping="Wrap"/>

            <!-- Suggestion box -->
            <Border CornerRadius="{StaticResource RadiusSM}"
                    Background="{StaticResource BtnSuccessBgBrush}"
                    BorderBrush="{StaticResource StatusOkBrush}"
                    BorderThickness="1"
                    Padding="10,8"
                    IsVisible="{Binding HasDiagnostic}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="💡"
                           FontSize="{StaticResource FontSizeCaption}"
                           VerticalAlignment="Top"
                           Margin="0,1,0,0"/>
                <TextBlock Text="{Binding DiagnosticSuggestion}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource StatusOkBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Technical details (collapsible) -->
            <Border CornerRadius="{StaticResource RadiusSM}"
                    Background="{StaticResource Bg0Brush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10,8"
                    IsVisible="{Binding HasTechnicalDetail}">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding [preview.technical], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           FontWeight="{StaticResource FontWeightHeading}"
                           Foreground="{StaticResource TextMutedBrush}"
                           LetterSpacing="1"/>
                <SelectableTextBlock Text="{Binding DiagnosticTechnical}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>

        <!-- Empty / no-query state -->
        <StackPanel IsVisible="{Binding HasData, Converter={x:Static BoolConverters.Not}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
          <!-- Only show when NOT loading and NOT error -->
          <TextBlock Text="{Binding [preview.noData], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeLabel}"
                     Foreground="{StaticResource TextMutedBrush}"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
          <TextBlock Text="{Binding [preview.f3Hint], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Name="ResultGrid"
                  IsVisible="{Binding HasData}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  Margin="0"/>
      </Grid>
      </Border>

      <!-- ── Live SQL view ──────────────────────────────────────────────────── -->
      <Border Grid.Row="2"
              IsVisible="{Binding ShowLiveSql}"
              CornerRadius="{StaticResource RadiusLGBottom}"
              ClipToBounds="True">
        <ctrl:LiveSqlBar DataContext="{Binding #Root.LiveSqlViewModel}"/>
      </Border>

    </Grid>
  </Border>
</UserControl>
