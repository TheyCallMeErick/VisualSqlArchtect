<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             x:Class="AkkornStudio.UI.Controls.SqlEditor.SqlEditorSchemaBrowserControl"
             x:DataType="vm:SqlEditorViewModel">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Margin="0,0,0,8"
            Background="{StaticResource Bg1Brush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusLG}"
            Padding="10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding SchemaSearchText}"
                 Watermark="{Binding [sqlEditor.sidebar.schema.searchWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                 FontSize="{StaticResource FontSizeCaption}"
                 Background="{StaticResource Bg2Brush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderSubtleBrush}"/>
        <Button Grid.Column="1"
                Margin="8,0,0,0"
                Padding="10,2"
                MinHeight="24"
                Click="ClearSchemaFilterButton_Click"
                Content="{Binding [common.clear], Source={x:Static loc:LocalizationService.Instance}}"/>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  IsVisible="{Binding HasFilteredSchemaTables}">
      <ItemsControl ItemsSource="{Binding FilteredSchemaTables}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SqlEditorSchemaTableItem">
            <Expander Margin="0,0,0,6">
                <Expander.Header>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,4,0">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding FullName}"
                                 FontWeight="{StaticResource FontWeightTitle}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Columns.Count, StringFormat='Colunas: {0}'}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <Border Background="#2252C6A8" CornerRadius="10" Padding="6,2">
                        <TextBlock Text="{Binding PrimaryKeyCount, StringFormat='PK {0}'}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                      </Border>
                      <Border Background="#224E7FFF" CornerRadius="10" Padding="6,2">
                        <TextBlock Text="{Binding ForeignKeyCount, StringFormat='FK {0}'}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                      </Border>
                      <Button Padding="8,2"
                              MinHeight="22"
                              Tag="{Binding FullName}"
                              Click="InsertTableButton_Click">
                        <mi:MaterialIcon Kind="Plus" Width="12" Height="12"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Expander.Header>

              <ItemsControl ItemsSource="{Binding Columns}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SqlEditorSchemaColumnItem">
                    <Border Margin="0,3,0,0"
                            Padding="8,6"
                            CornerRadius="{StaticResource RadiusSM}"
                            Background="{StaticResource Bg1Brush}">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <mi:MaterialIcon Grid.Column="0"
                                         Kind="{Binding TypeIcon}"
                                         Width="14"
                                         Height="14"
                                         VerticalAlignment="Center"
                                         Foreground="{StaticResource AccentPrimaryHoverBrush}"/>

                        <StackPanel Grid.Column="1" Spacing="1">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontWeight="{StaticResource FontWeightMonoStrong}"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding DataType}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                          </StackPanel>
                          <TextBlock Text="{Binding RelatedTable, StringFormat='Relaciona com {0}'}"
                                     IsVisible="{Binding HasRelationship}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{StaticResource AccentPrimaryHoverBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <mi:MaterialIcon Kind="KeyVariant"
                                           Width="13"
                                           Height="13"
                                           IsVisible="{Binding IsPrimaryKey}"
                                           Foreground="#5CE59D"/>
                          <mi:MaterialIcon Kind="SourceBranch"
                                           Width="13"
                                           Height="13"
                                           IsVisible="{Binding IsForeignKey}"
                                           Foreground="#72B8FF"/>
                          <mi:MaterialIcon Kind="Magnify"
                                           Width="13"
                                           Height="13"
                                           IsVisible="{Binding IsIndexed}"
                                           Foreground="#FFCF75"/>
                          <mi:MaterialIcon Kind="CertificateOutline"
                                           Width="13"
                                           Height="13"
                                           IsVisible="{Binding IsUnique}"
                                           Foreground="#D6B5FF"/>
                          <Button Padding="6,2"
                                  MinHeight="20"
                                  Tag="{Binding Name}"
                                  Click="InsertColumnButton_Click">
                            <mi:MaterialIcon Kind="Plus" Width="12" Height="12"/>
                          </Button>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <TextBlock Grid.Row="1"
               Text="{Binding SchemaEmptyText}"
               IsVisible="{Binding IsSchemaEmpty}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="{StaticResource FontSizeCaption}"
               TextWrapping="Wrap"/>
  </Grid>
</UserControl>
