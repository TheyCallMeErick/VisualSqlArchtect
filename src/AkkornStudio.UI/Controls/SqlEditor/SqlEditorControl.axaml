<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:ctrl="using:AkkornStudio.UI.Controls.SqlEditor"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.SqlEditor.SqlEditorControl"
             x:DataType="vm:SqlEditorViewModel">
  <UserControl.Styles>
    <Style Selector="TextBlock.exec-status">
      <Setter Property="Foreground" Value="{StaticResource StatusInfoBrush}"/>
    </Style>
    <Style Selector="TextBlock.exec-status.error">
      <Setter Property="Foreground" Value="{StaticResource StatusErrorBrush}"/>
    </Style>
    <Style Selector="Border.sql-connection-badge">
      <Setter Property="MaxWidth" Value="300"/>
    </Style>
    <Style Selector="Button.sql-connection-launch">
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.sql-connection-launch:pointerover">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="RenderTransform" Value="scale(1.01)"/>
    </Style>
    <Style Selector="Button.sql-tool-action">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sql-tool-action:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.03)"/>
    </Style>
    <Style Selector="Button.sql-tool-action:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.sql-tool-action.explain">
      <Setter Property="Background" Value="{StaticResource BtnInfoBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource BtnInfoFgBrush}"/>
    </Style>
    <Style Selector="Button.sql-tool-action.explain:pointerover">
      <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.sql-tool-action.benchmark">
      <Setter Property="Background" Value="{StaticResource BtnWarningBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource StatusWarningBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource BtnWarningFgBrush}"/>
    </Style>
  </UserControl.Styles>
  <Grid RowDefinitions="Auto,Auto,*,Auto"
        ClipToBounds="True">
    <ctrl:SqlEditorTabBar Grid.Row="0"/>

    <Grid Grid.Row="1"
          Margin="10,8,10,0"
          ColumnDefinitions="Auto,*">
      <Button Grid.Column="0"
              Classes="icon-ghost sql-connection-launch"
              Command="{Binding OpenConnectionSwitcherCommand}">
        <Grid>
          <Border Classes="badge sql-connection-badge"
                  IsVisible="{Binding IsNeutralConnectionContext}"
                  Background="{StaticResource Bg2Brush}">
            <TextBlock Text="{Binding ActiveConnectionContextBadgeText}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"/>
          </Border>
          <Border Classes="badge sql-connection-badge"
                  IsVisible="{Binding IsProductionConnectionContext}"
                  Background="#33E16174">
            <TextBlock Text="{Binding ActiveConnectionContextBadgeText}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"/>
          </Border>
          <Border Classes="badge sql-connection-badge"
                  IsVisible="{Binding IsStagingConnectionContext}"
                  Background="#33D9A441">
            <TextBlock Text="{Binding ActiveConnectionContextBadgeText}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"/>
          </Border>
          <Border Classes="badge sql-connection-badge"
                  IsVisible="{Binding HasNoActiveConnection}"
                  Background="{StaticResource Bg2Brush}">
            <TextBlock Text="{Binding ActiveConnectionContextBadgeText}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"/>
          </Border>
        </Grid>
      </Button>
    </Grid>

    <Grid Grid.Row="2" ClipToBounds="True">
      <Border Grid.Row="0"
              Classes="surface-panel"
              Margin="10,10,10,12"
              ClipToBounds="True">
        <ae:TextEditor x:Name="SqlTextEditor"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{StaticResource FontSizeLabel}"
                       IsReadOnly="False"
                       ShowLineNumbers="True"
                       WordWrap="False"
                       Background="{StaticResource Bg0Brush}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
      </Border>

      <Border Grid.Row="0"
              x:Name="GoToLineOverlay"
              Classes="surface-floating"
              IsVisible="False"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="22,18,22,0"
              Padding="10,8"
              MinWidth="210">
        <StackPanel Spacing="6">
          <TextBlock x:Name="GoToLineLabel"
                     Text="Ir para linha"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextSecondaryBrush}"/>
          <TextBox x:Name="GoToLineInput"
                   Classes="field"
                   KeyDown="GoToLineInput_OnKeyDown"
                   MinWidth="140"
                   HorizontalAlignment="Stretch"
                   Watermark="Numero da linha"/>
        </StackPanel>
      </Border>

      <Panel IsVisible="{Binding ShouldShowResultsSheet}"
             ZIndex="40">
        <Border Background="{StaticResource MacroScrimBrush}"
                PointerPressed="ResultsModalBackdrop_OnPointerPressed"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>

        <Border Width="1040"
                Classes="surface-floating"
                MaxWidth="1040"
                Height="640"
                MaxHeight="700"
                MinHeight="340"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0"
                  Classes="surface-floating-header"
                  ColumnDefinitions="*,Auto"
                  Margin="14,12,14,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="Table" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="{Binding [sqlEditor.results.title], Source={x:Static loc:LocalizationService.Instance}}"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="{StaticResource FontWeightTitle}"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <Button Grid.Column="1"
                      Classes="icon-ghost"
                      Width="28"
                      Height="28"
                      Command="{Binding CloseResultsSheetCommand}">
                <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
              </Button>
            </Grid>

            <ctrl:SqlEditorResultPanel Grid.Row="1" Margin="12,0,12,12"/>
          </Grid>
        </Border>
      </Panel>

      <Panel IsVisible="{Binding IsConnectionSwitcherOpen}"
             ZIndex="60">
        <Border Background="{StaticResource MacroScrimBrush}"
                PointerPressed="ConnectionSwitcherBackdrop_OnPointerPressed"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>

        <Border Width="560"
                Classes="surface-floating"
                MaxWidth="620"
                MinHeight="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  Classes="surface-floating-header"
                  ColumnDefinitions="*,Auto"
                  Margin="14,12,14,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="DatabaseCogOutline"
                                 Width="16"
                                 Height="16"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource AccentBlueBrush}"/>
                <TextBlock Text="Trocar conexão SQL"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="{StaticResource FontWeightTitle}"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <Button Grid.Column="1"
                      Classes="icon-ghost"
                      Command="{Binding CloseConnectionSwitcherCommand}">
                <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
              </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="14,6,14,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="10">
                <Border Classes="callout-subtle">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Conexão"
                               Classes="section-label"/>
                    <TextBlock Grid.Column="1"
                               Grid.Row="0"
                               Text="{Binding CurrentConnectionProfileLabel}"
                               FontWeight="{StaticResource FontWeightStrong}"/>

                    <TextBlock Grid.Row="1" Text="Provider" Classes="section-label"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding CurrentConnectionProviderLabel}"/>

                    <TextBlock Grid.Row="2" Text="Banco" Classes="section-label"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding CurrentConnectionDatabaseLabel}"/>

                    <TextBlock Grid.Row="3" Text="Host" Classes="section-label"/>
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding CurrentConnectionHostLabel}"/>

                    <TextBlock Grid.Row="4" Text="Usuário / URL" Classes="section-label"/>
                    <StackPanel Grid.Column="1" Grid.Row="4" Spacing="2">
                      <TextBlock Text="{Binding CurrentConnectionUserLabel}"/>
                      <TextBlock Text="{Binding CurrentConnectionUrlLabel}"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{StaticResource TextMutedBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <TextBlock Text="Conexão" Classes="section-label"/>
                <ComboBox ItemsSource="{Binding ConnectionSwitcherProfiles}"
                          SelectedItem="{Binding ConnectionSwitcherSelectedProfile}"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SqlEditorConnectionProfileOption">
                      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <mi:MaterialIcon Kind="DatabaseOutline"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"
                                         Foreground="{StaticResource AccentPrimaryBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   FontWeight="{StaticResource FontWeightStrong}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1"
                                   Grid.Row="1"
                                   Text="{Binding Provider}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                      </Grid>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel IsVisible="{Binding CanChangeDatabaseInSwitcher}" Spacing="6">
                  <TextBlock Text="Banco/Catalog" Classes="section-label"/>
                  <ComboBox ItemsSource="{Binding ConnectionSwitcherDatabases}"
                            SelectedItem="{Binding ConnectionSwitcherSelectedDatabase}"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Classes="surface-floating-footer"
                    Padding="14,10">
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Spacing="8">
                <Button Classes="secondary compact"
                        Command="{Binding CloseConnectionSwitcherCommand}"
                        Content="Cancelar"/>
                <Button Classes="primary compact"
                        Command="{Binding ApplyConnectionSwitcherCommand}"
                        Content="Aplicar"/>
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Panel>
    </Grid>

    <Border Grid.Row="3"
            Background="{StaticResource Bg1Brush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="10,6">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center">
        <Button Grid.Column="0"
                Classes="secondary compact"
                Margin="0,0,10,0"
                Content="{Binding ExecuteOrCancelButtonText}"
                IsEnabled="{Binding CanExecuteOrCancel}"
                ToolTip.Tip="{Binding ExecuteOrCancelTooltipText}"
                Click="ExecuteOrCancelPrimaryButton_Click"/>

        <Button Grid.Column="1"
                Classes="secondary compact sql-tool-action explain"
                Margin="0,0,8,0"
                IsEnabled="{Binding IsExplainRunning, Converter={x:Static BoolConverters.Not}}"
                Click="ExplainButton_Click">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="TableSearch" Width="12" Height="12" VerticalAlignment="Center"/>
            <TextBlock Text="Explain" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Button Grid.Column="2"
                Classes="secondary compact sql-tool-action benchmark"
                Margin="0,0,10,0"
                IsEnabled="{Binding IsBenchmarkRunning, Converter={x:Static BoolConverters.Not}}"
                Click="BenchmarkButton_Click">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="TimerOutline" Width="12" Height="12" VerticalAlignment="Center"/>
            <TextBlock Text="Benchmark" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Button Grid.Column="3"
                Classes="secondary compact"
                Margin="0,0,8,0"
                Content="Executar tudo"
                Click="ExecuteAllButton_Click"/>

        <Button Grid.Column="4"
                Classes="secondary compact"
                Margin="0,0,10,0"
                Content="Formatar SQL"
                Click="FormatSqlButton_Click"/>

        <ProgressBar Grid.Column="5"
                     IsIndeterminate="True"
                     Width="72"
                     Height="3"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsExecuting}"/>

        <TextBlock Grid.Column="6"
                   Margin="0,0,10,0"
                   Classes.exec-status="True"
                   Classes.error="{Binding HasExecutionError}"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Text="{Binding ExecutionStatusText}"
                   TextTrimming="CharacterEllipsis"/>

        <TextBlock Grid.Column="7"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   IsVisible="{Binding HasSignatureHelp}"
                   Text="{Binding SignatureHelpText}"
                   TextTrimming="CharacterEllipsis"/>

        <TextBlock Grid.Column="8"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   IsVisible="{Binding HasHoverDocumentation}"
                   Text="{Binding HoverDocumentationText}"
                   TextTrimming="CharacterEllipsis"/>

        <TextBlock Grid.Column="9"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Text="{Binding ResultSummaryText}"/>

        <Button Grid.Column="10"
                Classes="secondary compact"
                Margin="0,0,10,0"
                IsVisible="{Binding CanReopenResultsSheet}"
                Command="{Binding ReopenResultsSheetCommand}"
                Content="{Binding RestoreResultsButtonText}"/>

        <Button Grid.Column="11"
                Classes="icon-ghost"
                Margin="0,0,10,0"
                Click="CursorPositionButton_Click"
                ToolTip.Tip="{Binding CursorPositionTooltipText}">
          <TextBlock VerticalAlignment="Center"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Text="{Binding CursorPositionText}"/>
        </Button>

        <TextBlock Grid.Column="12"
             Margin="0,0,10,0"
             VerticalAlignment="Center"
             FontSize="{StaticResource FontSizeCaption}"
             Foreground="{StaticResource TextSecondaryBrush}"
             Text="{Binding ActiveProviderStatusText}"/>

        <TextBlock Grid.Column="13"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Text="{Binding IndentationStatusText}"/>
      </Grid>
    </Border>

    <ctrl:MutationConfirmDialog Grid.Row="3"
                                IsVisible="{Binding HasPendingMutationConfirmation}"
                                Margin="0,30,0,0"/>

    <Border Grid.Row="3"
            Classes="callout-subtle warning"
            IsVisible="{Binding HasPendingCloseTabConfirmation}"
            Margin="0,30,0,0"
            Padding="10,8">
      <StackPanel Spacing="6">
        <TextBlock Text="{Binding PendingCloseTabMessage}"
                   FontWeight="{StaticResource FontWeightTitle}"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="{Binding [sqlEditor.tab.closeAnyway], Source={x:Static loc:LocalizationService.Instance}}"
                  Classes="Danger"
                  Command="{Binding ConfirmPendingCloseTabCommand}"/>
          <Button Content="{Binding [sqlEditor.tab.keepTab], Source={x:Static loc:LocalizationService.Instance}}"
                  Classes="secondary compact"
                  Command="{Binding CancelPendingCloseTabCommand}"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
