<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ervm="using:AkkornStudio.UI.ViewModels.ErDiagram"
             xmlns:erc="using:AkkornStudio.UI.Controls.ErDiagram"
             xmlns:ctrl="using:AkkornStudio.UI.Controls"
             xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
             x:Class="AkkornStudio.UI.Controls.ErDiagram.ErCanvasControl"
             x:DataType="ervm:ErCanvasViewModel">

  <Grid RowDefinitions="Auto,*" Background="{StaticResource Bg0Brush}">
    <Border Grid.Row="0"
            Classes="app-header-shell"
            Padding="12,8">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="16">
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding EntityCount, StringFormat=Entidades: {0}}"/>
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding EdgeCount, StringFormat=Relações: {0}}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="tb compact"
                  Click="CenterSelection_Click"
                  IsVisible="{Binding HasSelectionDetails}"
                  Padding="8,4">
            <TextBlock Text="Centralizar selecao"/>
          </Button>
          <Button Classes="tb compact"
                  Click="FitSelection_Click"
                  IsVisible="{Binding HasSelectionDetails}"
                  Padding="8,4">
            <TextBlock Text="Enquadrar selecao"/>
          </Button>
          <Button Classes="tb compact"
                  Command="{Binding RefreshCommand}"
                  Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Atualizar"/>
            </StackPanel>
          </Button>
          <TextBlock Classes="txt-body"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Text="Incluir Views"
                     VerticalAlignment="Center"/>
          <CheckBox IsChecked="{Binding IncludeViews}" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">
      <Border IsVisible="{Binding HasTechnicalWarnings}"
              Classes="callout-subtle"
              BorderThickness="0,0,0,1"
              CornerRadius="0"
              Padding="12,8">
        <StackPanel Spacing="6">
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding StatusMessage}"/>
          <ItemsControl ItemsSource="{Binding TechnicalWarnings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Classes="txt-body"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding .}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              IsVisible="{Binding HasSelectionDetails}"
              Classes="callout-subtle"
              BorderThickness="0,0,0,1"
              CornerRadius="0"
              Padding="12,8">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Classes="txt-label"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{Binding SelectionTitle}"
                       VerticalAlignment="Center"/>
            <Button Classes="tb compact"
                    Command="{Binding OpenSelectionInQueryCommand}"
                    IsVisible="{Binding HasSelectionJoinPredicate}"
                    Padding="8,4">
              <TextBlock Text="Abrir no Query"/>
            </Button>
          </StackPanel>
          <TextBlock Classes="txt-label"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Text="{Binding SelectionSubtitle}"/>
          <TextBlock Classes="txt-body"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Text="{Binding SelectionBody}"
                     TextWrapping="Wrap"/>
          <Border Classes="callout-subtle"
                  Background="{StaticResource Bg0Brush}"
                  Padding="8,6"
                  IsVisible="{Binding HasSelectionJoinPredicate}">
            <TextBlock FontFamily="{StaticResource MonoFont}"
                       Foreground="{StaticResource TextAccentBrush}"
                       Text="{Binding SelectionJoinPredicate}"
                       TextWrapping="Wrap"/>
          </Border>
        </StackPanel>
      </Border>

      <ctrl:InfiniteCanvasCoreControl x:Name="ViewportSurface"
                                  Grid.Row="2"
                                  Viewport="{Binding}"
                                  PointerWheelChanged="Viewport_PointerWheelChanged"
                                  PointerPressed="Viewport_PointerPressed"
                                  PointerMoved="Viewport_PointerMoved"
                                  PointerReleased="Viewport_PointerReleased">
        <ctrl:InfiniteCanvasCoreControl.SceneContent>
          <Canvas x:Name="SceneContentCanvas"
                  x:DataType="ervm:ErCanvasViewModel"
                  DataContext="{Binding DataContext, ElementName=ViewportSurface}"
                  Background="Transparent"
                  PointerPressed="CanvasBackground_PointerPressed">
            <ItemsControl x:Name="EdgeItems"
                          ItemsSource="{Binding Edges}"
                          Width="{Binding Width, ElementName=SceneContentCanvas}"
                          Height="{Binding Height, ElementName=SceneContentCanvas}"
                          ClipToBounds="False">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>

              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ervm:ErRelationEdgeViewModel">
                  <Canvas>
                    <shapes:Polyline Points="{Binding RoutePoints}"
                                     Stroke="#00FFFFFF"
                                     StrokeThickness="12"
                                     PointerPressed="Edge_PointerPressed"/>
                    <shapes:Polyline Points="{Binding RoutePoints}"
                                     Stroke="{StaticResource TextMutedBrush}"
                                     StrokeThickness="2"/>
                    <shapes:Polyline Points="{Binding RoutePoints}"
                                     Stroke="{StaticResource AccentPrimaryHoverBrush}"
                                     StrokeThickness="3"
                                     IsVisible="{Binding IsSelected}"/>
                    <Border Canvas.Left="{Binding LabelX}"
                            Canvas.Top="{Binding LabelY}"
                            Background="{StaticResource Bg1Brush}"
                            BorderBrush="{StaticResource AccentPrimaryHoverBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPill}"
                            Padding="6,2"
                            IsVisible="{Binding IsSelected}">
                      <TextBlock Classes="txt-body"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="{Binding Cardinality}"/>
                    </Border>
                  </Canvas>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="EntityItems"
                          ItemsSource="{Binding Entities}"
                          Width="{Binding Width, ElementName=SceneContentCanvas}"
                          Height="{Binding Height, ElementName=SceneContentCanvas}"
                          ClipToBounds="False">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>

              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ervm:ErEntityNodeViewModel">
                  <erc:ErEntityControl Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Canvas>
        </ctrl:InfiniteCanvasCoreControl.SceneContent>
        <ctrl:InfiniteCanvasCoreControl.OverlayContent>
          <Canvas x:DataType="ervm:ErCanvasViewModel"
            DataContext="{Binding DataContext, ElementName=ViewportSurface}"
                  IsHitTestVisible="False">
            <ctrl:CanvasMarqueeAdorner x:Name="SelectionMarquee"
                                       Fill="{StaticResource SelectedOverlayBrush}"
                                       Stroke="{StaticResource BorderFocusBrush}"
                                       StrokeThickness="1"/>
            <ctrl:CanvasFocusAdorner x:Name="FocusOverlay"
                                     Stroke="{StaticResource AccentPrimaryHoverBrush}"
                                     StrokeThickness="2"/>
          </Canvas>
        </ctrl:InfiniteCanvasCoreControl.OverlayContent>
      </ctrl:InfiniteCanvasCoreControl>
    </Grid>
  </Grid>
</UserControl>
