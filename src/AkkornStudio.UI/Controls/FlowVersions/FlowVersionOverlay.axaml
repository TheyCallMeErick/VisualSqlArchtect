<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels.Canvas"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.FlowVersionOverlay"
             x:DataType="vm:FlowVersionOverlayViewModel">

  <UserControl.Styles>

    <!-- Version row -->
    <Style Selector="Border.version-row">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,3"/>
    </Style>
    <Style Selector="Border.version-row:pointerover">
      <Setter Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
    </Style>

    <!-- Diff badge -->
    <Style Selector="Border.diff-add">
      <Setter Property="Background"  Value="{StaticResource BtnSuccessBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource StatusOkBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusXS}"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>
    <Style Selector="Border.diff-remove">
      <Setter Property="Background"  Value="{StaticResource BtnDangerBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource StatusErrorBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusXS}"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>
    <Style Selector="Border.diff-modify">
      <Setter Property="Background"  Value="{StaticResource BtnWarningBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource StatusWarningBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusXS}"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Overlay panel ══════════════════════════════════════════════════════ -->
  <Border MaxWidth="540"
      MaxHeight="680"
          Classes="surface-floating">

      <Grid RowDefinitions="Auto,*,Auto">

      <!-- ── Header ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
          Classes="surface-floating-header"
          Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Icon -->
          <Border Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="{StaticResource RadiusSM}"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderFocusBrush}"
                  BorderThickness="1"
                  Margin="0,0,8,0">
            <mi:MaterialIcon Kind="ClipboardTextHistory"
                             Width="13" Height="13"
                             Foreground="{StaticResource AccentPrimaryHoverBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [flowVersion.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="{StaticResource FontWeightTitle}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding [flowVersion.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>

          <!-- Close button -->
          <Button Grid.Column="2"
              Classes="modal-close-btn"
                  Name="CloseBtn">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

          <!-- ── New checkpoint row ────────────────────────────────────────────── -->
          <Border Padding="12,10">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding [flowVersion.saveCheckpoint], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"/>

              <TextBox Classes="field"
                       Text="{Binding NewLabel}"
                       Watermark="{Binding [flowVersion.watermark], Source={x:Static loc:LocalizationService.Instance}}"
                       Padding="8,5"
                       Name="LabelBox"/>
            </StackPanel>
          </Border>

          <!-- Divider -->
          <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

          <!-- ── Diff mode summary ─────────────────────────────────────────────── -->
          <Border Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding DiffSummary}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1"
                     Text="{Binding [flowVersion.compareMode], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource AccentPrimaryHoverBrush}"
                     IsVisible="{Binding IsDiffMode}"/>
            </Grid>
          </Border>

          <!-- Divider -->
          <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

          <!-- ── Diff base selector (visible in diff mode) ─────────────────────── -->
          <Border Padding="12,8"
                  IsVisible="{Binding IsDiffMode}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding [flowVersion.selectBase], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource AccentPrimaryHoverBrush}"/>
              <ComboBox ItemsSource="{Binding Versions}"
                        SelectedItem="{Binding DiffBaseVersion}"
                        Background="{StaticResource Bg0Brush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="{StaticResource FontSizeCaption}"
                        HorizontalAlignment="Stretch"
                        Name="DiffBaseCombo">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:FlowVersionRowViewModel">
                    <TextBlock Text="{Binding Label}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="{Binding [flowVersion.clickAny], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </Border>

          <!-- ── Version list ──────────────────────────────────────────────────── -->
          <Border Margin="8,4">
            <StackPanel>

              <!-- Empty state -->
              <Border Padding="16,20"
                      IsVisible="{Binding HasVersions, Converter={x:Static BoolConverters.Not}}">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                  <mi:MaterialIcon Kind="ClipboardTextHistory"
                                   Width="24" Height="24"
                                   Foreground="{StaticResource BorderSubtleBrush}"
                                   HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding [flowVersion.noCheckpoints], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="{StaticResource FontSizeBody}"
                             Foreground="{StaticResource TextMutedBrush}"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding [flowVersion.noCheckpointsHint], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="{StaticResource FontSizeCaption}"
                             Foreground="{StaticResource TextMutedBrush}"
                             HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>

              <!-- Version rows -->
              <ItemsControl ItemsSource="{Binding Versions}"
                            IsVisible="{Binding HasVersions}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:FlowVersionRowViewModel">
                    <Border Classes="version-row">
                      <Grid RowDefinitions="Auto,Auto">

                    <!-- Row 0: Label + timestamp + buttons -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto">

                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="{StaticResource FontWeightTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding CreatedAtFormatted}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{StaticResource TextMutedBrush}"
                                     FontFamily="{StaticResource MonoFont}"/>
                          <TextBlock Text="{Binding NodeCount}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                      </StackPanel>

                      <!-- Compare button -->
                      <Button Grid.Column="1"
                              Classes="modal-footer-secondary-btn"
                              Margin="6,0,4,0"
                              Tag="{Binding Id}"
                              Name="CompareBtn">
                        <mi:MaterialIcon Kind="Compare" Width="12" Height="12"/>
                      </Button>

                      <!-- Restore button -->
                      <Button Grid.Column="2"
                              Classes="modal-footer-secondary-btn"
                              Margin="0,0,4,0"
                              Tag="{Binding Id}"
                              Name="RestoreBtn">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <mi:MaterialIcon Kind="Restore" Width="12" Height="12"/>
                          <TextBlock Text="{Binding [flowVersion.restore], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>
                      </Button>

                      <!-- Delete button -->
                      <Button Grid.Column="3"
                              Classes="modal-close-btn"
                              Tag="{Binding Id}"
                              Name="DeleteBtn">
                        <mi:MaterialIcon Kind="TrashCanOutline" Width="12" Height="12"/>
                      </Button>
                    </Grid>

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

            </StackPanel>
          </Border>

          <!-- ── Diff results ──────────────────────────────────────────────────── -->
          <Border IsVisible="{Binding HasDiffItems}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="0,1,0,0">

            <StackPanel>
              <Border Padding="12,8">
                <TextBlock Text="{Binding [flowVersion.diffResults], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           FontWeight="{StaticResource FontWeightTitle}"
                           Foreground="{StaticResource AccentPrimaryHoverBrush}"/>
              </Border>

              <ScrollViewer MaxHeight="200"
                            Margin="8,0,8,8"
                            HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DiffItems}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiffItemViewModel">
                      <Grid ColumnDefinitions="14,*" Margin="0,1">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Icon}"
                                   Foreground="{Binding KindBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="{StaticResource FontWeightHeading}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Description}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="2"
              Classes="surface-floating-footer"
              Padding="12,10">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding DiffSummary}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
              Classes="modal-footer-secondary-btn"
                  Name="DiffModeBtn"
                  Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Compare" Width="12" Height="12"/>
              <TextBlock Text="{Binding [flowVersion.compareMode], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="2"
              Classes="modal-footer-primary-btn"
                  Name="SaveBtn">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <mi:MaterialIcon Kind="ContentSave" Width="12" Height="12"/>
              <TextBlock Text="{Binding [flowVersion.saveCheckpoint], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

    </Grid>
  </Border>
</UserControl>
