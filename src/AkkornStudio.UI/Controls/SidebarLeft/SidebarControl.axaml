<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:ctrl="using:AkkornStudio.UI.Controls"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.SidebarControl"
             x:DataType="vm:SidebarViewModel"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

  <UserControl.Styles>
  </UserControl.Styles>

  <Grid RowDefinitions="42,*,Auto">

    <!-- Tab Bar (Header) -->
    <Border Grid.Row="0"
            Classes="surface-panel">
      <StackPanel Orientation="Horizontal" Spacing="0">

        <!-- Nodes Tab -->
        <Button x:Name="NodesTabButton"
                Classes="panel-tab"
                Classes.active="{Binding ShowNodes}"
                Command="{Binding SelectNodesCommand}"
          Content="{Binding [sidebar.tab.nodes], Source={x:Static loc:LocalizationService.Instance}}"/>

        <!-- Connection Tab -->
        <Button x:Name="ConnectionTabButton"
                Classes="panel-tab"
                Classes.active="{Binding ShowConnection}"
                Command="{Binding SelectConnectionCommand}"
          Content="{Binding [sidebar.tab.connection], Source={x:Static loc:LocalizationService.Instance}}"/>

      </StackPanel>
    </Border>

    <!-- Tab Content Area -->
    <Grid Grid.Row="1" RowDefinitions="*">
      <!-- Nodes Tab -->
      <Grid IsVisible="{Binding ShowNodes}" Grid.Column="0">
        <ctrl:NodesListControl x:Name="NodesControl"
                               DataContext="{Binding NodesList}"/>
      </Grid>

      <!-- Connection Tab -->
      <Grid IsVisible="{Binding ShowConnection}" Grid.Column="0" VerticalAlignment="Stretch">
        <ctrl:ConnectionTabControl x:Name="ConnectionControl"
                                   DataContext="{Binding ConnectionManager}"
                                   VerticalAlignment="Stretch"
                                   HorizontalAlignment="Stretch"/>
      </Grid>

    </Grid>

    <!-- Footer (Add Node button) -->
    <Border Grid.Row="2"
            Classes="surface-panel"
            Padding="8,6"
            IsVisible="{Binding ShowNodes}">
      <Grid>
        <Button Content="{Binding [sidebar.addNode], Source={x:Static loc:LocalizationService.Instance}}"
        Classes="success compact"
          Command="{Binding AddNodeCommand}"
              FontWeight="{StaticResource FontWeightLabel}"
                HorizontalAlignment="Stretch"/>
      </Grid>
    </Border>
  </Grid>

</UserControl>
