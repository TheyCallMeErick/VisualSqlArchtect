<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:ctrl="using:AkkornStudio.UI.Controls"
             xmlns:shell="using:AkkornStudio.UI.Controls.Shell"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Name="Root"
             x:Class="AkkornStudio.UI.Controls.Shell.OutputPreviewModalControl"
             x:DataType="vm:OutputPreviewModalViewModel">

  <UserControl.Styles>
    <Style Selector="ae|TextEditor.ddl-output">
      <Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>
  </UserControl.Styles>

  <Panel IsVisible="{Binding IsVisible}" ZIndex="90">
    <Border Background="{StaticResource MacroScrimBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

        <Border IsVisible="{Binding ShowShellCard}"
            Classes="surface-floating"
          Width="1180"
            MaxWidth="1180"
            Height="700"
            MaxHeight="700"
            MinHeight="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            RenderTransformOrigin="50%,50%"
            RenderTransform="scale(1)">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0"
              Classes="surface-floating-header"
              ColumnDefinitions="*,Auto"
              Margin="14,12,14,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="EyeOutline" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource AccentBlueBrush}"/>
            <StackPanel Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightTitle}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding [preview.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          <Button Grid.Column="1"
                  Command="{Binding CloseCommand}"
                  Classes="icon-ghost"
                  ToolTip.Tip="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>

        <Border Grid.Row="1"
                Classes="surface-card"
                Margin="0,0,0,2"
                Padding="8,0,8,0">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="panel-tab"
                    Classes.active="{Binding ShowPrimaryContent}"
                    Command="{Binding ShowPrimaryTabCommand}"
                    Content="{Binding PrimaryTabLabel}"/>
             <Button Classes="panel-tab"
               Classes.active="{Binding ShowCanvasDiagnosticsContent}"
               IsVisible="{Binding HasCanvasDiagnostics}"
               Command="{Binding ShowCanvasDiagnosticsTabCommand}"
               Content="{Binding CanvasDiagnosticsTabLabel}"/>
             <Button Classes="panel-tab"
               Classes.active="{Binding ShowStructureDiagnosticsContent}"
               IsVisible="{Binding HasStructureDiagnostics}"
               Command="{Binding ShowStructureDiagnosticsTabCommand}"
               Content="{Binding StructureDiagnosticsTabLabel}"/>
             <Button Classes="panel-tab"
               Classes.active="{Binding ShowSchemaCompareContent}"
               IsVisible="{Binding HasSchemaCompare}"
               Command="{Binding ShowSchemaCompareTabCommand}"
               Content="{Binding SchemaCompareTabLabel}"/>
          </StackPanel>
        </Border>

        <Grid Grid.Row="2">
          <Border IsVisible="{Binding ShowQueryPrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="12">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}">
                  <Run Text="{Binding [preview.providerLabel], Source={x:Static loc:LocalizationService.Instance}}"/>
                  <Run Text=": "/>
                  <Run Text="{Binding QueryProviderLabel}"/>
                </TextBlock>
              </StackPanel>

              <ae:TextEditor Grid.Row="1"
                             Name="QuerySqlEditor"
                             Classes="ddl-output"
                             IsReadOnly="True"
                             ShowLineNumbers="True"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
            </Grid>
          </Border>

          <Border IsVisible="{Binding ShowDdlPrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="12">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}">
                  <Run Text="{Binding [preview.providerLabel], Source={x:Static loc:LocalizationService.Instance}}"/>
                  <Run Text=": "/>
                  <Run Text="{Binding DdlProviderLabel}"/>
                </TextBlock>
                <TextBlock Text="{Binding [preview.ddlDiagnosticsHint], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextMutedBrush}"/>
              </StackPanel>

              <ae:TextEditor Grid.Row="1"
                             Name="DdlSqlEditor"
                             Classes="ddl-output"
                             IsReadOnly="True"
                             ShowLineNumbers="True"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
            </Grid>
          </Border>

            <Border IsVisible="{Binding ShowCanvasDiagnosticsContent}"
              Background="{StaticResource Bg0Brush}">
              <ctrl:SidebarDiagnosticsControl DataContext="{Binding Diagnostics}" />
            </Border>

            <Border IsVisible="{Binding ShowStructureDiagnosticsContent}"
              Background="{StaticResource Bg0Brush}">
              <shell:DdlSchemaAnalysisWorkspaceControl DataContext="{Binding DdlTool}" />
            </Border>

            <Border IsVisible="{Binding ShowSchemaCompareContent}"
              Background="{StaticResource Bg0Brush}">
              <shell:DdlSchemaCompareWorkspaceControl DataContext="{Binding DdlSchemaCompareTool}" />
            </Border>

          <Border IsVisible="{Binding ShowUnavailablePrimaryContent}"
                  Background="{StaticResource Bg0Brush}"
                  Padding="16">
            <TextBlock Text="{Binding UnavailableMessage}"
                       TextWrapping="Wrap"
                       FontSize="{StaticResource FontSizeLabel}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
        </Grid>

        <Border Grid.Row="3"
                Classes="surface-floating-footer"
                Padding="14,10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding PrimaryTabLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Command="{Binding CloseCommand}"
                    Classes="secondary compact"
                    Content="{Binding [preview.close], Source={x:Static loc:LocalizationService.Instance}}"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Panel IsVisible="{Binding ShowSqlBenchmarkPrimaryContent}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           ZIndex="91">
      <ctrl:BenchmarkOverlay DataContext="{Binding BenchmarkTool}"/>
    </Panel>

    <Panel IsVisible="{Binding ShowSqlExplainPrimaryContent}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           ZIndex="91">
      <ctrl:ExplainPlanOverlay DataContext="{Binding ExplainPlanTool}"/>
    </Panel>
  </Panel>
</UserControl>
