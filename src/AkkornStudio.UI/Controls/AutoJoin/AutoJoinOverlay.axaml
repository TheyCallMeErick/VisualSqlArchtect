<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.AutoJoinOverlay"
             x:DataType="vm:AutoJoinOverlayViewModel">

  <UserControl.Styles>

    <!-- Card -->
    <Style Selector="Border.join-card">
      <Setter Property="Background"    Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush"   Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"  Value="{StaticResource RadiusMD}"/>
      <Setter Property="Padding"       Value="12,10"/>
      <Setter Property="Margin"        Value="0,4"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Overlay panel ══════════════════════════════════════════════════════ -->
  <Border MaxWidth="380"
        MaxHeight="520"
          Background="{StaticResource Bg0Brush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusLG}"
          BoxShadow="{StaticResource ShadowXL}">

      <Grid RowDefinitions="Auto,*,Auto">

      <!-- ── Header ───────────────────────────────────────────────────────── -->
    <Border Grid.Row="0"
        Background="{StaticResource Bg1Brush}"
              CornerRadius="{StaticResource RadiusLGTop}"
              Padding="12,10">

      <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Sparkle icon -->
          <Border Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="{StaticResource RadiusSM}"
                  Background="{StaticResource Bg2Brush}"
                  BorderBrush="{StaticResource BorderFocusBrush}"
                  BorderThickness="1"
                  Margin="0,0,8,0">
            <mi:MaterialIcon Kind="AutoFix"
                             Width="13" Height="13"
                             Foreground="{StaticResource AccentPrimaryHoverBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [autoJoin.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="{StaticResource FontWeightTitle}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding Title}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>

          <!-- Close -->
          <Button Grid.Column="2"
              Classes="modal-close-btn"
                  Command="{Binding DismissCommand}"
                  Name="DismissAllBtn">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Grid.Row="0" Height="1" Background="{StaticResource BorderSubtleBrush}" VerticalAlignment="Bottom"/>

      <!-- ── Suggestion cards ──────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1"
                    Margin="8,6"
                    HorizontalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding Cards}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:JoinSuggestionCardViewModel">

              <Border Classes="join-card"
                      IsVisible="{Binding IsVisible}">

                <Grid RowDefinitions="Auto,Auto,Auto">

                  <!-- Row 1: Join type badge + table pair + confidence -->
                  <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,6">

                    <!-- JOIN type badge -->
                    <Border Grid.Column="0"
                            Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource BorderFocusBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2"
                            Margin="0,0,8,0">
                      <TextBlock Text="{Binding JoinType}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 FontWeight="{StaticResource FontWeightHeading}"
                                 Foreground="{StaticResource AccentPrimaryHoverBrush}"
                                 FontFamily="{StaticResource MonoFont}"/>
                    </Border>

                    <!-- Table pair -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding TablePair}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Confidence badge -->
                    <Border Grid.Column="2"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2"
                            Margin="6,0,4,0">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.15"/>
                      </Border.Background>
                      <TextBlock Text="{Binding ConfidenceLabel}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{Binding ConfidenceBrush}"/>
                    </Border>

                    <!-- Score percentage -->
                    <Border Grid.Column="3"
                            Background="{StaticResource Bg0Brush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusXS}"
                            Padding="5,2">
                      <TextBlock Text="{Binding ScoreLabel}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 FontWeight="{StaticResource FontWeightHeading}"
                                 FontFamily="{StaticResource MonoFont}"
                                 Foreground="{Binding ConfidenceBrush}"
                                 VerticalAlignment="Center"/>
                    </Border>
                  </Grid>

                  <!-- Score bar (thin strip below the header row) -->
                  <Border Grid.Row="0" Height="2" VerticalAlignment="Bottom"
                          Margin="0,0,0,6" CornerRadius="{StaticResource RadiusXS}">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.08"/>
                    </Border.Background>
                    <Border HorizontalAlignment="Left"
                            Width="{Binding ScoreBarWidth}"
                            Height="2"
                            CornerRadius="{StaticResource RadiusXS}">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding ConfidenceColor}" Opacity="0.7"/>
                      </Border.Background>
                    </Border>
                  </Border>

                  <!-- Row 2: ON clause -->
                  <Border Grid.Row="1"
                          Background="{StaticResource Bg0Brush}"
                          CornerRadius="{StaticResource RadiusXS}"
                          Padding="7,4"
                          Margin="0,0,0,8">
                    <TextBlock Text="{Binding OnClause}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource StatusOkBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </Border>

                  <!-- Row 3: Rationale + action buttons -->
                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">

                    <TextBlock Grid.Column="0"
                               Text="{Binding Rationale}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="1"
                          Classes="modal-footer-secondary-btn"
                            Margin="0,0,4,0"
                            Command="{Binding AcceptCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="Check" Width="12" Height="12"/>
                        <TextBlock Text="{Binding [autoJoin.accept], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeCaption}"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                          Classes="modal-close-btn"
                            Content="{Binding [autoJoin.skip], Source={x:Static loc:LocalizationService.Instance}}"
                            Command="{Binding DismissCommand}"/>
                  </Grid>

                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state (all dismissed or accepted) -->
      <Border Grid.Row="1"
              Padding="16,12"
              IsVisible="{Binding HasCards, Converter={x:Static BoolConverters.Not}}">
        <TextBlock Text="{Binding [autoJoin.allHandled], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"/>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="0,1,0,0"
              Background="{StaticResource Bg1Brush}"
              CornerRadius="{StaticResource RadiusLGBottom}"
              Padding="10,8">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding Title}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"/>
          <Button Grid.Column="1"
              Classes="modal-footer-secondary-btn"
                  Command="{Binding DismissCommand}"
                  Margin="0,0,8,0"
                  Content="{Binding [common.cancel], Source={x:Static loc:LocalizationService.Instance}}"/>
          <Button Grid.Column="2"
              Classes="modal-footer-primary-btn"
                  Content="{Binding [autoJoin.acceptAll], Source={x:Static loc:LocalizationService.Instance}}"
                  Command="{Binding AcceptAllCommand}"
                  Name="AcceptAllBtn"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
