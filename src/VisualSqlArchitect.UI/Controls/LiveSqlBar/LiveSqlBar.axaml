<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:core="using:VisualSqlArchitect.Core"
             xmlns:conv="using:VisualSqlArchitect.UI.Converters"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.LiveSqlBar"
             x:DataType="vm:LiveSqlBarViewModel">

  <UserControl.Resources>
    <conv:SqlTokenKindConverter x:Key="KindConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>

    <!-- Keyword -->
    <Style Selector="TextBlock.tok-Keyword">
      <Setter Property="Foreground" Value="#818CF8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <!-- Identifier -->
    <Style Selector="TextBlock.tok-Identifier">
      <Setter Property="Foreground" Value="#E8EAED"/>
    </Style>
    <!-- Literal string / number -->
    <Style Selector="TextBlock.tok-Literal">
      <Setter Property="Foreground" Value="#4ADE80"/>
    </Style>
    <!-- Operator -->
    <Style Selector="TextBlock.tok-Operator">
      <Setter Property="Foreground" Value="#FB7185"/>
    </Style>
    <!-- Punctuation -->
    <Style Selector="TextBlock.tok-Punctuation">
      <Setter Property="Foreground" Value="#4A5568"/>
    </Style>
    <!-- Function call -->
    <Style Selector="TextBlock.tok-Function">
      <Setter Property="Foreground" Value="#FBBF24"/>
    </Style>
    <!-- Comment -->
    <Style Selector="TextBlock.tok-Comment">
      <Setter Property="Foreground" Value="#4A5568"/>
      <Setter Property="FontStyle"  Value="Italic"/>
    </Style>
    <!-- Plain / whitespace -->
    <Style Selector="TextBlock.tok-Plain">
      <Setter Property="Foreground" Value="#8B95A8"/>
    </Style>

    <!-- Action button -->
    <Style Selector="Button.sql-action">
      <Setter Property="Background"       Value="Transparent"/>
      <Setter Property="BorderThickness"  Value="0"/>
      <Setter Property="Foreground"       Value="#4A5568"/>
      <Setter Property="Padding"          Value="6,3"/>
      <Setter Property="CornerRadius"     Value="5"/>
      <Setter Property="FontSize"         Value="11"/>
      <Setter Property="Cursor"           Value="Hand"/>
    </Style>
    <Style Selector="Button.sql-action:pointerover">
      <Setter Property="Background" Value="#1E2335"/>
      <Setter Property="Foreground" Value="#E8EAED"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Bar shell ══════════════════════════════════════════════════════════ -->
  <Border Background="#0A0C11"
          BorderBrush="#1E2335"
          BorderThickness="0,1,0,0">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="0">

      <!-- ── Safe Preview blocked banner ──────────────────────────────────────── -->
      <Border Grid.Row="0"
              Background="#1A0A0A"
              BorderBrush="#EF4444"
              BorderThickness="0,0,0,1"
              Padding="12,5"
              IsVisible="{Binding IsMutatingCommand}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border CornerRadius="4" Background="#EF4444" Padding="5,2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Lock" Width="10" Height="10" Foreground="White" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding [liveSql.safePreview], Source={x:Static loc:LocalizationService.Instance}}" FontSize="9" FontWeight="Bold" Foreground="White" LetterSpacing="0.8"/>
            </StackPanel>
          </Border>
          <TextBlock Text="{Binding BlockedReason}"
                     FontSize="10"
                     Foreground="#FB7185"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- ── Top strip: label + provider + actions ───────────────────────────── -->
      <Grid Grid.Row="1"
            ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto"
            Margin="12,6,8,4">

        <!-- Status dot -->
        <Ellipse Grid.Column="0"
                 Width="7" Height="7"
                 Margin="0,0,8,0">
          <Ellipse.Fill>
            <SolidColorBrush Color="#4ADE80" Opacity="{Binding IsValid, Converter={x:Static BoolConverters.Not}, FallbackValue=0.3}"/>
          </Ellipse.Fill>
        </Ellipse>

        <!-- "LIVE SQL" label -->
        <TextBlock Grid.Column="1"
                   Text="{Binding [liveSql.title], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="9"
                   FontWeight="Bold"
                   Foreground="#3B4560"
                   LetterSpacing="1.5"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

        <!-- Safe Preview badge (shown when mutating command detected) -->
        <Border Grid.Column="2"
                Background="#EF4444"
                Padding="5,2"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                IsVisible="{Binding IsMutatingCommand}"
          ToolTip.Tip="{Binding [tooltip.liveSqlMutatingBlocked], Source={x:Static loc:LocalizationService.Instance}}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Lock" Width="10" Height="10" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [liveSql.blocked], Source={x:Static loc:LocalizationService.Instance}}" FontSize="9" FontWeight="Bold" Foreground="White"/>
          </StackPanel>
        </Border>

        <!-- Error hint (shown inline when invalid and not a mutating block) -->
        <TextBlock Grid.Column="2"
                   Text="{Binding CompileError}"
                   FontSize="10"
                   Foreground="#FB7185"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   IsVisible="{Binding IsValid, Converter={x:Static BoolConverters.Not}}"/>

        <!-- Provider picker -->
        <ComboBox Grid.Column="3"
                  Background="#0D0F14"
                  BorderBrush="#252C3F"
                  Foreground="#60A5FA"
                  FontSize="10"
                  CornerRadius="5"
                  Padding="7,2"
                  Margin="4,0"
                  VerticalAlignment="Center">
          <ComboBox.Items>
            <core:DatabaseProvider>Postgres</core:DatabaseProvider>
            <core:DatabaseProvider>MySql</core:DatabaseProvider>
            <core:DatabaseProvider>SqlServer</core:DatabaseProvider>
            <core:DatabaseProvider>SQLite</core:DatabaseProvider>
          </ComboBox.Items>
        </ComboBox>

        <!-- Copy SQL button -->
        <Button Grid.Column="4"
                Classes="sql-action"
                Name="CopyBtn"
          ToolTip.Tip="{Binding [tooltip.copySql], Source={x:Static loc:LocalizationService.Instance}}"
                IsEnabled="{Binding HasSql}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="ContentCopy" Width="12" Height="12"/>
            <TextBlock Text="{Binding [liveSql.copy], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
          </StackPanel>
        </Button>

        <!-- Format / pretty-print -->
        <Button Grid.Column="5"
                Classes="sql-action"
                Name="FormatBtn"
          ToolTip.Tip="{Binding [tooltip.formatSql], Source={x:Static loc:LocalizationService.Instance}}"
                IsEnabled="{Binding HasSql}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="FormatAlignLeft" Width="12" Height="12"/>
            <TextBlock Text="{Binding [liveSql.format], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
          </StackPanel>
        </Button>

        <!-- Benchmark button -->
        <Button Grid.Column="6"
                Classes="sql-action"
                Name="BenchmarkBtn"
          ToolTip.Tip="{Binding [tooltip.openBenchmark], Source={x:Static loc:LocalizationService.Instance}}"
                IsEnabled="{Binding HasSql}"
                AutomationProperties.Name="Open benchmark">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="TimerOutline" Width="12" Height="12"/>
            <TextBlock Text="{Binding [liveSql.benchmark], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
          </StackPanel>
        </Button>

        <!-- Explain Plan button -->
        <Button Grid.Column="7"
                Classes="sql-action"
                Name="ExplainBtn"
          ToolTip.Tip="{Binding [tooltip.openExplainPlan], Source={x:Static loc:LocalizationService.Instance}}"
                IsEnabled="{Binding HasSql}"
                AutomationProperties.Name="Open explain plan">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="TableSearch" Width="12" Height="12"/>
            <TextBlock Text="{Binding [liveSql.explain], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
          </StackPanel>
        </Button>

        <!-- Recompile indicator (spinning when active) -->
        <ProgressBar Grid.Column="8"
                     Width="20" Height="2"
                     IsIndeterminate="True"
                     Foreground="#3B82F6"
                     Background="Transparent"
                     VerticalAlignment="Center"
                     Margin="4,0"
                     IsVisible="{Binding IsCompiling}"/>
      </Grid>

      <!-- ── SQL text display ───────────────────────────────────────────────── -->
      <Border Grid.Row="2" Margin="12,0,12,4" Background="#070B10" BorderBrush="#252C3F" BorderThickness="1" CornerRadius="8">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      MinHeight="90"
                      MaxHeight="220"
                      Margin="10,8">
          <ItemsControl ItemsSource="{Binding Tokens}"
                        HorizontalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SqlToken">
                <TextBlock Text="{Binding Text}"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="12"
                           Classes.tok-Keyword="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Keyword}"
                           Classes.tok-Identifier="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Identifier}"
                           Classes.tok-Literal="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Literal}"
                           Classes.tok-Operator="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Operator}"
                           Classes.tok-Punctuation="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Punctuation}"
                           Classes.tok-Function="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Function}"
                           Classes.tok-Comment="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Comment}"
                           Classes.tok-Plain="{Binding Kind, Converter={StaticResource KindConverter}, ConverterParameter=Plain}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- ── Guardrail warnings strip ──────────────────────────────────────── -->
      <ItemsControl Grid.Row="3"
                    ItemsSource="{Binding GuardIssues}"
                    IsVisible="{Binding HasGuardWarning}"
                    Margin="12,2,12,5">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:GuardIssue">
            <Border CornerRadius="4"
                    Background="#241A00"
                    BorderBrush="#FBBF24"
                    BorderThickness="1"
                    Padding="6,3"
                    Margin="0,2,6,0">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <mi:MaterialIcon Kind="Alert"
                                 Width="11" Height="11"
                                 Foreground="#FBBF24"
                                 VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Message}"
                           FontSize="10"
                           Foreground="#D4A017"
                           VerticalAlignment="Center">
                  <ToolTip.Tip>
                    <StackPanel Spacing="3" MaxWidth="340">
                      <TextBlock Text="{Binding Message}"  FontWeight="Bold" Foreground="White" FontSize="11"/>
                      <TextBlock Text="{Binding Suggestion}" Foreground="#60A5FA" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                  </ToolTip.Tip>
                </TextBlock>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </Grid>
  </Border>
</UserControl>
