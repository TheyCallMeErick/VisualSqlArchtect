<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             x:Class="VisualSqlArchitect.UI.Controls.BottomSheetToast"
             x:DataType="vm:ToastCenterViewModel">
  <Border IsVisible="{Binding IsVisible}"
          HorizontalAlignment="Center"
          VerticalAlignment="Bottom"
          Margin="0,0,0,14"
          Padding="12,10"
          MinWidth="420"
          MaxWidth="820"
          Background="{StaticResource MacroBg1Brush}"
          BorderBrush="{Binding AccentColor}"
          BorderThickness="1"
          CornerRadius="12">
    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="{Binding SeverityIcon}"
                 Foreground="{Binding AccentColor}"
                 FontWeight="Bold"
                 Margin="0,0,8,0"
                 VerticalAlignment="Top"/>

      <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
        <TextBlock Text="{Binding SeverityLabel}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{Binding AccentColor}"/>
        <TextBlock Text="{Binding Message}"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
      </StackPanel>

      <Button Grid.Row="0" Grid.Column="2"
              Command="{Binding DismissCommand}"
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource TextSecondaryBrush}"
              Padding="2"
              VerticalAlignment="Top"
              Cursor="Hand">
        <TextBlock Text="✕" FontSize="11"/>
      </Button>

      <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
        <Button Command="{Binding ShowDetailsCommand}"
                IsVisible="{Binding HasDetails}"
                Classes="secondary"
                CornerRadius="{StaticResource StartRadiusButton}"
                Padding="8,4"
                FontSize="11"
                Cursor="Hand"
                Content="{Binding [common.details], Source={x:Static loc:LocalizationService.Instance}}"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
