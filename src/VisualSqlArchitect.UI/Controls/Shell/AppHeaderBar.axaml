<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.Shell.AppHeaderBar"
             x:Name="Root">
  <Border Classes="app-header-shell"
          PointerPressed="Header_PointerPressed">
    <Grid ColumnDefinitions="Auto,*,Auto">
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">
        <Border Width="22"
                Height="22"
                CornerRadius="6"
                Background="{StaticResource MacroBg2Brush}"
                BorderBrush="{StaticResource AccentBlueBrush}"
                BorderThickness="1"
                IsVisible="{Binding ShowBrandBadge, ElementName=Root}">
          <TextBlock Text="VS"
                     FontSize="8"
                     FontWeight="ExtraBold"
                     Foreground="{StaticResource AccentBlueBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Button Classes="app-header-title-btn"
          Content="{Binding Title, ElementName=Root}"
          Click="TitleButton_Click"
          VerticalAlignment="Center"/>

        <ContentPresenter Content="{Binding LeftContent, ElementName=Root}"
                          VerticalAlignment="Center"/>
      </StackPanel>

      <ContentPresenter Grid.Column="1"
                        Content="{Binding CenterContent, ElementName=Root}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="4"
                  VerticalAlignment="Center">
        <ContentPresenter Content="{Binding RightContent, ElementName=Root}"
                          VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="3"
                    IsVisible="{Binding ShowWindowControls, ElementName=Root}">
          <Button Classes="app-window-btn"
                  Click="Minimize_Click"
                  Width="28"
                  Height="28"
                  ToolTip.Tip="Minimizar janela">
            <mi:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
          </Button>

          <Button Classes="app-window-btn"
                  Click="Maximize_Click"
                  Width="28"
                  Height="28"
                  ToolTip.Tip="Maximizar/restaurar janela">
            <mi:MaterialIcon Kind="WindowMaximize" Width="14" Height="14"/>
          </Button>

          <Button Classes="app-window-btn app-window-btn-danger"
                  Click="Close_Click"
                  Width="28"
                  Height="28"
                  ToolTip.Tip="Fechar janela">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
