<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:canvas="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:explain="using:VisualSqlArchitect.UI.Services.Explain"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.ExplainPlanOverlay"
             x:DataType="canvas:ExplainPlanViewModel"
             Width="1220">

  <UserControl.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="Foreground" Value="#6B7A99"/>
      <Setter Property="Margin"     Value="0,0,0,4"/>
    </Style>
    <Style Selector="Button.close-btn">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#4A5568"/>
      <Setter Property="Padding"         Value="6"/>
      <Setter Property="CornerRadius"    Value="5"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.close-btn:pointerover">
      <Setter Property="Background" Value="#1E2335"/>
      <Setter Property="Foreground" Value="#E8EAED"/>
    </Style>
    <Style Selector="Button.run-btn">
      <Setter Property="Background"      Value="#3B82F6"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="Padding"         Value="10,6"/>
      <Setter Property="CornerRadius"    Value="7"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.run-btn:pointerover">
      <Setter Property="Background" Value="#2563EB"/>
    </Style>
    <Style Selector="Button.export-btn">
      <Setter Property="Background" Value="#111827"/>
      <Setter Property="BorderBrush" Value="#25324A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#9CA3AF"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.export-btn:pointerover">
      <Setter Property="Background" Value="#172135"/>
      <Setter Property="Foreground" Value="#E5E7EB"/>
      <Setter Property="BorderBrush" Value="#3B82F6"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Card shell ════════════════════════════════════════════════════════ -->
    <Border Background="#0F1219"
          BorderBrush="#1E2335"
          BorderThickness="1"
          CornerRadius="12"
          BoxShadow="0 8 40 0 #80000000"
          Width="1220"
          Height="820"
          MinHeight="660"
          MaxHeight="860"
          Padding="0">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

      <!-- ── Header ──────────────────────────────────────────────────────── -->
      <Grid Grid.Row="0"
            ColumnDefinitions="Auto,Auto,*,Auto"
            Background="#0B0D13"
            Margin="0"
            Height="48">
        <Border Grid.Column="0"
                Background="#1A1E2C"
                CornerRadius="8"
                Padding="8"
                Margin="16,0,0,0"
                VerticalAlignment="Center">
          <mi:MaterialIcon Kind="TableSearch" Width="16" Height="16" Foreground="#60A5FA"/>
        </Border>

        <StackPanel Grid.Column="1" Spacing="2" Margin="12,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="{Binding [explain.title], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="13" FontWeight="SemiBold" Foreground="#E8EAED"/>
          <TextBlock Text="{Binding ExplainHeader}"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="10" Foreground="#4A5568"/>
        </StackPanel>

        <!-- Provider badge -->
        <Border Grid.Column="2"
                HorizontalAlignment="Left"
                Margin="14,0,0,0"
                VerticalAlignment="Center"
                Background="#131720"
                BorderBrush="#252C3F"
                BorderThickness="1"
                CornerRadius="5"
                Padding="7,3">
          <TextBlock Text="{Binding ProviderLabel}"
                     FontSize="10" Foreground="#60A5FA"/>
        </Border>

        <Border Grid.Column="2"
                HorizontalAlignment="Left"
                Margin="88,0,0,0"
                VerticalAlignment="Center"
                Background="#2D1B09"
                BorderBrush="#92400E"
                BorderThickness="1"
                CornerRadius="5"
                Padding="7,3"
                IsVisible="{Binding IsSimulated}">
          <TextBlock Text="SIMULATED"
                     FontSize="10"
                     FontWeight="SemiBold"
                     Foreground="#F59E0B"/>
        </Border>

        <!-- Close -->
        <Button Grid.Column="3"
                Classes="close-btn"
                Name="CloseBtn"
                Margin="0,0,12,0"
                VerticalAlignment="Center">
          <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
        </Button>
      </Grid>

      <!-- ── SQL preview ──────────────────────────────────────────────────── -->
      <Border Grid.Row="1"
              Background="#0B0E15"
              BorderBrush="#1E2335"
              BorderThickness="0,1,0,1"
              Padding="16,10">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding [explain.sql], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="9" FontWeight="Bold"
                     Foreground="#4338CA"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"/>
          <SelectableTextBlock Grid.Column="1"
                               Text="{Binding Sql}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="#8B95A8"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"
                               VerticalAlignment="Center">
            <ToolTip.Tip>
              <TextBlock Text="{Binding SqlTooltipText}"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="11"
                         MaxWidth="920"
                         TextWrapping="Wrap"/>
            </ToolTip.Tip>
          </SelectableTextBlock>
          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="10"
                      VerticalAlignment="Center"
                      Margin="10,0,0,0"
                      IsVisible="{Binding CanUseAnalyzeOptions}">
            <CheckBox IsChecked="{Binding IncludeAnalyze}"
                      VerticalAlignment="Center"
                      Foreground="#9CA3AF"
                      FontSize="11"
                      Content="Analyze"/>
            <CheckBox IsChecked="{Binding IncludeBuffers}"
                      IsVisible="{Binding CanUseBuffersOption}"
                      IsEnabled="{Binding IncludeAnalyze}"
                      VerticalAlignment="Center"
                      Foreground="#9CA3AF"
                      FontSize="11"
                      Content="Buffers"/>
          </StackPanel>

          <Button Grid.Column="3"
                  Classes="export-btn"
                  Name="SnapshotBtn"
                  IsEnabled="{Binding HasData}"
                  Margin="12,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <mi:MaterialIcon Kind="Camera" Width="12" Height="12" VerticalAlignment="Center"/>
              <TextBlock Text="Snapshot" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Re-run -->
          <Button Grid.Column="4"
                  Classes="run-btn"
                  Name="RunBtn"
                  IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"
                  Margin="12,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <mi:MaterialIcon Kind="Refresh" Width="12" Height="12" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding [explain.rerun], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          </Grid>
          <Border Background="#111827"
                  BorderBrush="#25324A"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8,6"
                  IsVisible="{Binding HasTimingData}">
            <Grid ColumnDefinitions="Auto,*,Auto,*">
              <TextBlock Grid.Column="0" Text="Planning:" FontSize="10" Foreground="#6B7280"/>
              <TextBlock Grid.Column="1" Margin="6,0,0,0" Text="{Binding PlanningTimeText}" FontSize="10" Foreground="#93C5FD"/>
              <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="Execution:" FontSize="10" Foreground="#6B7280"/>
              <TextBlock Grid.Column="3" Margin="6,0,0,0" Text="{Binding ExecutionTimeText}" FontSize="10" Foreground="#93C5FD"/>
            </Grid>
          </Border>
          <Border Background="#2A1C09"
                  BorderBrush="#92400E"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8,6"
                  IsVisible="{Binding HasAnalyzeDmlWarning}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <mi:MaterialIcon Kind="Alert" Width="12" Height="12" Foreground="#F59E0B"/>
              <TextBlock Text="{Binding AnalyzeDmlWarningText}"
                         FontSize="10"
                         Foreground="#FCD34D"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- ── Alert summary bar ───────────────────────────────────────────── -->
      <Border Grid.Row="2"
              Background="#160E00"
              BorderBrush="#92400E"
              BorderThickness="0,0,0,1"
              Padding="16,7"
              IsVisible="{Binding HasAlerts}">
        <Grid ColumnDefinitions="Auto,*">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14"
                           Foreground="#FBBF24" VerticalAlignment="Center"/>
          <TextBlock FontSize="11" Foreground="#FBBF24" VerticalAlignment="Center">
            <Run Text="{Binding AlertCount}"/>
            <Run Text="{Binding [explain.alertSuffix], Source={x:Static loc:LocalizationService.Instance}}"/>
          </TextBlock>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
          <Button Name="ListModeBtn" Classes="export-btn">
            <TextBlock Text="Lista"/>
          </Button>
          <Button Name="TreeModeBtn" Classes="export-btn">
            <TextBlock Text="Arvore"/>
          </Button>
        </StackPanel>
        </Grid>
      </Border>

      <!-- ── Content area ────────────────────────────────────────────────── -->
      <Grid Grid.Row="3" MinHeight="420">

        <Grid IsVisible="{Binding ShowListView}"
              ColumnDefinitions="3*,2*"
              Margin="0">
          <!-- Main plan list -->
          <Border Grid.Column="0"
                  Margin="12,8,6,10"
                  Padding="0"
                  CornerRadius="8"
                  Background="#0C1019"
                  BorderBrush="#25324A"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*,Auto">
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,64,64,64,68,96"
                    Margin="12,10,12,8">
                <TextBlock Grid.Column="0" Text="{Binding [explain.header.operation], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"/>
                <TextBlock Grid.Column="1" Text="{Binding [explain.header.cost], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="2" Text="{Binding [explain.header.rows], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="3" Text="%"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="ERR"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="5" Text="{Binding [explain.header.alert], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#4B5A78" LetterSpacing="1"
                           HorizontalAlignment="Right"/>
              </Grid>

              <Border Grid.Row="0" Background="#1E2335" Height="1" Margin="12,32,12,0" VerticalAlignment="Bottom"/>

              <ScrollViewer Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Margin="0,4,0,0">
                <ItemsControl ItemsSource="{Binding Steps}" Margin="0,0,0,8">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="explain:ExplainStep">
                      <Button Margin="0,1,0,0"
                              Padding="12,8"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              Click="OnStepRowClick">
                        <Button.Styles>
                          <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#0D1525"/>
                          </Style>
                        </Button.Styles>
                        <Grid ColumnDefinitions="*,64,64,64,68,96">
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <Border Width="{Binding IndentMargin}" Height="1"/>
                            <Ellipse Width="4" Height="4"
                                     Fill="#252C3F"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IndentLevel, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Operation}"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="12"
                                         Foreground="#C8D0DC"
                                         TextWrapping="NoWrap"/>
                              <TextBlock Text="{Binding Detail}"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="10"
                                         Foreground="#4A5568"
                                         TextWrapping="NoWrap"
                                         IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                              <Border Width="96"
                                      Height="4"
                                      CornerRadius="2"
                                      Background="#1F2937"
                                      IsVisible="{Binding HasCostBar}">
                                <Border Width="{Binding CostBarWidth}"
                                        Height="4"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2">
                                  <Border.Background>
                                    <SolidColorBrush Color="{Binding CostBarFill}"/>
                                  </Border.Background>
                                </Border>
                              </Border>
                            </StackPanel>
                          </StackPanel>

                          <TextBlock Grid.Column="1"
                                     Text="{Binding CostText}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="11"
                                     Foreground="#6B7A99"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>

                          <TextBlock Grid.Column="2"
                                     Text="{Binding RowsText}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="11"
                                     Foreground="#6B7A99"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>

                          <TextBlock Grid.Column="3"
                                     Text="{Binding CostFractionText}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="11"
                                     Foreground="#6B7A99"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>

                          <TextBlock Grid.Column="4"
                                     Text="{Binding RowsErrorText}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="11"
                                     Foreground="{Binding RowsErrorColor}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding HasRowsError}"/>

                          <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                            <Border CornerRadius="4"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasStaleStatsBadge}">
                              <Border.Background>
                                <SolidColorBrush Color="#A78BFA"/>
                              </Border.Background>
                              <TextBlock Text="{Binding StaleStatsLabel}"
                                         FontSize="8"
                                         FontWeight="Bold"
                                         Foreground="#0D0F14"
                                         LetterSpacing="0.5"/>
                            </Border>
                            <Border CornerRadius="4"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasAlert}">
                              <Border.Background>
                                <SolidColorBrush Color="{Binding AlertColor}"/>
                              </Border.Background>
                              <TextBlock Text="{Binding AlertLabel}"
                                         FontSize="8"
                                         FontWeight="Bold"
                                         Foreground="#0D0F14"
                                         LetterSpacing="0.5"/>
                            </Border>
                          </StackPanel>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>

          <!-- Technical side panel -->
          <Border Grid.Column="1"
                  Margin="6,8,12,10"
                  Padding="0"
                  CornerRadius="8"
                  Background="#0C1019"
                  BorderBrush="#25324A"
                  BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0">
              <StackPanel Margin="10" Spacing="8">
                <Border Padding="10,8"
                        CornerRadius="8"
                        Background="#0E1422"
                        BorderBrush="#25324A"
                        BorderThickness="1"
                        IsVisible="{Binding CanCompareSnapshots}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Comparacao de snapshots"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#93C5FD"/>
                    <Grid ColumnDefinitions="Auto,*,Auto,*">
                      <TextBlock Grid.Column="0" Text="A" FontSize="10" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                      <ComboBox Grid.Column="1"
                                Margin="0,0,6,0"
                                ItemsSource="{Binding Snapshots}"
                                SelectedItem="{Binding SelectedSnapshotA}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="explain:ExplainSnapshot">
                            <TextBlock Text="{Binding Label}" FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <TextBlock Grid.Column="2" Margin="0,0,6,0" Text="B" FontSize="10" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                      <ComboBox Grid.Column="3"
                                ItemsSource="{Binding Snapshots}"
                                SelectedItem="{Binding SelectedSnapshotB}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="explain:ExplainSnapshot">
                            <TextBlock Text="{Binding Label}" FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ComparisonRows}" IsVisible="{Binding HasComparisonRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="explain:ExplainComparisonRow">
                          <Grid ColumnDefinitions="*,74,74,64,76" Margin="0,1">
                            <TextBlock Grid.Column="0" Text="{Binding Operation}" FontSize="10" Foreground="#CBD5E1"/>
                            <TextBlock Grid.Column="1" Text="{Binding CostAText}" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="{Binding CostBText}" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="{Binding DeltaText}" FontSize="10" Foreground="{Binding DeltaColor}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="{Binding StatusLabel}" FontSize="9" Foreground="{Binding DeltaColor}" HorizontalAlignment="Right"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Padding="10,8"
                        CornerRadius="8"
                        Background="#0C1626"
                        BorderBrush="#1F3B63"
                        BorderThickness="1"
                        IsVisible="{Binding HasIndexSuggestions}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Recomendacoes de indice"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#93C5FD"/>
                    <ItemsControl ItemsSource="{Binding IndexSuggestions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="explain:ExplainIndexSuggestion">
                          <Button Background="#0A1220"
                                  BorderBrush="#25324A"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                  Margin="0,2,0,0"
                                  HorizontalContentAlignment="Stretch"
                                  Click="OnIndexSuggestionClick">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding BadgeText}" FontSize="9" Foreground="#60A5FA"/>
                              <TextBlock Text="{Binding Table}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="#E2E8F0"/>
                              <TextBlock Text="{Binding ColumnsText}" FontSize="10" Foreground="#93C5FD"/>
                              <TextBlock Text="{Binding Reason}" FontSize="10" Foreground="#A5B4FC" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding Sql}" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap"/>
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Padding="10,8"
                        CornerRadius="8"
                        Background="#0D1220"
                        BorderBrush="#25324A"
                        BorderThickness="1"
                        IsVisible="{Binding HasHistory}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Historico"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#93C5FD"/>
                    <ItemsControl ItemsSource="{Binding History}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="explain:ExplainHistoryItem">
                          <Grid ColumnDefinitions="48,*,66,66" Margin="0,1">
                            <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="{Binding TopOperation}" FontSize="10" Foreground="#CBD5E1"/>
                            <TextBlock Grid.Column="2" Text="{Binding CostText}" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="{Binding AlertText}" FontSize="10" Foreground="#A5B4FC" HorizontalAlignment="Right"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Padding="10,8"
                        CornerRadius="8"
                        Background="#101521"
                        BorderBrush="#25324A"
                        BorderThickness="1"
                        IsVisible="{Binding HasSelectedStep}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding SelectedStepTitle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB"/>
                    <TextBlock Text="{Binding SelectedStepDetailText}"
                               FontSize="10"
                               Foreground="#9CA3AF"
                               TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="Auto,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding SelectedStepEstimatedRowsText}" FontSize="10" Foreground="#9CA3AF"/>
                      <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding SelectedStepActualRowsText}" FontSize="10" Foreground="#9CA3AF"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,Auto,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding SelectedStepRowsErrorText}" FontSize="10" Foreground="#C4B5FD"/>
                      <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding SelectedStepActualTimeText}" FontSize="10" Foreground="#93C5FD"/>
                      <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="{Binding SelectedStepLoopsText}" FontSize="10" Foreground="#9CA3AF"/>
                    </Grid>
                    <TextBlock Text="{Binding SelectedStepSuggestionText}"
                               FontSize="10"
                               Foreground="#93C5FD"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>

        <Border IsVisible="{Binding ShowTreeView}"
                Margin="12,8,12,10"
                Padding="8"
                CornerRadius="8"
                Background="#0D1320"
                BorderBrush="#25324A"
                BorderThickness="1">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto">
            <Canvas Name="TreeCanvas"
                    Width="{Binding TreeCanvasWidth}"
                    Height="{Binding TreeCanvasHeight}"/>
          </ScrollViewer>
        </Border>

        <!-- Loading state -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
          <ProgressBar IsIndeterminate="True"
                       Width="180" Height="3"
                       Background="#1A2335"
                       Foreground="#3B82F6"
                       CornerRadius="2"/>
          <TextBlock Text="{Binding [explain.running], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="12" Foreground="#4A5568"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error state -->
        <Border IsVisible="{Binding HasError}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#130D0D"
                BorderBrush="#5C1A1A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                MaxWidth="460">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding [explain.failed], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#FB7185"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="11" Foreground="#F87171"
                       TextWrapping="Wrap" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Empty / no SQL -->
        <StackPanel IsVisible="{Binding HasData, Converter={x:Static BoolConverters.Not}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
          <TextBlock Text="{Binding [explain.noPlan], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="13" Foreground="#4A5568"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
          <TextBlock Text="{Binding [explain.rerunHint], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="11" Foreground="#3B4560"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
        </StackPanel>
      </Grid>

      <!-- ── Footer hint ─────────────────────────────────────────────────── -->
      <Border Grid.Row="4"
              Background="#0B0D13"
              BorderBrush="#1E2335"
              BorderThickness="0,1,0,0"
              Padding="16,8">
        <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <Border Background="#FBBF24" CornerRadius="2" Width="10" Height="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [explain.legend.seqscan], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="5">
            <Border Background="#FB923C" CornerRadius="2" Width="10" Height="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [explain.legend.sort], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="5">
            <Border Background="#60A5FA" CornerRadius="2" Width="10" Height="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [explain.legend.hash], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568"/>
          </StackPanel>
          <TextBlock Text="{Binding [explain.escClose], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="10" Foreground="#3B4560"
                     HorizontalAlignment="Right"
                     Margin="0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
          <Button Name="CopyJsonBtn"
                  Classes="export-btn"
                  IsEnabled="{Binding HasRawOutput}">
            <TextBlock Text="Copiar JSON"/>
          </Button>
          <Button Name="CopyTextBtn"
                  Classes="export-btn">
            <TextBlock Text="Copiar texto"/>
          </Button>
          <Button Name="SaveJsonBtn"
                  Classes="export-btn"
                  IsEnabled="{Binding HasRawOutput}">
            <TextBlock Text="Salvar .json"/>
          </Button>
          <Button Name="OpenDaliboBtn"
                  Classes="export-btn"
                  IsVisible="{Binding CanOpenDalibo}">
            <TextBlock Text="Abrir no Dalibo"/>
          </Button>
        </StackPanel>
        </Grid>
      </Border>

    </Grid>
  </Border>
</UserControl>
