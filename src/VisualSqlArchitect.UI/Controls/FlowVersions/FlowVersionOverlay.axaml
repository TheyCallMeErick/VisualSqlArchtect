<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.FlowVersionOverlay"
             x:DataType="vm:FlowVersionOverlayViewModel">

  <UserControl.Styles>

    <!-- Version row -->
    <Style Selector="Border.version-row">
      <Setter Property="Background"     Value="#111520"/>
      <Setter Property="BorderBrush"    Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"   Value="8"/>
      <Setter Property="Padding"        Value="10,8"/>
      <Setter Property="Margin"         Value="0,3"/>
    </Style>
    <Style Selector="Border.version-row:pointerover">
      <Setter Property="BorderBrush" Value="#3B5280"/>
    </Style>

    <!-- Action buttons -->
    <Style Selector="Button.action-btn">
      <Setter Property="Background"     Value="#0F2040"/>
      <Setter Property="BorderBrush"    Value="#1E3A60"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"     Value="#60A5FA"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="CornerRadius"   Value="5"/>
      <Setter Property="Padding"        Value="7,3"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.action-btn:pointerover">
      <Setter Property="Background" Value="#162B50"/>
    </Style>

    <!-- Danger button -->
    <Style Selector="Button.danger-btn">
      <Setter Property="Background"     Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"     Value="#4A5568"/>
      <Setter Property="FontSize"       Value="11"/>
      <Setter Property="Padding"        Value="5,3"/>
      <Setter Property="Cursor"         Value="Hand"/>
    </Style>
    <Style Selector="Button.danger-btn:pointerover">
      <Setter Property="Foreground" Value="#F87171"/>
    </Style>

    <!-- Diff badge -->
    <Style Selector="Border.diff-add">
      <Setter Property="Background"  Value="#0A2010"/>
      <Setter Property="BorderBrush" Value="#1A4030"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>
    <Style Selector="Border.diff-remove">
      <Setter Property="Background"  Value="#201010"/>
      <Setter Property="BorderBrush" Value="#401A1A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>
    <Style Selector="Border.diff-modify">
      <Setter Property="Background"  Value="#1A1505"/>
      <Setter Property="BorderBrush" Value="#3A2F05"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding"     Value="6,2"/>
      <Setter Property="Margin"      Value="0,2"/>
    </Style>

  </UserControl.Styles>

  <!-- ══ Overlay panel ══════════════════════════════════════════════════════ -->
  <Border MaxWidth="540"
          Background="#0D0F14"
          BorderBrush="#252C3F"
          BorderThickness="1"
          CornerRadius="12"
          BoxShadow="0 8 40 0 #80000000">

    <StackPanel>

      <!-- ── Header ───────────────────────────────────────────────────────── -->
      <Border Background="#0B0D12"
              CornerRadius="12,12,0,0"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Icon -->
          <Border Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="6"
                  Background="#0F1A30"
                  BorderBrush="#1E3A60"
                  BorderThickness="1"
                  Margin="0,0,8,0">
            <mi:MaterialIcon Kind="ClipboardTextHistory"
                             Width="13" Height="13"
                             Foreground="#60A5FA"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [flowVersion.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#E8EAED"/>
            <TextBlock Text="{Binding [flowVersion.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="10"
                       Foreground="#4A5568"/>
          </StackPanel>

          <!-- Close button -->
          <Button Grid.Column="2"
                  Classes="danger-btn"
                  Name="CloseBtn">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── New checkpoint row ────────────────────────────────────────────── -->
      <Border Padding="12,10">
        <Grid ColumnDefinitions="*,Auto">

          <TextBox Grid.Column="0"
                   Text="{Binding NewLabel}"
                   Watermark="{Binding [flowVersion.watermark], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="11"
                   Background="#0A0D15"
                   Foreground="#C8D0DC"
                   BorderBrush="#252C3F"
                   BorderThickness="1"
                   CornerRadius="6"
                   Padding="8,5"
                   Margin="0,0,8,0"
                   Name="LabelBox"/>

          <Button Grid.Column="1"
                  Classes="action-btn"
                  Name="SaveBtn">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <mi:MaterialIcon Kind="ContentSave" Width="12" Height="12"/>
              <TextBlock Text="{Binding [flowVersion.saveCheckpoint], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Diff mode toggle ───────────────────────────────────────────────── -->
      <Border Padding="12,8">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding DiffSummary}"
                     FontSize="10"
                     Foreground="#4A5568"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Classes="action-btn"
                  Name="DiffModeBtn">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Compare" Width="12" Height="12"/>
              <TextBlock Text="{Binding [flowVersion.compareMode], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Diff base selector (visible in diff mode) ─────────────────────── -->
      <Border Padding="12,8"
              IsVisible="{Binding IsDiffMode}">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding [flowVersion.selectBase], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="10"
                     Foreground="#60A5FA"/>
          <ComboBox ItemsSource="{Binding Versions}"
                    SelectedItem="{Binding DiffBaseVersion}"
                    Background="#0A0D15"
                    BorderBrush="#252C3F"
                    Foreground="#C8D0DC"
                    FontSize="11"
                    HorizontalAlignment="Stretch"
                    Name="DiffBaseCombo">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:FlowVersionRowViewModel">
                <TextBlock Text="{Binding Label}"
                           FontSize="11"
                           Foreground="#C8D0DC"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Text="{Binding [flowVersion.clickAny], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="10"
                     Foreground="#4A5568"/>
        </StackPanel>
      </Border>

      <!-- ── Version list ──────────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="280"
                    Margin="8,4"
                    HorizontalScrollBarVisibility="Disabled">

        <StackPanel>

          <!-- Empty state -->
          <Border Padding="16,20"
                  IsVisible="{Binding HasVersions, Converter={x:Static BoolConverters.Not}}">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
              <mi:MaterialIcon Kind="ClipboardTextHistory"
                               Width="24" Height="24"
                               Foreground="#252C3F"
                               HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [flowVersion.noCheckpoints], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="12"
                         Foreground="#4A5568"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [flowVersion.noCheckpointsHint], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="10"
                         Foreground="#2A3348"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Version rows -->
          <ItemsControl ItemsSource="{Binding Versions}"
                        IsVisible="{Binding HasVersions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:FlowVersionRowViewModel">
                <Border Classes="version-row">
                  <Grid RowDefinitions="Auto,Auto">

                    <!-- Row 0: Label + timestamp + buttons -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto">

                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EAED"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding CreatedAtFormatted}"
                                     FontSize="10"
                                     Foreground="#4A5568"
                                     FontFamily="{StaticResource MonoFont}"/>
                          <TextBlock Text="{Binding NodeCount}"
                                     FontSize="10"
                                     Foreground="#2A3348"/>
                        </StackPanel>
                      </StackPanel>

                      <!-- Compare button -->
                      <Button Grid.Column="1"
                              Classes="action-btn"
                              Margin="6,0,4,0"
                              Tag="{Binding Id}"
                              Name="CompareBtn">
                        <mi:MaterialIcon Kind="Compare" Width="12" Height="12"/>
                      </Button>

                      <!-- Restore button -->
                      <Button Grid.Column="2"
                              Classes="action-btn"
                              Margin="0,0,4,0"
                              Tag="{Binding Id}"
                              Name="RestoreBtn">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <mi:MaterialIcon Kind="Restore" Width="12" Height="12"/>
                          <TextBlock Text="{Binding [flowVersion.restore], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
                        </StackPanel>
                      </Button>

                      <!-- Delete button -->
                      <Button Grid.Column="3"
                              Classes="danger-btn"
                              Tag="{Binding Id}"
                              Name="DeleteBtn">
                        <mi:MaterialIcon Kind="TrashCanOutline" Width="12" Height="12"/>
                      </Button>
                    </Grid>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Diff results ──────────────────────────────────────────────────── -->
      <Border IsVisible="{Binding HasDiffItems}"
              BorderBrush="#1E2335"
              BorderThickness="0,1,0,0">

        <StackPanel>
          <Border Padding="12,8">
            <TextBlock Text="{Binding [flowVersion.diffResults], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#60A5FA"/>
          </Border>

          <ScrollViewer MaxHeight="200"
                        Margin="8,0,8,8"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DiffItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DiffItemViewModel">
                  <Grid ColumnDefinitions="14,*" Margin="0,1">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Icon}"
                               Foreground="{Binding KindBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Description}"
                               FontSize="10"
                               Foreground="#8B95A8"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
