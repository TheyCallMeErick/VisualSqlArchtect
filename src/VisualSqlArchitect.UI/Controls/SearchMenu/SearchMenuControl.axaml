<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:canvas="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.SearchMenuControl"
             x:DataType="canvas:SearchMenuViewModel">

  <UserControl.Styles>
    <!-- Result item default -->
    <Style Selector="Border.result-item">
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="CornerRadius"  Value="8"/>
      <Setter Property="Padding"       Value="10,7"/>
      <Setter Property="Margin"        Value="4,1"/>
      <Setter Property="Cursor"        Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.result-item:pointerover">
      <Setter Property="Background" Value="#1E2335"/>
    </Style>
    <Style Selector="Border.result-item.selected">
      <Setter Property="Background" Value="#1A2845"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Floating panel ═════════════════════════════════════════════════════ -->
  <Border Width="340"
          CornerRadius="12"
          Background="#13161F"
          BorderBrush="#252C3F"
          BorderThickness="1"
          BoxShadow="0 8 40 0 #80000000, 0 2 8 0 #60000000">

    <StackPanel>

      <!-- ── Search input ──────────────────────────────────────────────────── -->
      <Border Background="#1A1E2C"
              CornerRadius="12,12,0,0"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Search icon -->
          <mi:MaterialIcon Grid.Column="0"
                           Kind="Magnify"
                           Width="18" Height="18"
                           Foreground="#60A5FA"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>

          <!-- Text input -->
          <TextBox Grid.Column="1"
                   Text="{Binding Query, Mode=TwoWay}"
                   Watermark="{Binding [search.watermark], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="13"
                   Background="Transparent"
                   BorderThickness="0"
                   CaretBrush="#60A5FA"
                   Foreground="#E8EAED"
                   Name="SearchInput">
            <TextBox.Styles>
              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                <Setter Property="BorderBrush" Value="Transparent"/>
              </Style>
            </TextBox.Styles>
          </TextBox>

          <!-- Keyboard shortcut badge -->
          <Border Grid.Column="2"
                  Background="#252C3F"
                  CornerRadius="4"
                  Padding="5,2"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding [search.shortcut], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="10"
                       Foreground="#4A5568"/>
          </Border>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Snippets section (shown when snippets exist) ─────────────────── -->
      <Border Padding="8,8,8,2"
              IsVisible="{Binding HasSnippets}">
        <StackPanel Spacing="4">
          <!-- Header -->
          <TextBlock Text="{Binding [search.snippets], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="9"
                     FontWeight="Bold"
                     Foreground="#FBBF24"
                     LetterSpacing="1.5"
                     Margin="6,0,0,2"/>
          <ItemsControl ItemsSource="{Binding Snippets}" Name="SnippetsList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="canvas:SnippetViewModel">
                <Border Classes="result-item">
                  <Grid ColumnDefinitions="34,*,Auto">
                    <!-- Star icon badge -->
                    <Border Grid.Column="0"
                            Width="28" Height="28"
                            CornerRadius="7"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Background="#1A150A">
                      <mi:MaterialIcon Kind="Bookmark"
                                       Width="14" Height="14"
                                       Foreground="#FBBF24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Border>
                    <!-- Name + summary -->
                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="12"
                                 FontWeight="Medium"
                                 Foreground="#E8EAED"/>
                      <TextBlock Text="{Binding Summary}"
                                 FontSize="10"
                                 Foreground="#4A5568"/>
                    </StackPanel>
                    <!-- Tags badge (optional) -->
                    <Border Grid.Column="2"
                            Background="#1A150A"
                            CornerRadius="4"
                            Padding="5,2"
                            Margin="4,0"
                            IsVisible="{Binding HasTags}">
                      <TextBlock Text="{Binding Tags}"
                                 FontSize="9"
                                 Foreground="#FBBF24"/>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Divider between snippets and node results -->
      <Border Height="1" Background="#1E2335"
              IsVisible="{Binding HasSnippets}"/>

      <!-- ── Results list ───────────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Results}" Margin="0,4,0,4" Name="ResultsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="canvas:NodeSearchResultViewModel">

              <Border Classes="result-item">

                <Grid ColumnDefinitions="34,*,Auto">

                  <!-- Category icon badge -->
                  <Border Grid.Column="0"
                          Width="28" Height="28"
                          CornerRadius="7"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding AccentColor}" Opacity="0.18"/>
                    </Border.Background>
                    <mi:MaterialIcon Kind="{Binding IconKind}"
                                     Width="15" Height="15"
                                     Foreground="{Binding AccentBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                  </Border>

                  <!-- Name + category -->
                  <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#E8EAED"/>
                    <TextBlock Text="{Binding Category}"
                               FontSize="10"
                               Foreground="#4A5568"/>
                  </StackPanel>

                  <!-- Accent dot -->
                  <Ellipse Grid.Column="2"
                           Width="6" Height="6"
                           Fill="{Binding AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state -->
      <Border Padding="16,20"
              IsVisible="{Binding Results.Count, Converter={x:Static BoolConverters.Not}}">
        <StackPanel HorizontalAlignment="Center" Spacing="6">
          <TextBlock Text="{Binding [search.empty], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="13"
                     Foreground="#4A5568"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding [search.emptyHint], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="10"
                     Foreground="#3B4560"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- ── Footer keyboard hints ─────────────────────────────────────────── -->
      <Border Background="#0E1018"
              CornerRadius="0,0,12,12"
              Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↑↓" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="{Binding [common.navigate], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↵" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="{Binding [search.spawn], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="{Binding [common.esc], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568"/>
            </Border>
            <TextBlock Text="{Binding [common.close], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
