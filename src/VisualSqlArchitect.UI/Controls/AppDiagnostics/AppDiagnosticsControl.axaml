<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:appdiag="using:VisualSqlArchitect.UI.Services.AppDiagnostics.Models"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.AppDiagnosticsControl"
             x:DataType="vm:AppDiagnosticsViewModel">

  <UserControl.Styles>
    <Style Selector="Border.diag-row">
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="CornerRadius"  Value="8"/>
      <Setter Property="Padding"       Value="12,9"/>
      <Setter Property="Margin"        Value="4,2"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.10"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.diag-row:pointerover">
      <Setter Property="Background" Value="{StaticResource PanelElevatedBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.008)"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Floating diagnostics panel ════════════════════════════════════════════ -->
  <Border Width="520"
          CornerRadius="12"
          Background="{StaticResource Surface0Brush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          BoxShadow="0 8 40 0 #80000000, 0 2 8 0 #60000000"
          RenderTransformOrigin="50%,50%"
          RenderTransform="scale(1)">

    <StackPanel>

      <!-- ── Header ───────────────────────────────────────────────────────── -->
      <Border Background="{StaticResource PanelElevatedBrush}"
              CornerRadius="12,12,0,0"
              Padding="16,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

          <!-- Pulse icon -->
          <mi:MaterialIcon Grid.Column="0"
                           Kind="HeartPulse"
                           Width="18" Height="18"
                           Foreground="{Binding OverallColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

          <!-- Title + overall status -->
          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="{Binding [diagnostics.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding OverallLabel}"
                       FontSize="10"
                       Foreground="{Binding OverallColor}"/>
          </StackPanel>

          <!-- Run button -->
          <Button Grid.Column="2"
                  Command="{Binding RunChecksCommand}"
                  Background="{StaticResource BorderSoftBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="10,5"
                  Margin="0,0,6,0"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding [diagnostics.tooltip.rerun], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [diagnostics.run], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Refresh" Width="13" Height="13" Foreground="{StaticResource StatusInfoBrush}"/>
              <TextBlock Text="{Binding [diagnostics.run], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11" Foreground="{StaticResource StatusInfoBrush}"/>
            </StackPanel>
          </Button>

          <!-- Copy report button -->
          <Button Grid.Column="3"
                  Command="{Binding CopyReportCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="6"
                  Padding="8,5"
                  Margin="0,0,6,0"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding [diagnostics.tooltip.copy], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [diagnostics.tooltip.copy], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="ContentCopy" Width="15" Height="15" Foreground="{StaticResource TextMutedBrush}"/>
          </Button>

          <!-- Close button -->
          <Button Grid.Column="4"
                  Command="{Binding CloseCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="6"
                  Padding="8,5"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding [diagnostics.tooltip.close], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [diagnostics.tooltip.close], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="{StaticResource TextMutedBrush}"/>
          </Button>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="{StaticResource BorderSoftBrush}"/>

      <!-- Running indicator -->
      <Border Padding="16,8"
              IsVisible="{Binding IsRunning}"
              Background="{StaticResource Surface1Brush}">
        <TextBlock Text="{Binding [diagnostics.running], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="11"
                   Foreground="{StaticResource StatusInfoBrush}"
                   HorizontalAlignment="Center"/>
      </Border>

      <!-- ── Entries list ──────────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Entries}" Margin="0,4,0,4">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="appdiag:AppDiagnosticEntry">

              <Border Classes="diag-row">
                <Grid ColumnDefinitions="28,*,Auto">

                  <!-- Status icon -->
                  <Border Grid.Column="0"
                          Width="22" Height="22"
                          CornerRadius="5"
                          Background="{StaticResource BorderSoftBrush}"
                          VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="{Binding StatusIconKind}"
                                     Width="14" Height="14"
                                     Foreground="{Binding StatusColor}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                  </Border>

                  <!-- Name + details + recommendation -->
                  <StackPanel Grid.Column="1" Spacing="2"
                              VerticalAlignment="Center" Margin="10,0,8,0">
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Details}"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock FontSize="10"
                               Foreground="{StaticResource StatusWarningBrush}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding Status,
                                 Converter={x:Static ObjectConverters.IsNotNull}}"
                               Text="{Binding Recommendation}">
                      <TextBlock.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                          <Binding Path="Status"
                                   Converter="{x:Static ObjectConverters.IsNotNull}"/>
                          <Binding Path="Status"
                                   ConverterParameter="0"
                                   Converter="{x:Static ObjectConverters.IsNotNull}"/>
                        </MultiBinding>
                      </TextBlock.IsVisible>
                    </TextBlock>
                  </StackPanel>

                  <!-- Timestamp -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding LastCheckLabel}"
                             FontSize="10"
                             Foreground="{StaticResource BorderBrush}"
                             VerticalAlignment="Center"
                             FontFamily="{StaticResource MonoFont}"/>
                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- ── Footer ───────────────────────────────────────────────────────── -->
      <Border Background="{StaticResource PanelMutedBrush}"
              CornerRadius="0,0,12,12"
              Padding="12,8">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="{StaticResource BorderSoftBrush}" CornerRadius="3" Padding="4,1">
              <mi:MaterialIcon Kind="CheckCircle" Width="12" Height="12" Foreground="{StaticResource StatusOkBrush}"/>
            </Border>
            <TextBlock Text="{Binding [diagnostics.ok], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="{StaticResource BorderSoftBrush}" CornerRadius="3" Padding="4,1">
              <mi:MaterialIcon Kind="Alert" Width="12" Height="12" Foreground="{StaticResource StatusWarningBrush}"/>
            </Border>
            <TextBlock Text="{Binding [diagnostics.warning], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="{StaticResource BorderSoftBrush}" CornerRadius="3" Padding="4,1">
              <mi:MaterialIcon Kind="CloseCircle" Width="12" Height="12" Foreground="{StaticResource StatusErrorBrush}"/>
            </Border>
            <TextBlock Text="{Binding [diagnostics.error], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="{StaticResource BorderSoftBrush}" CornerRadius="3" Padding="4,1">
              <TextBlock Text="{Binding [common.esc], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
            </Border>
            <TextBlock Text="{Binding [common.close], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
