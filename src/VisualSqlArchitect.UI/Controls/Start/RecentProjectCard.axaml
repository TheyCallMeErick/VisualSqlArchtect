<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             x:Class="VisualSqlArchitect.UI.Controls.Start.RecentProjectCard"
             x:DataType="vm:StartRecentProjectItem">

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <Border Grid.Row="0" Height="2" CornerRadius="2" Background="{StaticResource AccentBlueBrush}" Opacity="0.65" Margin="0,0,0,6"/>
    <Border Grid.Row="1"
            Height="52"
            CornerRadius="8"
            Background="{StaticResource MacroBg2Brush}"
            BorderBrush="{StaticResource MacroBorderSubtleBrush}"
            BorderThickness="1"
            Padding="8,6">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Text="Ultimo snapshot"
                   FontSize="10"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBlock Grid.Row="1"
                   Text="{Binding SnapshotSummary}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Bottom"
                   TextTrimming="CharacterEllipsis"/>
      </Grid>
    </Border>

    <TextBlock Grid.Row="2"
               Margin="0,6,0,0"
               Text="{Binding DisplayName}"
               FontSize="{StaticResource StartFontCardTitle}"
               FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimaryBrush}"
               TextTrimming="CharacterEllipsis"/>

    <TextBlock Grid.Row="3"
               Margin="0,4,0,0"
               Text="{Binding LastOpenedLabel}"
               FontSize="{StaticResource StartFontMeta}"
               Foreground="{StaticResource TextSecondaryBrush}"/>

    <TextBlock Grid.Row="4"
               Text="{Binding Provider}"
               VerticalAlignment="Bottom"
               Foreground="{StaticResource AccentBlueBrush}"
               FontSize="{StaticResource StartFontMeta}"
               FontWeight="SemiBold"/>
  </Grid>
</UserControl>
