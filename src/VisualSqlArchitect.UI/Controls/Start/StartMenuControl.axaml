<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:start="using:VisualSqlArchitect.UI.Controls.Start"
             xmlns:shell="using:VisualSqlArchitect.UI.Controls.Shell"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.Start.StartMenuControl"
             x:DataType="vm:StartMenuViewModel"
             x:Name="Root">

  <UserControl.Styles>
    <Style Selector="TextBlock.kicker">
      <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="LetterSpacing" Value="0.6"/>
    </Style>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource StartFontPageTitle}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource StartFontSectionTitle}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource StartFontBrand}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource StartFontNav}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.nav.active">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource StartFontMeta}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource StartFontMeta}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>
    <Style Selector="Button.icon-ghost">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tips-pill">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource StartFontMeta}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusCard}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingCard}"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #26000000"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="Border.card.hero-card">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0.0" Color="#201D4ED8"/>
          <GradientStop Offset="1.0" Color="#00141B2D"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#503B82F6"/>
    </Style>
    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BtnPrimaryBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource BtnPrimaryFgBrush}"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusPill}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingPrimaryButton}"/>
      <Setter Property="FontSize" Value="{StaticResource StartFontButton}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightAction}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="{StaticResource BtnGhostBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource BtnGhostFgBrush}"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusButton}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingGhostButton}"/>
      <Setter Property="FontSize" Value="{StaticResource StartFontMeta}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="Button.template-tile">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>
    <Style Selector="Button.template-tile:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="StackPanel.empty-state TextBlock">
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.quick-action-card">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0.0" Color="#241D4ED8"/>
          <GradientStop Offset="1.0" Color="#10141B2D"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#503B82F6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
    <Style Selector="Border.empty-placeholder">
      <Setter Property="Background" Value="#120F172A"/>
      <Setter Property="BorderBrush" Value="#304B6CB7"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <!-- Responsive typography scale for desktop ranges -->
    <Style Selector="UserControl.start-compact TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource StartFontBrandCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource StartFontPageTitleCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource StartFontSectionTitleCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource StartFontNavCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact Button.primary">
      <Setter Property="FontSize" Value="{StaticResource StartFontButtonCompact}"/>
    </Style>
    <Style Selector="UserControl.start-compact Button.ghost">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaCompact}"/>
    </Style>

    <Style Selector="UserControl.start-large TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource StartFontBrandLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource StartFontPageTitleLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource StartFontSectionTitleLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource StartFontNavLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large Button.primary">
      <Setter Property="FontSize" Value="{StaticResource StartFontButtonLarge}"/>
    </Style>
    <Style Selector="UserControl.start-large Button.ghost">
      <Setter Property="FontSize" Value="{StaticResource StartFontMetaLarge}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Background="{StaticResource MacroBg0Brush}">
    <Canvas Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.38">
      <Border Width="420" Height="420" CornerRadius="999" Background="#181D4ED8" Canvas.Left="-140" Canvas.Top="-220"/>
      <Border Width="360" Height="360" CornerRadius="999" Background="#1216A34A" Canvas.Right="-90" Canvas.Top="110"/>
    </Canvas>

    <shell:AppHeaderBar Grid.Row="0"
                        Title="Visual SQL Architect"
                        ShowBrandBadge="True"
                        ShowWindowControls="True">
      <shell:AppHeaderBar.RightContent>
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource StartSpaceSM}" VerticalAlignment="Center">
          <Button Classes="tips-pill" Content="Dicas">
            <ToolTip.Tip>
              <StackPanel Spacing="4" MaxWidth="320">
                <TextBlock Text="Dicas rápidas" FontWeight="{StaticResource FontWeightStrong}"/>
                <TextBlock Text="1. Clique em Novo Diagrama para iniciar do zero." TextWrapping="Wrap"/>
                <TextBlock Text="2. Use templates para acelerar protótipos." TextWrapping="Wrap"/>
                <TextBlock Text="3. Abra conexões salvas para carregar tabelas reais." TextWrapping="Wrap"/>
                <TextBlock Text="Atalho: Ctrl+K abre a paleta de comandos." TextWrapping="Wrap"/>
              </StackPanel>
            </ToolTip.Tip>
          </Button>
          <Button Classes="icon-ghost"
                  Padding="7,4"
                  ToolTip.Tip="Configuracoes"
                  VerticalAlignment="Center"
                  Command="{Binding OpenSettingsCommand}">
            <mi:MaterialIcon Kind="CogOutline" Width="14" Height="14"/>
          </Button>
        </StackPanel>
      </shell:AppHeaderBar.RightContent>
    </shell:AppHeaderBar>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Grid Margin="24" ColumnDefinitions="2.2*,1*" RowDefinitions="Auto,Auto,*" MinHeight="640">
      <Border Grid.Row="0" Grid.Column="0" Margin="0,0,14,0" Classes="card hero-card" Name="HeroBlock">
        <StackPanel Spacing="8">
          <TextBlock Classes="kicker" Text="WORKSPACE"/>
          <TextBlock Classes="h1" Text="Continuar de onde parou"/>
          <TextBlock Classes="meta" Text="Retome rapidamente um projeto recente ou comece um novo diagrama."/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Border Classes="chip"><TextBlock Classes="meta" Text="Fluxo rapido"/></Border>
            <Border Classes="chip"><TextBlock Classes="meta" Text="Templates"/></Border>
            <Border Classes="chip"><TextBlock Classes="meta" Text="Conexoes"/></Border>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Classes="card" Margin="0" Name="ConnectionsSection" MinHeight="352">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Classes="h2" Text="Conexoes salvas"/>
            <TextBlock Classes="meta" Text="Conecte-se rapidamente a um banco para carregar schema e tabelas."/>
          </StackPanel>

          <ScrollViewer Grid.Row="1" Margin="{StaticResource StartMarginInnerVertical}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSavedConnections}">
            <ItemsControl ItemsSource="{Binding SavedConnections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StartSavedConnectionItem">
                  <Button Classes="ghost"
                          Padding="8,4"
                          Margin="0,2,0,2"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Tag="{Binding}"
                          Click="SavedConnectionCard_Click">
                    <start:ConnectionStatusCard/>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="1" Classes="empty-placeholder" HorizontalAlignment="Stretch" VerticalAlignment="Center" IsVisible="{Binding HasSavedConnections, Converter={x:Static BoolConverters.Not}}">
            <StackPanel Classes="empty-state" Spacing="6">
              <TextBlock Text="Nenhuma conexão configurada ainda" Classes="meta" FontWeight="SemiBold"/>
              <TextBlock Text="Crie uma conexão para explorar tabelas reais no editor." Classes="meta" Opacity="0.85"/>
            </StackPanel>
          </Border>

          <Button Grid.Row="2" Classes="primary" Content="+ Nova Conexao" Command="{Binding OpenConnectionsCommand}" HorizontalAlignment="Center" MinWidth="170"/>
        </Grid>
      </Border>

      <Border Grid.Row="1" Grid.Column="0" Margin="0,14,14,0" Classes="card" Name="RecentSection" MinHeight="300">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <TextBlock Classes="h2" Text="Projetos Recentes"/>

          <TextBox Grid.Row="1"
                   Margin="{StaticResource StartMarginInnerTop}"
                   Text="{Binding RecentSearchQuery}"
                   Watermark="Buscar projeto recente..."
                   Height="34"/>

          <ScrollViewer Grid.Row="2" Margin="{StaticResource StartMarginInnerTop}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="170">
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource StartSpaceSM}">
              <Border Classes="quick-action-card" Width="272" Height="154">
                <Grid RowDefinitions="Auto,*,Auto,Auto">
                  <TextBlock Classes="meta" Text="Acoes rapidas" FontWeight="{StaticResource FontWeightStrong}"/>
                  <TextBlock Grid.Row="1" Classes="meta" Text="Abra um arquivo existente ou inicie um novo diagrama." TextWrapping="Wrap" Opacity="0.9" Margin="0,6,0,0"/>
                  <Button Grid.Row="2" Classes="ghost" Content="Abrir arquivo" Command="{Binding OpenFromDiskCommand}" Margin="0,8,0,0" HorizontalAlignment="Center" MinWidth="132"/>
                  <Button Grid.Row="3" Classes="primary" Content="Novo Diagrama" Command="{Binding CreateNewDiagramCommand}" Margin="0,8,0,0" HorizontalAlignment="Center" MinWidth="164"/>
                </Grid>
              </Border>

              <ItemsControl ItemsSource="{Binding RecentProjects}" IsVisible="{Binding HasRecentProjects}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource StartSpaceSM}"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:StartRecentProjectItem">
                    <Button Classes="ghost"
                            Width="220"
                            Height="154"
                            Padding="{StaticResource StartPaddingGhostButton}"
                            Tag="{Binding}"
                            Click="RecentProjectCard_Click"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                      <start:RecentProjectCard/>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <Border Grid.Row="3" Classes="empty-placeholder" Margin="0,10,0,0" VerticalAlignment="Center" IsVisible="{Binding HasRecentProjects, Converter={x:Static BoolConverters.Not}}">
            <StackPanel Classes="empty-state" Spacing="8">
              <TextBlock Text="Nenhum projeto recente ainda" Classes="h2" FontSize="{StaticResource StartFontSectionTitle}"/>
              <TextBlock Text="Use o card de ações rápidas acima para começar." Classes="meta" Opacity="0.9"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="card" Margin="0,14,0,0" Name="TemplatesSection">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Classes="h2" Text="Explorar templates"/>
            <Border Classes="chip"><TextBlock Classes="meta" Text="Favoritos no topo"/></Border>
          </StackPanel>
          <ScrollViewer Grid.Row="1" Margin="{StaticResource StartMarginInnerTop}" Padding="2,0,2,8" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="176" MinHeight="176">
            <ItemsControl ItemsSource="{Binding TemplateCatalog}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="0"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StartTemplateItem">
                  <Grid Margin="6,6,6,6" Width="236" Height="152">
                    <Button Classes="template-tile"
                            Width="236"
                            Height="152"
                            Padding="{StaticResource StartPaddingGhostButton}"
                            Tag="{Binding}"
                            Click="TemplateCard_Click"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                      <start:TemplateCard/>
                    </Button>

                    <Button Classes="icon-ghost"
                            Width="24"
                            Height="24"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,8,8,0"
                            Tag="{Binding}"
                            Click="TemplateFavorite_Click"
                            ToolTip.Tip="Favoritar template"
                            ZIndex="2">
                      <Grid>
                        <TextBlock Text="★" Foreground="{StaticResource BtnWarningFgBrush}" IsVisible="{Binding IsFavorite}"/>
                        <TextBlock Text="☆" Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding !IsFavorite}"/>
                      </Grid>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
      </Grid>
    </ScrollViewer>

  </Grid>
</UserControl>
