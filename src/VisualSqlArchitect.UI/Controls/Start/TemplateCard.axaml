<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:startmodels="using:VisualSqlArchitect.UI.Services.Start.Models"
             x:Class="VisualSqlArchitect.UI.Controls.Start.TemplateCard"
             x:DataType="startmodels:StartTemplateItem">

  <Grid RowDefinitions="Auto,Auto,*">
    <TextBlock Text="{Binding Name}"
               FontSize="{StaticResource StartFontCardTitle}"
               FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimaryBrush}"
               TextTrimming="CharacterEllipsis"/>

    <Border Grid.Row="1" Margin="0,6,0,0" Background="#1A1D4ED8" BorderBrush="#403B82F6" BorderThickness="1" CornerRadius="999" Padding="7,2" HorizontalAlignment="Left">
      <TextBlock Text="{Binding Category}"
                 FontSize="{StaticResource StartFontMeta}"
                 Foreground="{StaticResource AccentBlueBrush}"/>
    </Border>

    <TextBlock Grid.Row="2"
               Margin="0,6,0,0"
               Text="{Binding Description}"
               FontSize="{StaticResource StartFontMeta}"
               Foreground="{StaticResource TextSecondaryBrush}"
               Opacity="0.92"
               MaxLines="3"
               TextWrapping="Wrap"
               TextTrimming="CharacterEllipsis"/>
  </Grid>
</UserControl>
