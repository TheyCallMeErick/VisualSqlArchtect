<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.PropertyPanelControl"
             x:DataType="vm:PropertyPanelViewModel">

  <UserControl.Styles>

    <!-- Section header -->
    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize"      Value="9"/>
      <Setter Property="FontWeight"    Value="Bold"/>
      <Setter Property="Foreground"    Value="#4A5568"/>
      <Setter Property="LetterSpacing" Value="1.5"/>
      <Setter Property="Margin"        Value="0,0,0,6"/>
    </Style>

    <!-- Parameter label -->
    <Style Selector="TextBlock.param-label">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="Foreground" Value="#8B95A8"/>
      <Setter Property="Margin"     Value="0,0,0,3"/>
    </Style>

    <!-- Parameter input -->
    <Style Selector="TextBox.param-input">
      <Setter Property="Background"    Value="#0D0F14"/>
      <Setter Property="BorderBrush"   Value="#252C3F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"    Value="#E8EAED"/>
      <Setter Property="FontFamily"    Value="Consolas,monospace"/>
      <Setter Property="FontSize"      Value="11"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="7,5"/>
    </Style>
    <Style Selector="TextBox.param-input:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#3B82F6"/>
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox.param-combo">
      <Setter Property="Background"    Value="#0D0F14"/>
      <Setter Property="BorderBrush"   Value="#252C3F"/>
      <Setter Property="Foreground"    Value="#E8EAED"/>
      <Setter Property="FontSize"      Value="11"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Padding"       Value="7,5"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Pin row -->
    <Style Selector="Border.pin-info-row">
      <Setter Property="Padding"       Value="8,5"/>
      <Setter Property="CornerRadius"  Value="6"/>
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.pin-info-row:pointerover">
      <Setter Property="Background" Value="#131720"/>
    </Style>

    <Style Selector="Button.panel-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Border.CornerRadius" Value="0"/>
      <Setter Property="Border.BorderThickness" Value="0,0,0,2"/>
      <Setter Property="Border.BorderBrush" Value="Transparent"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.1"/>
          <BrushTransition Property="Border.BorderBrush" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.panel-tab:pointerover">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.panel-tab.active">
      <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="Border.BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="Button.panel-tab:focus-visible">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="Border.BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="Border.BorderThickness" Value="0,0,0,2"/>
    </Style>
    <Style Selector="Button.panel-tab:disabled">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Opacity" Value="0.62"/>
      <Setter Property="Border.BorderBrush" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Panel shell ════════════════════════════════════════════════════════ -->
  <Border Background="#0F1219"
          BorderBrush="#1A1D26"
          BorderThickness="1,0,0,0">

    <Grid RowDefinitions="42,*">

      <!-- ── Panel header ──────────────────────────────────────────────────── -->
      <Border Grid.Row="0"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Spacing="0">
          <Button Classes="panel-tab"
                  Classes.active="{Binding ShowPropertiesTab}"
                  Command="{Binding SelectPropertiesTabCommand}"
                  Content="Properties"/>
          <Button Classes="panel-tab"
                  Classes.active="{Binding ShowProjectSettingsTab}"
                  Command="{Binding SelectProjectSettingsTabCommand}"
                  Content="Project Settings"/>
        </StackPanel>
      </Border>

      <!-- ── Scrollable content ────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            IsVisible="{Binding ShowPropertiesTab}">
        <Grid RowDefinitions="Auto,*">
        <Border Padding="12,10"
                BorderBrush="#1A1D26"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding HasNode}">
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
            <Border Grid.Column="0"
              Grid.RowSpan="2"
                    Width="24" Height="24"
                    CornerRadius="6"
                    Background="{Binding HeaderGradient}"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center">
              <mi:MaterialIcon Kind="{Binding CategoryIconKind}"
                               Width="12" Height="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
              <TextBlock Text="{Binding PanelTitle}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#E8EAED"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding NodeCategory}"
                         FontSize="10"
                         Foreground="#4A5568"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Spacing="1">
              <TextBlock Text="NODE TYPE"
                         FontSize="9"
                         FontWeight="Bold"
                         Foreground="#4A5568"
                         LetterSpacing="1.4"/>
              <TextBlock Text="{Binding NodeTypeLabel}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="#E8EAED"/>
              <TextBlock Text="{Binding NodeTypeSubtitle}"
                         FontSize="10"
                         Foreground="#8B95A8"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Grid>
        </Border>
        <StackPanel Grid.Row="1" Spacing="0" IsVisible="{Binding HasNode}">

          <!-- ── ALIAS ──────────────────────────────────────────────────────── -->
          <Border Padding="12,12,12,8"
                  BorderBrush="#1A1D26"
              BorderThickness="0,0,0,1"
              IsVisible="{Binding ShowAliasEditor}">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-label" Text="{Binding NodeAliasLabel}"/>
              <TextBox Classes="param-input"
                       Text="{Binding NodeAlias, Mode=TwoWay}"
                       Watermark="{Binding [property.aliasWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="11"/>
            </StackPanel>
          </Border>

          <!-- ── PARAMETERS ─────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,8"
                  BorderBrush="#1A1D26"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasParams}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.parameters], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding Parameters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ParameterRowViewModel">
                    <StackPanel Spacing="3" Margin="0,0,0,10">

                      <!-- Param label + dirty indicator -->
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="param-label"
                                   Text="{Binding Name}"/>
                        <Ellipse Grid.Column="1"
                                 Width="5" Height="5"
                                 Fill="#FBBF24"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsDirty}"/>
                      </Grid>

                      <!-- Text / JsonPath input -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding Description}"
                               IsVisible="{Binding IsText}"/>

                      <!-- Number input -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="0"
                               IsVisible="{Binding IsNumber}"/>

                      <!-- Enum / Cast type picker -->
                      <ComboBox Classes="param-combo"
                                ItemsSource="{Binding EnumValues}"
                                SelectedItem="{Binding Value, Mode=TwoWay}"
                                IsVisible="{Binding IsEnum}"/>

                      <!-- Boolean toggle -->
                      <CheckBox Content="{Binding [property.enabled], Source={x:Static loc:LocalizationService.Instance}}"
                                IsChecked="{Binding Value, Mode=TwoWay, Converter={x:Static BoolConverters.Not}}"
                                Foreground="#8B95A8"
                                FontSize="11"
                                IsVisible="{Binding IsBoolean}"/>

                      <!-- DateTime picker (ISO 8601) -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding [property.datetimeWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                               IsVisible="{Binding IsDateTime}"/>

                      <!-- Date picker (ISO 8601 date only) -->
                      <TextBox Classes="param-input"
                               Text="{Binding Value, Mode=TwoWay}"
                               Watermark="{Binding [property.dateWatermark], Source={x:Static loc:LocalizationService.Instance}}"
                               IsVisible="{Binding IsDate}"/>

                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Apply button -->
                    <Button Content="{Binding [property.apply], Source={x:Static loc:LocalizationService.Instance}}"
                      HorizontalAlignment="Right"
                      Background="#0F1A30"
                      BorderBrush="#1E3A60"
                      BorderThickness="1"
                      Foreground="#60A5FA"
                      FontSize="11"
                      CornerRadius="6"
                      Padding="10,4"
                      Name="ApplyBtn">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#162540"/>
                  </Style>
                </Button.Styles>
              </Button>
            </StackPanel>
          </Border>

          <!-- ── INPUT PINS ────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,6"
                  BorderBrush="#1A1D26"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasInputs}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.inputPins], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding InputPins}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PinInfoRowViewModel">
                    <Border Classes="pin-info-row">
                      <Grid ColumnDefinitions="10,*,Auto,Auto">

                        <!-- Color dot -->
                        <Ellipse Grid.Column="0"
                                 Width="7" Height="7"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"/>

                        <!-- Name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="11"
                                   Foreground="#8B95A8"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas,monospace"/>

                        <!-- Type badge -->
                        <Border Grid.Column="2"
                                Background="#0D0F14"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="4,0">
                          <TextBlock Text="{Binding TypeLabel}"
                                     FontSize="9"
                                     Foreground="{Binding ColorBrush}"/>
                        </Border>

                        <!-- Connected indicator -->
                        <Ellipse Grid.Column="3"
                                 Width="5" Height="5"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"
                                 Opacity="{Binding Connected, Converter={x:Static BoolConverters.Not}}"
                                 IsVisible="{Binding Connected}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── OUTPUT PINS ───────────────────────────────────────────────── -->
          <Border Padding="12,10,12,6"
                  BorderBrush="#1A1D26"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasOutputs}">

            <StackPanel Spacing="0">
              <TextBlock Classes="section-label" Text="{Binding [property.outputPins], Source={x:Static loc:LocalizationService.Instance}}"/>

              <ItemsControl ItemsSource="{Binding OutputPins}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PinInfoRowViewModel">
                    <Border Classes="pin-info-row">
                      <Grid ColumnDefinitions="10,*,Auto">

                        <Ellipse Grid.Column="0"
                                 Width="7" Height="7"
                                 Fill="{Binding ColorBrush}"
                                 VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="11"
                                   Foreground="#8B95A8"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas,monospace"/>

                        <Border Grid.Column="2"
                                Background="#0D0F14"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="4,0">
                          <TextBlock Text="{Binding TypeLabel}"
                                     FontSize="9"
                                     Foreground="{Binding ColorBrush}"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── SQL TRACE ─────────────────────────────────────────────────── -->
          <Border Padding="12,10,12,12"
                  IsVisible="{Binding HasSqlTrace}">

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="section-label"
                           Text="{Binding [property.sqlTrace], Source={x:Static loc:LocalizationService.Instance}}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Background="#0A2218"
                        CornerRadius="4"
                        Padding="5,1">
                  <TextBlock Text="{Binding [property.live], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="8"
                             FontWeight="Bold"
                             Foreground="#14B8A6"
                             LetterSpacing="1"/>
                </Border>
              </Grid>

              <!-- Context label -->
              <TextBlock Text="{Binding SqlTraceContext}"
                         FontSize="10"
                         Foreground="#4A5568"
                         TextWrapping="Wrap"/>

              <!-- Fragment box -->
              <Border Background="#070B10"
                      BorderBrush="#14B8A6"
                      BorderThickness="0,0,0,2"
                      CornerRadius="6"
                      Padding="10,8">
                <TextBlock Text="{Binding SqlTraceFragment}"
                           FontFamily="Consolas,monospace"
                           FontSize="11"
                           Foreground="#14B8A6"
                           TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </Border>

        </StackPanel>

        <TextBlock Grid.Row="1"
             Text="Select a node to edit its properties."
                   Margin="12,12,12,0"
                   FontSize="11"
                   Foreground="#4A5568"
                   IsVisible="{Binding HasNode, Converter={x:Static BoolConverters.Not}}"/>
        </Grid>
      </ScrollViewer>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    IsVisible="{Binding ShowProjectSettingsTab}">
        <StackPanel Spacing="12" Margin="12,10,12,12">
          <TextBlock Classes="section-label" Text="Naming Conventions"/>

          <StackPanel Spacing="4">
            <TextBlock Classes="param-label" Text="Alias convention"/>
            <ComboBox Classes="param-combo"
                      ItemsSource="{Binding NamingConventionOptions}"
                      SelectedItem="{Binding SelectedNamingConvention, Mode=TwoWay}"/>
          </StackPanel>

          <CheckBox Content="Enforce alias naming"
                    IsChecked="{Binding EnforceAliasNaming, Mode=TwoWay}"
                    FontSize="11"
                    Foreground="#8B95A8"/>

          <CheckBox Content="Warn on reserved SQL keywords"
                    IsChecked="{Binding WarnOnReservedKeywords, Mode=TwoWay}"
                    FontSize="11"
                    Foreground="#8B95A8"/>

          <StackPanel Spacing="4">
            <TextBlock Classes="param-label" Text="Max alias length"/>
            <TextBox Classes="param-input"
                     Text="{Binding MaxAliasLength, Mode=TwoWay}"
                     Watermark="64"/>
          </StackPanel>

          <Border Background="#0D0F14"
                  BorderBrush="#252C3F"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8,7">
            <TextBlock Text="These settings are project-scoped and will be used by naming and validation helpers."
                       FontSize="10"
                       TextWrapping="Wrap"
                       Foreground="#4A5568"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
