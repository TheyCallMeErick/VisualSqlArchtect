<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.FileVersionHistoryOverlay"
             x:DataType="vm:FileVersionHistoryViewModel">

  <Border MaxWidth="620"
          Background="#0D0F14"
          BorderBrush="#252C3F"
          BorderThickness="1"
          CornerRadius="12"
          BoxShadow="0 8 40 0 #80000000">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

      <Border Grid.Row="0" Background="#0B0D12" CornerRadius="12,12,0,0" Padding="12,10">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                  Background="#0F1A30" BorderBrush="#1E3A60" BorderThickness="1" Margin="0,0,8,0">
            <mi:MaterialIcon Kind="History" Width="13" Height="13" Foreground="#60A5FA"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>

          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding [fileHistory.title], Source={x:Static loc:LocalizationService.Instance}}" FontSize="12" FontWeight="SemiBold" Foreground="#E8EAED"/>
            <TextBlock Text="{Binding CurrentFileLabel}" FontSize="10" Foreground="#4A5568"/>
          </StackPanel>

          <Button Grid.Column="2" Name="CloseBtn" Background="Transparent" BorderThickness="0" Foreground="#8B95A8">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <Border Grid.Row="1" Height="1" Background="#1E2335"/>

      <Border Grid.Row="2" Padding="12,10">
        <Grid ColumnDefinitions="Auto,Auto,*">
          <Button Grid.Column="0" Name="ReloadBtn" Margin="0,0,8,0"
                  Background="#0F2040" BorderBrush="#1E3A60" BorderThickness="1"
                  Foreground="#60A5FA" CornerRadius="5" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
              <TextBlock Text="{Binding [fileHistory.reload], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>

          <Button Grid.Column="1" Name="RestoreBtn"
                  IsEnabled="{Binding CanRestore}"
                  Background="#123019" BorderBrush="#1E5A2B" BorderThickness="1"
                  Foreground="#4ADE80" CornerRadius="5" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="Restore" Width="12" Height="12"/>
              <TextBlock Text="{Binding [fileHistory.restoreSelected], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>

          <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Margin="12,0,0,0"
                     VerticalAlignment="Center" FontSize="10" Foreground="#4A5568"/>
        </Grid>
      </Border>

      <Border Grid.Row="3" Padding="10,0,10,10">
        <Border Background="#0A0D15" BorderBrush="#252C3F" BorderThickness="1" CornerRadius="8" Padding="8">
          <Grid>
            <ListBox ItemsSource="{Binding Versions}"
                     SelectedItem="{Binding SelectedVersion}"
                     IsVisible="{Binding HasVersions}"
                     Name="HistoryList">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,Auto" Margin="2,4">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding CreatedAtLocalLabel}" Foreground="#E8EAED" FontSize="11"/>
                      <TextBlock Text="{Binding VersionPath}" Foreground="#4A5568" FontSize="9" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding SizeLabel}" Foreground="#60A5FA" FontSize="10" HorizontalAlignment="Right"/>
                      <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding [fileHistory.compressedLabel], Source={x:Static loc:LocalizationService.Instance}}" Foreground="#4A5568" FontSize="9"/>
                        <TextBlock Text="{Binding IsCompressed}" Foreground="#4A5568" FontSize="9"/>
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel IsVisible="{Binding HasVersions, Converter={x:Static BoolConverters.Not}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
              <mi:MaterialIcon Kind="History" Width="22" Height="22" Foreground="#2A3348" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [fileHistory.empty], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11" Foreground="#4A5568" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding [fileHistory.emptyHint], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#2A3348" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>
      </Border>
    </Grid>
  </Border>
</UserControl>
