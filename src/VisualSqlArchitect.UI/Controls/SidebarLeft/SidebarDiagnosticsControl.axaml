<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:appdiag="using:VisualSqlArchitect.UI.Services.AppDiagnostics.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             x:Class="VisualSqlArchitect.UI.Controls.SidebarDiagnosticsControl"
             x:DataType="vm:AppDiagnosticsViewModel">

  <UserControl.Styles>
    <Style Selector="Border.diag-shell">
      <Setter Property="Background" Value="{StaticResource MacroBg0Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusCard}"/>
    </Style>

    <Style Selector="Expander.diag-category">
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusButton}"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Expander.diag-category:pointerover">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="Border.diag-item">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusButton}"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12,12,12,10">
    <Border Grid.Row="0" Classes="diag-shell" Padding="10,8">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <mi:MaterialIcon Grid.Column="0"
                         Kind="History"
                         Width="14"
                         Height="14"
                         Margin="0,0,8,0"
                         Foreground="{Binding OverallColor}"
                         VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1"
                   Text="{Binding [diagnostics.title], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="{StaticResource FontSizeBody}"
                   FontWeight="{StaticResource FontWeightStrong}"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <Border Grid.Column="2"
                Padding="8,2"
                Background="{StaticResource MacroBg2Brush}"
                CornerRadius="999">
          <TextBlock Text="{Binding OverallLabel}"
                     FontSize="{StaticResource FontSizeMeta}"
                     Foreground="{Binding OverallColor}"/>
        </Border>
      </Grid>
    </Border>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="6"
                Margin="0,10,0,10">
      <Button Command="{Binding RunChecksCommand}"
              Classes="secondary"
              CornerRadius="{StaticResource StartRadiusButton}"
              Padding="9,5"
              FontSize="{StaticResource FontSizeMeta}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <mi:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
          <TextBlock Text="{Binding [diagnostics.run], Source={x:Static loc:LocalizationService.Instance}}"/>
        </StackPanel>
      </Button>

      <Button Command="{Binding CopyReportCommand}"
              Classes="secondary"
              CornerRadius="{StaticResource StartRadiusButton}"
              Padding="9,5"
              FontSize="{StaticResource FontSizeMeta}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <mi:MaterialIcon Kind="ContentCopy" Width="12" Height="12"/>
          <TextBlock Text="{Binding [liveSql.copy], Source={x:Static loc:LocalizationService.Instance}}"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <ScrollViewer x:Name="DiagnosticsScroll"
                  Grid.Row="2"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl x:Name="CategoriesItems"
                    ItemsSource="{Binding Categories}"
                    HorizontalAlignment="Stretch">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="appdiag:AppDiagnosticCategoryViewModel">
            <Expander Classes="diag-category"
                      Width="{Binding #CategoriesItems.Bounds.Width}"
                      IsExpanded="{Binding IsExpanded}">
              <Expander.Header>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="10,8">
                  <mi:MaterialIcon Grid.Column="0"
                                   Kind="{Binding IconKind}"
                                   Width="13"
                                   Height="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             FontSize="{StaticResource FontSizeBody}"
                             FontWeight="{StaticResource FontWeightStrong}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <Border Grid.Column="2"
                          IsVisible="{Binding HasErrors}"
                          Background="{StaticResource BtnDangerBgBrush}"
                          CornerRadius="999"
                          Padding="6,1"
                          Margin="0,0,6,0">
                    <TextBlock Text="{Binding ErrorCount}"
                               Foreground="{StaticResource BtnDangerFgBrush}"
                               FontSize="{StaticResource FontSizeMeta}"/>
                  </Border>
                  <Border Grid.Column="3"
                          IsVisible="{Binding HasWarnings}"
                          Background="{StaticResource BtnWarningBgBrush}"
                          CornerRadius="999"
                          Padding="6,1"
                          Margin="0,0,6,0">
                    <TextBlock Text="{Binding WarningCount}"
                               Foreground="{StaticResource BtnWarningFgBrush}"
                               FontSize="{StaticResource FontSizeMeta}"/>
                  </Border>
                  <TextBlock Grid.Column="4"
                             Text="{Binding TotalCount, StringFormat='({0})'}"
                             FontSize="{StaticResource FontSizeMeta}"
                             Foreground="{StaticResource TextMutedBrush}"
                             VerticalAlignment="Center"/>
                </Grid>
              </Expander.Header>

              <StackPanel Margin="10,0,10,10">
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="appdiag:AppDiagnosticEntry">
                      <Border Classes="diag-item">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                          <mi:MaterialIcon Grid.RowSpan="3"
                                           Grid.Column="0"
                                           Kind="{Binding StatusIconKind}"
                                           Width="13"
                                           Height="13"
                                           Foreground="{Binding StatusColor}"
                                           Margin="0,1,8,0"
                                           VerticalAlignment="Top"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Name}"
                                     FontSize="11"
                                     FontWeight="Medium"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding Details}"
                                     Margin="0,3,0,0"
                                     FontSize="{StaticResource FontSizeMeta}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"/>
                          <TextBlock Grid.Row="2"
                                     Grid.Column="1"
                                     Text="{Binding Recommendation}"
                                     Margin="0,4,0,0"
                                     FontSize="{StaticResource FontSizeMeta}"
                                     Foreground="{StaticResource TextMutedBrush}"
                                     TextWrapping="Wrap"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="3"
            Classes="diag-shell"
            Padding="8,6"
            Margin="0,8,0,0">
      <TextBlock Text="{Binding [diagnostics.tip], Source={x:Static loc:LocalizationService.Instance}}"
                 FontSize="{StaticResource FontSizeMeta}"
                 Foreground="{StaticResource TextSecondaryBrush}"/>
    </Border>
  </Grid>
</UserControl>
