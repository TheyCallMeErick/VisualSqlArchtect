<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.SidebarDiagnosticsControl"
             x:DataType="vm:AppDiagnosticsViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.section-caption">
      <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Opacity" Value="0.82"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="Border.diag-item">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusButton}"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="Border.diag-item:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
  </UserControl.Styles>

  <Border Background="{StaticResource MacroBg0Brush}">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12,12,12,10">
      <StackPanel Grid.Row="0" Spacing="4">
        <TextBlock Classes="section-caption" Text="HEALTH CHECK"/>
        <TextBlock Classes="section-title" Text="{Binding [diagnostics.title], Source={x:Static loc:LocalizationService.Instance}}"/>
        <Border Background="{StaticResource MacroBg1Brush}"
                BorderBrush="{StaticResource MacroBorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource StartRadiusButton}"
                Padding="8,6">
          <TextBlock Text="{Binding OverallLabel}"
                     FontSize="{StaticResource FontSizeBody}"
                     FontWeight="Medium"
                     Foreground="{Binding OverallColor}"/>
        </Border>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="6"
                  Margin="0,10,0,10">
        <Button Command="{Binding RunChecksCommand}"
                Classes="secondary"
                CornerRadius="{StaticResource StartRadiusButton}"
                Padding="9,5"
                FontSize="{StaticResource FontSizeMeta}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
            <TextBlock Text="{Binding [diagnostics.run], Source={x:Static loc:LocalizationService.Instance}}"/>
          </StackPanel>
        </Button>
        <Button Command="{Binding CopyReportCommand}"
                Classes="secondary"
                CornerRadius="{StaticResource StartRadiusButton}"
                Padding="9,5"
                FontSize="{StaticResource FontSizeMeta}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="ContentCopy" Width="12" Height="12"/>
            <TextBlock Text="Copiar"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Entries}" Margin="0,0,0,2">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AppDiagnosticEntry">
              <Border Classes="diag-item">
                <StackPanel Spacing="3">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="{Binding StatusIconKind}"
                                     Width="13"
                                     Height="13"
                                     Foreground="{Binding StatusColor}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Name}"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                  </StackPanel>
                  <TextBlock Text="{Binding Details}"
                             FontSize="{StaticResource FontSizeMeta}"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Recommendation}"
                             FontSize="{StaticResource FontSizeMeta}"
                             Foreground="{StaticResource TextMutedBrush}"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Border Grid.Row="3"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource StartRadiusButton}"
              Padding="8,6"
              Margin="0,8,0,0">
        <TextBlock Classes="section-caption" Text="Tip: execute diagnostics after major graph changes."/>
      </Border>
    </Grid>
  </Border>
</UserControl>
