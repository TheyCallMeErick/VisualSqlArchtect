<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:ctrl="using:VisualSqlArchitect.UI.Controls"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.SidebarControl"
             x:DataType="vm:SidebarViewModel">

  <!-- Tab Bar Style -->
  <UserControl.Styles>
    <Style Selector="Button.tab-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Border.CornerRadius" Value="0"/>
      <Setter Property="Border.BorderThickness" Value="0,0,0,2"/>
      <Setter Property="Border.BorderBrush" Value="Transparent"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.1"/>
          <BrushTransition Property="Border.BorderBrush" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.tab-button:pointerover">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="Button.tab-button.active">
      <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="Border.BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="Button.tab-button:focus-visible">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="Border.BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="Border.BorderThickness" Value="0,0,0,2"/>
    </Style>

    <Style Selector="Button.tab-button:disabled">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Opacity" Value="0.62"/>
      <Setter Property="Border.BorderBrush" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="42,*,Auto">

    <!-- Tab Bar (Header) -->
    <Border Grid.Row="0"
          Background="{StaticResource MacroBg1Brush}"
          BorderBrush="{StaticResource MacroBorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="0">

        <!-- Nodes Tab -->
        <Button x:Name="NodesTabButton"
                Classes="tab-button"
                Classes.active="{Binding ShowNodes}"
          Content="{Binding [sidebar.tab.nodes], Source={x:Static loc:LocalizationService.Instance}}"/>

        <!-- Connection Tab -->
        <Button x:Name="ConnectionTabButton"
                Classes="tab-button"
                Classes.active="{Binding ShowConnection}"
          Content="{Binding [sidebar.tab.connection], Source={x:Static loc:LocalizationService.Instance}}"/>

        <!-- Schema Tab -->
        <Button x:Name="SchemaTabButton"
                Classes="tab-button"
                Classes.active="{Binding ShowSchema}"
          Content="{Binding [sidebar.tab.schema], Source={x:Static loc:LocalizationService.Instance}}"/>

      </StackPanel>
    </Border>

    <!-- Tab Content Area -->
    <Grid Grid.Row="1" RowDefinitions="*">
      <!-- Nodes Tab -->
      <Grid IsVisible="{Binding ShowNodes}" Grid.Column="0">
        <ctrl:NodesListControl x:Name="NodesControl"/>
      </Grid>

      <!-- Connection Tab -->
      <Grid IsVisible="{Binding ShowConnection}" Grid.Column="0">
        <ctrl:ConnectionTabControl x:Name="ConnectionControl"/>
      </Grid>

      <!-- Schema Tab -->
      <Grid IsVisible="{Binding ShowSchema}" Grid.Column="0">
        <ctrl:SchemaControl x:Name="SchemaControl"/>
      </Grid>

    </Grid>

    <!-- Footer (Add Node + New Connection buttons) -->
    <Border Grid.Row="2"
          Background="{StaticResource MacroBg1Brush}"
          BorderBrush="{StaticResource MacroBorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="5">
        <Button Content="{Binding [sidebar.addNode], Source={x:Static loc:LocalizationService.Instance}}"
        Classes="success"
          Command="{Binding AddNodeCommand}"
                Padding="10,7"
        FontSize="{StaticResource FontSizeMeta}"
                FontWeight="Medium"
          CornerRadius="{StaticResource StartRadiusButton}"
                BorderThickness="0"
                HorizontalAlignment="Stretch"/>
        <Button Content="{Binding [connectionTab.new], Source={x:Static loc:LocalizationService.Instance}}"
        Classes="info"
          Command="{Binding AddConnectionCommand}"
                Padding="10,7"
        FontSize="{StaticResource FontSizeMeta}"
                FontWeight="Medium"
          CornerRadius="{StaticResource StartRadiusButton}"
                BorderThickness="0"
                HorizontalAlignment="Stretch"/>
      </StackPanel>
    </Border>
  </Grid>

</UserControl>
