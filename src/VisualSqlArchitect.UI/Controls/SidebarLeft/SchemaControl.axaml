<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:conv="using:VisualSqlArchitect.UI.Converters"
             x:Class="VisualSqlArchitect.UI.Controls.SchemaControl"
             x:DataType="vm:SchemaViewModel"
             Background="{StaticResource MacroBg0Brush}">

  <UserControl.Resources>
    <conv:StringToMaterialIconConverter x:Key="StringToIconConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.schema-title">
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="TextBlock.schema-meta">
      <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="Border.schema-header-card">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.schema-header-card:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="Border.schema-object-card">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.schema-object-card:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="Border.schema-object-card.expanded">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="StackPanel.schema-empty-state TextBlock">
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*" Margin="0">

    <!-- Header -->
    <Border Grid.Row="0" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="12,10">
      <DockPanel LastChildFill="True">
        <Button DockPanel.Dock="Right" Classes="secondary" Padding="8" CornerRadius="{StaticResource StartRadiusButton}" Cursor="Hand">
          <mi:MaterialIcon Kind="Refresh" Width="17" Height="17"/>
        </Button>
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding [schema.database], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeMeta}" FontWeight="{StaticResource FontWeightStrong}" Opacity="0.65" LetterSpacing="0.5"/>
          <TextBlock Text="{Binding DatabaseName}" Classes="schema-title"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Search -->
    <Border Grid.Row="1" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="12,10">
      <Border Background="{StaticResource MacroBg2Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1" CornerRadius="{StaticResource StartRadiusButton}" Padding="10,8">
        <DockPanel>
          <mi:MaterialIcon DockPanel.Dock="Left" Kind="Magnify" Foreground="{StaticResource TextSecondaryBrush}" Width="17" Height="17" VerticalAlignment="Center" Margin="0,0,7,0"/>
          <TextBox DockPanel.Dock="Left" Classes="sidebar-input" Text="{Binding FilterQuery}" Watermark="{Binding [schema.search], Source={x:Static loc:LocalizationService.Instance}}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" Foreground="{StaticResource TextPrimaryBrush}" Padding="0" FontSize="11" FontFamily="monospace"/>
        </DockPanel>
      </Border>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasConnection}">
      <StackPanel Spacing="4" Margin="0,10,0,0">
        <ItemsControl ItemsSource="{Binding Categories}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:SchemaCategoryViewModel">
              <StackPanel Spacing="2" Margin="8,10,8,0">
                <Border Classes="schema-header-card" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1" CornerRadius="14,14,0,0" Padding="13,11">
                  <DockPanel LastChildFill="True">
                    <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsExpanded}" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" Padding="4,2" FontSize="{StaticResource FontSizeMeta}" CornerRadius="{StaticResource StartRadiusButton}" BorderThickness="0">
                      <ToggleButton.Content>
                        <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"/>
                      </ToggleButton.Content>
                    </ToggleButton>
                    <StackPanel Spacing="9" Orientation="Horizontal" VerticalAlignment="Center">
                      <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="18" Height="18" Foreground="{Binding Color}"/>
                      <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Name}" Classes="schema-title"/>
                        <TextBlock Text="{Binding Count, StringFormat='{}︸ {0} item(s)'}" Classes="schema-meta" Opacity="0.6"/>
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding IsExpanded}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SchemaObjectViewModel">
                      <StackPanel Spacing="0">
                        <Border Padding="13,10" MinHeight="46" Background="{StaticResource MacroBg2Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1,0,1,0" Cursor="Hand" Classes="schema-object-card" Classes.expanded="{Binding IsExpanded}">
                          <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Command="{Binding AddNodeCommand}" IsVisible="{Binding AddNodeCommand, Converter={x:Static ObjectConverters.IsNotNull}}" Classes="success" Padding="6,2" FontSize="{StaticResource FontSizeMeta}" CornerRadius="{StaticResource StartRadiusButton}" Margin="8,0,0,0" Opacity="0.9">
                              <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                            </Button>
                            <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsExpanded}" IsVisible="{Binding IsExpandable}" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" Padding="4,2" FontSize="{StaticResource FontSizeMeta}" CornerRadius="{StaticResource StartRadiusButton}" BorderThickness="0">
                              <ToggleButton.Content>
                                <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"/>
                              </ToggleButton.Content>
                            </ToggleButton>
                            <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Center">
                              <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="17" Height="17" Foreground="{StaticResource AccentBlueBrush}"/>
                              <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Name}" Classes="schema-title"/>
                                <TextBlock Text="{Binding SubText}" Classes="schema-meta" Opacity="0.65"/>
                              </StackPanel>
                            </StackPanel>
                          </DockPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SchemaObjectViewModel">
                              <Border Padding="13,8" MinHeight="40" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1,0,1,0" Cursor="Hand" Margin="0" Classes="schema-object-card">
                                <DockPanel Margin="18,0,0,0">
                                  <Border DockPanel.Dock="Right" Background="{Binding BadgeColor}" CornerRadius="{StaticResource StartRadiusButton}" Padding="6,3" Opacity="0.25" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding DataType}" Foreground="{Binding BadgeColor}" FontSize="{StaticResource FontSizeMeta}" FontWeight="{StaticResource FontWeightStrong}" FontFamily="monospace"/>
                                  </Border>
                                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIconConverter}}" Width="15" Height="15" VerticalAlignment="Center" Foreground="{Binding BadgeColor}"/>
                                    <TextBlock Text="{Binding Name}" Classes="schema-title" VerticalAlignment="Center"/>
                                  </StackPanel>
                                </DockPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsExpanded}"/>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1" CornerRadius="0,0,14,14" Height="1" IsVisible="{Binding IsExpanded}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding ShowFilterEmptyState}" Classes="schema-empty-state">
      <TextBlock Text="{Binding [schema.search], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeMeta}" Opacity="0.8"/>
      <TextBlock Text="Nenhum objeto encontrado para o filtro atual" Foreground="{StaticResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}" FontWeight="{StaticResource FontWeightStrong}"/>
    </StackPanel>

    <!-- No Connection -->
    <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" IsVisible="{Binding HasConnection, Converter={x:Static BoolConverters.Not}}">
      <mi:MaterialIcon Kind="CloudOffOutline" Foreground="{StaticResource TextSecondaryBrush}" Width="52" Height="52"/>
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding [schema.noConnection], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontWeight="{StaticResource FontWeightStrong}"/>
        <TextBlock Text="{Binding [schema.noConnectionHint], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" FontSize="{StaticResource FontSizeMeta}" MaxWidth="220"/>
      </StackPanel>
    </StackPanel>

  </Grid>

</UserControl>
