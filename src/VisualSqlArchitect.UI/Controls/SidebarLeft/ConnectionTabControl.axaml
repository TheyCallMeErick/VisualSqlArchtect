<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:connmodels="using:VisualSqlArchitect.UI.Services.ConnectionManager.Models"
             xmlns:ctrl="using:VisualSqlArchitect.UI.Controls"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             x:Class="VisualSqlArchitect.UI.Controls.ConnectionTabControl"
             x:DataType="vm:ConnectionManagerViewModel"
             Background="{StaticResource MacroBg0Brush}"
             Name="ConnTabControl">

  <UserControl.Styles>
    <Style Selector="TextBlock.section-caption">
      <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <Style Selector="Border.connection-card">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource StartRadiusCard}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="MinHeight" Value="54"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.connection-card:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="Border.connection-card.active">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style Selector="TextBlock.empty-state">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="TextBlock.connection-title">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="TextBlock.connection-meta">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}"/>
      <Setter Property="MaxLines" Value="1"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="12">

    <!-- Active Connection Section -->
    <StackPanel Grid.Row="0" Spacing="10">
      <TextBlock Text="{Binding [connectionTab.active], Source={x:Static loc:LocalizationService.Instance}}"
           Classes="section-caption"
                 Margin="2,0,0,0"
             />

        <Border Classes="connection-card"
              Cursor="Hand"
              IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Health dot -->
          <Ellipse Grid.Column="0"
                   Width="8"
                   Height="8"
                   Fill="{Binding ConnectionIndicatorColor}"
                   VerticalAlignment="Center"/>

          <!-- Provider and database -->
          <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding ActiveConnectionLabel}"
                       Classes="connection-title"/>
            <TextBlock Text="{Binding ConnectionHealthLabel}"
                       Classes="connection-meta"
                       Margin="0,1,0,0"
                       ToolTip.Tip="{Binding ConnectionHealthTooltip}"/>
          </StackPanel>

          <!-- Refresh button -->
          <Button Grid.Column="2"
                  Content="↻"
                  Command="{Binding RefreshHealthCommand}"
              Classes="info"
                  Padding="8,5"
                  FontSize="{StaticResource FontSizeMeta}"
                  CornerRadius="{StaticResource StartRadiusButton}"
                  BorderThickness="0"
                  Margin="6,0,0,0"/>
        </Grid>
      </Border>

      <!-- No connection state -->
            <Border Classes="connection-card"
              IsVisible="{Binding ActiveProfileId, Converter={x:Static StringConverters.IsNullOrEmpty}}">
        <TextBlock Text="{Binding [connectionTab.none], Source={x:Static loc:LocalizationService.Instance}}"
                 Classes="connection-meta"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>
    </StackPanel>

    <!-- Saved Connections Section -->
    <StackPanel Grid.Row="1" Spacing="10" Margin="0,14,0,0">
      <TextBlock Text="{Binding [connectionTab.saved], Source={x:Static loc:LocalizationService.Instance}}"
             Classes="section-caption"
                 Margin="2,0,0,0"
             />

      <TextBlock Text="{Binding [connection.selectOrCreate], Source={x:Static loc:LocalizationService.Instance}}"
                 Classes="empty-state"
                 Margin="0,4,0,0"
                 IsVisible="{Binding Profiles.Count, Converter={x:Static BoolConverters.Not}}"/>

      <ScrollViewer VerticalScrollBarVisibility="Auto" Theme="{StaticResource FluentScrollViewer}">
        <ItemsControl ItemsSource="{Binding Profiles}" Margin="0,0,4,0" Name="ProfilesItemsControl">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="8"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>

          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="connmodels:ConnectionProfile">
                    <Border Classes="connection-card"
                      Cursor="Hand"
                      ToolTip.Tip="{Binding Name}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Status dot -->
                  <Ellipse Grid.Column="0"
                           Width="8"
                           Height="8"
                           VerticalAlignment="Center"
                           Fill="{StaticResource TextSecondaryBrush}"
                           Name="StatusDot"/>

                  <!-- Provider and database name -->
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding Provider}" Classes="connection-title"/>
                      <TextBlock Text="·" Classes="connection-meta"/>
                      <TextBlock Text="{Binding Database}" Classes="connection-title"/>
                    </StackPanel>
                    <TextBlock Classes="connection-meta">
                      <Run Text="{Binding Host}"/>
                      <Run Text=":"/>
                      <Run Text="{Binding Port}"/>
                    </TextBlock>
                  </StackPanel>

                  <!-- Connect/Disconnect button -->
                  <Button Grid.Column="2"
                          Padding="8,5"
                          FontSize="{StaticResource FontSizeMeta}"
                          CornerRadius="{StaticResource StartRadiusButton}"
                          BorderThickness="0"
                          Margin="6,0,0,0"
                          Command="{Binding ProfileActionCommand, RelativeSource={RelativeSource AncestorType=ctrl:ConnectionTabControl}}"
                          CommandParameter="{Binding .}"
                          Name="ActionButton"
                                                    Content="{Binding [connection.connect], Source={x:Static loc:LocalizationService.Instance}}"
                          Classes="secondary"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </StackPanel>

    <!-- New Connection Button -->
    <Button Grid.Row="2"
            Content="{Binding [connectionTab.new], Source={x:Static loc:LocalizationService.Instance}}"
          Classes="primary"
            Padding="12,8"
            HorizontalAlignment="Stretch"
            Margin="0,14,0,0"
            CornerRadius="{StaticResource StartRadiusButton}"
            BorderThickness="0"
            FontSize="{StaticResource FontSizeBody}"
            FontWeight="{StaticResource FontWeightStrong}"
            Command="{Binding OpenNewProfileCommand}"/>
  </Grid>

</UserControl>
