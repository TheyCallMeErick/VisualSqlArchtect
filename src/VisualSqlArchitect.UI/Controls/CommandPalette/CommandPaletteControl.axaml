<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="VisualSqlArchitect.UI.Controls.CommandPaletteControl"
             x:DataType="vm:CommandPaletteViewModel">

  <UserControl.Styles>
    <Style Selector="Border.cmd-item">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding"      Value="10,7"/>
      <Setter Property="Margin"       Value="4,1"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.08"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.cmd-item:pointerover">
      <Setter Property="Background" Value="#1E2335"/>
    </Style>
    <Style Selector="Border.cmd-item.selected">
      <Setter Property="Background" Value="#1A2845"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Floating panel ══════════════════════════════════════════════════════ -->
  <Border Width="420"
          CornerRadius="12"
          Background="#13161F"
          BorderBrush="#252C3F"
          BorderThickness="1"
          BoxShadow="0 8 40 0 #80000000, 0 2 8 0 #60000000">

    <StackPanel>

      <!-- ── Search input ────────────────────────────────────────────────── -->
      <Border Background="#1A1E2C"
              CornerRadius="12,12,0,0"
              Padding="12,10">

        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Command palette icon -->
          <mi:MaterialIcon Grid.Column="0"
                           Kind="Console"
                           Width="18" Height="18"
                           Foreground="#60A5FA"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>

          <!-- Text input -->
          <TextBox Grid.Column="1"
                   Text="{Binding Query, Mode=TwoWay}"
                   Watermark="{Binding [commandPalette.watermark], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="13"
                   Background="Transparent"
                   BorderThickness="0"
                   CaretBrush="#60A5FA"
                   Foreground="#E8EAED"
                   Name="SearchInput"
                   AutomationProperties.Name="{Binding [commandPalette.search], Source={x:Static loc:LocalizationService.Instance}}">
            <TextBox.Styles>
              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                <Setter Property="BorderBrush" Value="Transparent"/>
              </Style>
            </TextBox.Styles>
          </TextBox>

          <!-- Shortcut badge -->
          <Border Grid.Column="2"
                  Background="#252C3F"
                  CornerRadius="4"
                  Padding="5,2"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding [commandPalette.shortcut], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="10"
                       Foreground="#4A5568"/>
          </Border>
        </Grid>
      </Border>

      <!-- Divider -->
      <Border Height="1" Background="#1E2335"/>

      <!-- ── Results list ──────────────────────────────────────────────── -->
      <ScrollViewer MaxHeight="360" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Results}" Margin="0,4,0,4" Name="ResultsList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PaletteCommandItem">

              <Border Classes="cmd-item">
                <Grid ColumnDefinitions="32,*,Auto">

                  <!-- Icon badge -->
                  <mi:MaterialIcon Grid.Column="0"
                                   Kind="{Binding Icon}"
                                   Width="16" Height="16"
                                   Foreground="#60A5FA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                  <!-- Name + description -->
                  <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#E8EAED"/>
                    <TextBlock Text="{Binding Description}"
                               FontSize="10"
                               Foreground="#4A5568"/>
                  </StackPanel>

                  <!-- Shortcut badge -->
                  <Border Grid.Column="2"
                          Background="#1E2335"
                          CornerRadius="4"
                          Padding="6,2"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"
                          IsVisible="{Binding Shortcut, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding Shortcut}"
                               FontSize="10"
                               Foreground="#4A5568"
                               FontFamily="{StaticResource MonoFont}"/>
                  </Border>
                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Empty state -->
      <Border Padding="16,20"
              IsVisible="{Binding Results.Count, Converter={x:Static BoolConverters.Not}}">
        <TextBlock Text="{Binding [commandPalette.empty], Source={x:Static loc:LocalizationService.Instance}}"
                   FontSize="13"
                   Foreground="#4A5568"
                   HorizontalAlignment="Center"/>
      </Border>

      <!-- ── Footer keyboard hints ────────────────────────────────────── -->
      <Border Background="#0E1018"
              CornerRadius="0,0,12,12"
              Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↑↓" FontSize="10" Foreground="#4A5568"/>
            </Border>
              <TextBlock Text="{Binding [common.navigate], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="↵" FontSize="10" Foreground="#4A5568"/>
            </Border>
              <TextBlock Text="{Binding [commandPalette.execute], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Background="#1E2335" CornerRadius="3" Padding="4,1">
              <TextBlock Text="{Binding [common.esc], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568"/>
            </Border>
              <TextBlock Text="{Binding [common.close], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
