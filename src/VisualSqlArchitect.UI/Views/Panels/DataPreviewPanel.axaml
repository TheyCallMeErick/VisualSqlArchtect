<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
             xmlns:canvas="using:VisualSqlArchitect.UI.ViewModels.Canvas"
             xmlns:ctrl="using:VisualSqlArchitect.UI.Controls"
             xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
             x:Class="VisualSqlArchitect.UI.Controls.DataPreviewPanel"
             x:DataType="canvas:DataPreviewViewModel"
             x:Name="Root">

  <UserControl.Resources>
    <x:String x:Key="LoadingColorConverter">#60A5FA</x:String>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- DataGrid custom dark theme -->
    <Style Selector="DataGrid">
      <Setter Property="Background"          Value="#0D0F14"/>
      <Setter Property="GridLinesVisibility" Value="All"/>
      <Setter Property="BorderThickness"     Value="0"/>
      <Setter Property="RowBackground"       Value="Transparent"/>
      <!-- <Setter Property="AlternatingRowBackground" Value="#08FFFFFF"/> -->
      <Setter Property="Foreground"          Value="#C8D0DC"/>
      <Setter Property="FontSize"            Value="12"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#1A2335"/>
      <Setter Property="VerticalGridLinesBrush"   Value="#1A2335"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background"   Value="#11141E"/>
      <Setter Property="Foreground"   Value="#60A5FA"/>
      <Setter Property="FontSize"     Value="11"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Padding"      Value="10,7"/>
      <Setter Property="BorderBrush"  Value="#1E2335"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="#101A2B"/>
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Padding" Value="10,5"/>
    </Style>
  </UserControl.Styles>

  <!-- ══ Panel shell ════════════════════════════════════════════════════════ -->
  <Border Background="#0F1219"
          BorderBrush="#1E2335"
          BorderThickness="0,1,0,0"
          BoxShadow="0 -4 24 0 #40000000">

    <Grid RowDefinitions="Auto,Auto,*">

      <!-- ── Top drag handle + header ──────────────────────────────────────── -->
      <Grid Grid.Row="0"
            ColumnDefinitions="Auto,*,Auto,Auto,Auto"
            Background="#0D0F14"
            Height="40">

        <!-- Drag handle strip -->
        <Border Grid.Column="0"
                Width="3"
                Background="#252C3F"
                Margin="12,8,0,8"
                CornerRadius="2"
                Cursor="Hand"
                Name="DragHandle"/>

        <!-- Title + status -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="6">
            <!-- Colored indicator dot -->
            <Ellipse Width="7" Height="7" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="#60A5FA"/>
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="{Binding [preview.title], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#E8EAED"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Row count / status chip (color-coded by state) -->
          <Border Background="#1A2335"
                  CornerRadius="6"
                  Padding="7,2"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Foreground="{Binding StatusColor}"/>
          </Border>
        </StackPanel>

        <!-- Shortcut hint -->
        <Border Grid.Column="2"
                Background="#131720"
                CornerRadius="4"
                Padding="5,2"
                Margin="0,0,8,0"
                VerticalAlignment="Center">
          <TextBlock Text="F3" FontSize="10" Foreground="#4A5568"/>
        </Border>

        <!-- Run button (hidden while running) -->
        <Button Grid.Column="3"
                Content="↺  Run"
                FontSize="11"
                Foreground="#60A5FA"
                Background="#0F1A30"
                BorderBrush="#1E3A60"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,4"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Name="RunButton"
                IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#162540"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Cancel button (visible only while running) -->
        <Button Grid.Column="3"
                FontSize="11"
                Foreground="#FBBF24"
                Background="#1A1200"
                BorderBrush="#92400E"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,4"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Name="CancelButton"
                IsVisible="{Binding IsLoading}"
                ToolTip.Tip="{Binding [tooltip.cancelRunningQuery], Source={x:Static loc:LocalizationService.Instance}}"
                AutomationProperties.Name="Cancel query">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="⏹" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [preview.cancel], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11" VerticalAlignment="Center"/>
          </StackPanel>
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#2A1E00"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Close button -->
        <Button Grid.Column="4"
                Content="✕"
                FontSize="11"
                Foreground="#4A5568"
                Background="Transparent"
                BorderThickness="0"
                Padding="8,4"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Name="CloseButton">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Foreground" Value="#E8EAED"/>
            </Style>
          </Button.Styles>
        </Button>
      </Grid>

      <!-- ── Tab bar ───────────────────────────────────────────────────────── -->
      <Border Grid.Row="1"
              Background="#0B0E15"
              BorderBrush="#1E2335"
              BorderThickness="0,1,0,1"
              Padding="8,0">

        <Border.Styles>
          <Style Selector="Button.tab">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Foreground"      Value="#4A5568"/>
            <Setter Property="Cursor"          Value="Hand"/>
          </Style>
          <Style Selector="Button.tab:pointerover">
            <Setter Property="Foreground" Value="#C8D0DC"/>
          </Style>
          <Style Selector="Button.tab.active">
            <Setter Property="Foreground" Value="#60A5FA"/>
          </Style>
        </Border.Styles>

        <StackPanel Orientation="Horizontal" Spacing="0">

          <!-- Preview tab -->
          <Panel>
            <Button Classes="tab"
                    Name="TabPreviewButton"
                    Classes.active="{Binding ShowDataPreview}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="⊞" FontSize="10" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding [preview.tab.preview], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <!-- active underline -->
            <Border Height="2"
                    Background="#60A5FA"
                    VerticalAlignment="Bottom"
                    Margin="4,0"
                    IsVisible="{Binding ShowDataPreview}"
                    CornerRadius="1,1,0,0"/>
          </Panel>

          <!-- SQL tab -->
          <Panel>
            <Button Classes="tab"
                    Name="TabSqlButton"
                    Classes.active="{Binding ShowLiveSql}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="&lt;/&gt;" FontSize="10" VerticalAlignment="Center" Foreground="#4338CA"/>
                <TextBlock Text="SQL" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <!-- active underline -->
            <Border Height="2"
                    Background="#4338CA"
                    VerticalAlignment="Bottom"
                    Margin="4,0"
                    IsVisible="{Binding ShowLiveSql}"
                    CornerRadius="1,1,0,0"/>
          </Panel>

        </StackPanel>
      </Border>

      <!-- ── Content area ───────────────────────────────────────────────────── -->
            <Border Grid.Row="2"
              IsVisible="{Binding ShowDataPreview}"
              CornerRadius="0,0,10,10"
              ClipToBounds="True">
            <Grid>

        <!-- Running state -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
          <ProgressBar IsIndeterminate="True"
                       Width="200"
                       Height="3"
                       Background="#1A2335"
                       Foreground="#3B82F6"
                       CornerRadius="2"/>
          <TextBlock FontSize="12" Foreground="#4A5568" HorizontalAlignment="Center">
            <Run Text="{Binding [preview.running], Source={x:Static loc:LocalizationService.Instance}}"/>
            <Run Text="{Binding ElapsedMs}" Foreground="#60A5FA"/>
            <Run Text="ms"/>
          </TextBlock>
          <TextBlock Text="{Binding [preview.clickCancel], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="10" Foreground="#3B4560" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Cancelled state -->
        <StackPanel IsVisible="{Binding IsCancelled}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
          <TextBlock Text="⏹" FontSize="28" HorizontalAlignment="Center" Foreground="#FBBF24"/>
          <TextBlock Text="{Binding [preview.cancelled], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="13" FontWeight="SemiBold" Foreground="#FBBF24"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding [preview.runAgain], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="11" Foreground="#4A5568" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error state — structured diagnostic card -->
        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#130D0D"
                BorderBrush="#5C1A1A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20,16"
                MaxWidth="520">
          <StackPanel Spacing="12">

            <!-- Header: icon badge + category label -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border CornerRadius="6"
                      Background="#5C1A1A"
                      Padding="7,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding DiagnosticIcon}"
                           FontSize="14"
                           VerticalAlignment="Center"/>
              </Border>
              <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding DiagnosticLabel}"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#FB7185"/>
                <TextBlock Text="{Binding [preview.failed], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="10"
                           Foreground="#5C1A1A"/>
              </StackPanel>
            </StackPanel>

            <!-- Friendly message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="12"
                       Foreground="#F87171"
                       TextWrapping="Wrap"/>

            <!-- Suggestion box -->
            <Border CornerRadius="6"
                    Background="#0F1A0F"
                    BorderBrush="#1A4A1A"
                    BorderThickness="1"
                    Padding="10,8"
                    IsVisible="{Binding HasDiagnostic}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="💡"
                           FontSize="11"
                           VerticalAlignment="Top"
                           Margin="0,1,0,0"/>
                <TextBlock Text="{Binding DiagnosticSuggestion}"
                           FontSize="11"
                           Foreground="#4ADE80"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Technical details (collapsible) -->
            <Border CornerRadius="6"
                    Background="#0A0C11"
                    BorderBrush="#252C3F"
                    BorderThickness="1"
                    Padding="10,8"
                    IsVisible="{Binding HasTechnicalDetail}">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding [preview.technical], Source={x:Static loc:LocalizationService.Instance}}"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="#4A5568"
                           LetterSpacing="1"/>
                <SelectableTextBlock Text="{Binding DiagnosticTechnical}"
                                     FontFamily="Consolas,monospace"
                                     FontSize="10"
                                     Foreground="#6B7280"
                                     TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>

        <!-- Empty / no-query state -->
        <StackPanel IsVisible="{Binding HasData, Converter={x:Static BoolConverters.Not}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
          <!-- Only show when NOT loading and NOT error -->
          <TextBlock Text="{Binding [preview.noData], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="13"
                     Foreground="#4A5568"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
          <TextBlock Text="{Binding [preview.f3Hint], Source={x:Static loc:LocalizationService.Instance}}"
                     FontSize="11"
                     Foreground="#3B4560"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Name="ResultGrid"
                  IsVisible="{Binding HasData}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  Margin="0"/>
      </Grid>
      </Border>

      <!-- ── Live SQL view ──────────────────────────────────────────────────── -->
      <Border Grid.Row="2"
              IsVisible="{Binding ShowLiveSql}"
              CornerRadius="0,0,10,10"
              ClipToBounds="True">
        <ctrl:LiveSqlBar DataContext="{Binding #Root.LiveSqlViewModel}"/>
      </Border>

    </Grid>
  </Border>
</UserControl>
