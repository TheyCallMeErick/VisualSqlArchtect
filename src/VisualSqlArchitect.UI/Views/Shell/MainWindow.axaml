<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualSqlArchitect.UI.ViewModels"
        xmlns:ctrl="using:VisualSqlArchitect.UI.Controls"
  xmlns:start="using:VisualSqlArchitect.UI.Controls.Start"
        xmlns:shell="using:VisualSqlArchitect.UI.Controls.Shell"
  xmlns:loc="using:VisualSqlArchitect.UI.Services.Localization"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="VisualSqlArchitect.UI.MainWindow"
          x:Name="RootWindow"
  x:DataType="vm:ShellViewModel"
        Title="{Binding [app.windowTitle], Source={x:Static loc:LocalizationService.Instance}}"
        Width="1440" Height="900"
        MinWidth="960" MinHeight="620"
        Background="{StaticResource MacroBg0Brush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <!-- Splitter default / hover -->
    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="{StaticResource MacroBorderSubtleBrush}"/>
    </Style>
    <Style Selector="GridSplitter:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style Selector="Button.tb">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="Padding"         Value="7,5"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.tb:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.03)"/>
    </Style>
    <Style Selector="Button.tb.danger:pointerover">
      <Setter Property="Background" Value="{StaticResource BtnDangerBgBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource BtnDangerFgBrush}"/>
    </Style>
    <Style Selector="Border.undo-redo-host">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="2"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #22000000"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.undo-redo-btn">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.undo-redo-btn:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg3Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.06)"/>
    </Style>
    <Style Selector="Button.undo-redo-btn:pressed">
      <Setter Property="RenderTransform" Value="scale(0.96)"/>
    </Style>
    <Style Selector="Border.tabs-scroll-host">
      <Setter Property="Background" Value="{StaticResource MacroBg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="3,2"/>
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer.topbar-tabs-scroll">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <Style Selector="Border.mode-switch-host">
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="BoxShadow" Value="{StaticResource PanelShadow}"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.mode-switch-btn">
      <Setter Property="MinWidth" Value="84"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.14"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.mode-switch-btn:pointerover">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Background" Value="{StaticResource MacroBg3Brush}"/>
      <Setter Property="RenderTransform" Value="scale(1.04)"/>
    </Style>
    <Style Selector="Button.mode-switch-btn.active">
      <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>
    <Style Selector="Button.mode-switch-btn:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.sidebar-toggle-fab">
      <Setter Property="Width" Value="24"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="{StaticResource MacroBg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource MacroBorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sidebar-toggle-fab:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg3Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="scale(1.05)"/>
    </Style>
    <Style Selector="Button.sidebar-toggle-fab:pressed">
      <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.settings-nav">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.settings-nav:pointerover">
      <Setter Property="Background" Value="{StaticResource MacroBg3Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.settings-nav.active">
      <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </Window.Styles>

    <!-- ══════════════════════════════════════════════════════════════════
      ROOT: TitleBar | RestoreBanner | CteBanner | Body | StatusBar
    ═══════════════════════════════════════════════════════════════════ -->
            <Grid>
            <Grid IsVisible="{Binding IsCanvasVisible}">
            <Grid RowDefinitions="36,Auto,Auto,*,28"
              DataContext="{Binding ActiveCanvas}">

    <!-- ╔══ TITLE BAR ══════════════════════════════════════════════════╗ -->
    <shell:AppHeaderBar Grid.Row="0"
              x:Name="CanvasHeader"
                        Title="{Binding [main.brand], Source={x:Static loc:LocalizationService.Instance}}"
                        ShowBrandBadge="True"
                        ShowWindowControls="True">
      <shell:AppHeaderBar.CenterContent>
        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              MaxWidth="1040">
          <Border Grid.Column="0"
                  Classes="undo-redo-host"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
            <Grid ColumnDefinitions="Auto,1,Auto">
              <Button Grid.Column="0"
                      Classes="undo-redo-btn"
                      Command="{Binding UndoCommand}"
                      ToolTip.Tip="{Binding UndoRedo.UndoDescription}"
                      AutomationProperties.Name="{Binding [main.undo], Source={x:Static loc:LocalizationService.Instance}}">
                <mi:MaterialIcon Kind="Undo" Width="14" Height="14"/>
              </Button>
              <Border Grid.Column="1"
                      Width="1"
                      Height="14"
                      VerticalAlignment="Center"
                      Background="{StaticResource MacroBorderSubtleBrush}"/>
              <Button Grid.Column="2"
                      Classes="undo-redo-btn"
                      Command="{Binding RedoCommand}"
                      ToolTip.Tip="{Binding UndoRedo.RedoDescription}"
                      AutomationProperties.Name="{Binding [main.redo], Source={x:Static loc:LocalizationService.Instance}}">
                <mi:MaterialIcon Kind="Redo" Width="14" Height="14"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Column="1"
                  Classes="mode-switch-host"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Classes="mode-switch-btn"
                      Name="QueryModeBtn"
                      Content="{Binding [mode.query], Source={x:Static loc:LocalizationService.Instance}}"
                      Click="QueryModeBtn_Click"
                      ToolTip.Tip="{Binding [tooltip.switchToQueryMode], Source={x:Static loc:LocalizationService.Instance}}"/>
              <Button Classes="mode-switch-btn"
                      Name="DdlModeBtn"
                      Content="{Binding [mode.ddl], Source={x:Static loc:LocalizationService.Instance}}"
                      Click="DdlModeBtn_Click"
                      ToolTip.Tip="{Binding [tooltip.switchToDdlMode], Source={x:Static loc:LocalizationService.Instance}}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Classes="tabs-scroll-host"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
            <ScrollViewer Classes="topbar-tabs-scroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0">
              <StackPanel Name="QueryTabsHost"
                          Orientation="Horizontal"
                          Spacing="2"
                          VerticalAlignment="Center"/>
            </ScrollViewer>
          </Border>

          <Button Grid.Column="3"
                  Classes="tb"
                  Width="26"
                  Height="26"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Name="NewTabBtn"
                  ToolTip.Tip="{Binding [tooltip.newCanvas], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
          </Button>
        </Grid>
      </shell:AppHeaderBar.CenterContent>

      <shell:AppHeaderBar.RightContent>
        <StackPanel Orientation="Horizontal" Spacing="3"
                    Margin="0,0,4,0" VerticalAlignment="Center">

	          <!-- Orphan cleanup (visible only when orphans are detected) -->
          <Button Classes="tb" FontSize="11"
                  Command="{Binding CleanupOrphansCommand}"
                  IsVisible="{Binding HasOrphanNodes}"
                  ToolTip.Tip="{Binding [tooltip.cleanupOrphans], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [main.cleanupOrphans], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="VectorUnion" Width="14" Height="14"/>
              <TextBlock Text="{Binding OrphanCount}" FontSize="11"/>
              <TextBlock Text="{Binding [main.orphanSuffix], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>

            <Border Width="1" Height="14" Background="{StaticResource MacroBorderSubtleBrush}" Margin="2,0"
                  IsVisible="{Binding HasOrphanNodes}"/>

          <!-- Auto-fix naming conventions (visible only when violations exist) -->
          <Button Classes="tb" FontSize="11"
                  Command="{Binding AutoFixNamingCommand}"
                  IsVisible="{Binding HasNamingViolations}"
                  ToolTip.Tip="{Binding [tooltip.autoFixAliasNaming], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [main.autoFixAliasNaming], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="AutoFix" Width="14" Height="14"/>
              <TextBlock Text="{Binding [main.namingPrefix], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
              <TextBlock Text="{Binding NamingConformance}" FontSize="11"/>
              <TextBlock Text="%" FontSize="11"/>
            </StackPanel>
          </Button>

            <Border Width="1" Height="14" Background="{StaticResource MacroBorderSubtleBrush}" Margin="2,0"
                  IsVisible="{Binding HasNamingViolations}"/>

          <!-- Auto Layout -->
          <Button Classes="tb" FontSize="11"
                  Command="{Binding AutoLayoutCommand}"
              ToolTip.Tip="{Binding [tooltip.autoLayout], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [main.autoLayoutCanvas], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="FormatHorizontalAlignCenter" Width="14" Height="14"/>
              <TextBlock Text="{Binding [main.layout], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>

          <Border Width="1"
                  Height="14"
                  Background="{StaticResource MacroBorderSubtleBrush}"
                  Margin="2,0"
                  IsVisible="{Binding HasTwoSelectedTableSources}"/>

          <Button Classes="tb"
                  FontSize="11"
                  Command="{Binding RunSelectedAutoJoinCommand}"
                  IsVisible="{Binding HasTwoSelectedTableSources}"
                  ToolTip.Tip="{Binding [tooltip.autoJoinSelected], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [autoJoin.runSelected], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="SourceBranch" Width="14" Height="14"/>
              <TextBlock Text="{Binding [autoJoin.runSelected], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
            </StackPanel>
          </Button>

          <Border Width="1" Height="14" Background="{StaticResource MacroBorderSubtleBrush}" Margin="2,0"/>

          <!-- Preview toggle -->
          <Button Classes="tb" Name="TogglePreviewBtn"
              ToolTip.Tip="{Binding [tooltip.dataPreview], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [main.toggleDataPreview], Source={x:Static loc:LocalizationService.Instance}}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <mi:MaterialIcon Kind="TableEye" Width="14" Height="14"/>
              <TextBlock Text="{Binding [main.preview], Source={x:Static loc:LocalizationService.Instance}}" FontSize="11"/>
              <Border IsVisible="{Binding Diagnostics.HasAttention}"
                      Background="{StaticResource PanelMutedBrush}"
                      BorderBrush="{StaticResource BtnWarningBgBrush}"
                      BorderThickness="1"
                      CornerRadius="999"
                      Padding="4,0">
                <StackPanel Orientation="Horizontal" Spacing="3">
                  <mi:MaterialIcon Kind="Alert"
                                   Width="10"
                                   Height="10"
                                   Foreground="{StaticResource StatusWarningBrush}"
                                   VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Diagnostics.AttentionCountLabel}"
                             FontSize="10"
                             Foreground="{StaticResource StatusWarningBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Button>

          <!-- Secondary actions moved to title menu -->

        </StackPanel>
      </shell:AppHeaderBar.RightContent>
    </shell:AppHeaderBar>

    <!-- ╔══ RESTORE BANNER ══════════════════════════════════════════════╗ -->
    <Border Grid.Row="1" Name="RestoreBanner" IsVisible="False"
          Background="{StaticResource MacroBg2Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="0,0,0,1"
            Padding="12,7">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
      <mi:MaterialIcon Grid.Column="0" Kind="History" Width="16" Height="16" Foreground="{StaticResource AccentBlueBrush}"
                        VerticalAlignment="Center" Margin="0,0,8,0"/>
      <TextBlock Grid.Column="1" FontSize="{StaticResource FontSizeMeta}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center">
              <Run Text="{Binding [main.restore.prompt], Source={x:Static loc:LocalizationService.Instance}}"/>
        </TextBlock>
        <Button Grid.Column="2" Name="RestoreSessionBtn"
                Content="{Binding [main.restore.button], Source={x:Static loc:LocalizationService.Instance}}"
        Classes="info"
        FontSize="{StaticResource FontSizeMeta}" CornerRadius="{StaticResource StartRadiusButton}"
                Padding="10,4" Margin="8,0,4,0" Cursor="Hand"/>
        <Button Grid.Column="3" Name="DismissRestoreBtn"
                Background="Transparent" BorderThickness="0"
        Foreground="{StaticResource TextMutedBrush}" Padding="6,4" Cursor="Hand">
          <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
        </Button>
      </Grid>
    </Border>

    <!-- ╔══ CTE EDITOR BANNER ══════════════════════════════════════════╗ -->
    <Border Grid.Row="2"
            IsVisible="{Binding IsInCteEditor}"
        Background="{StaticResource BtnWarningBgBrush}"
        BorderBrush="{StaticResource MacroBorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,7">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <mi:MaterialIcon Grid.Column="0" Kind="FileTree" Width="16" Height="16"
             Foreground="{StaticResource BtnWarningFgBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Text="{Binding CteEditorBreadcrumb}"
           FontSize="{StaticResource FontSizeMeta}" Foreground="{StaticResource BtnWarningFgBrush}" VerticalAlignment="Center"/>
        <Button Grid.Column="2"
                Command="{Binding ExitCteEditorCommand}"
            Classes="warning"
            FontSize="{StaticResource FontSizeMeta}"
            CornerRadius="{StaticResource StartRadiusButton}"
                Padding="10,4"
                Cursor="Hand"
                AutomationProperties.Name="{Binding EditorExitA11y}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="ExitToApp" Width="14" Height="14"/>
            <TextBlock Text="{Binding EditorExitLabel}" FontSize="11"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- ╔══ BODY ════════════════════════════════════════════════════════╗ -->
    <Grid Grid.Row="3" Name="BodyGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="280" MinWidth="220" MaxWidth="500"/>
      </Grid.ColumnDefinitions>

      <!-- ╠═ CENTRE: Canvas + Preview ════════════════════════════════════════╣ -->
      <Grid Grid.Column="0" Grid.ColumnSpan="5" Name="CenterGrid" Panel.ZIndex="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Canvas + overlays -->
        <Panel Grid.Row="0" ClipToBounds="True">
          <ctrl:InfiniteCanvas Name="TheCanvas" ViewModel="{Binding}" ClipToBounds="True"/>

          <!-- Search overlay (Shift+A) -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,70,0,0"
                 IsVisible="{Binding SearchMenu.IsVisible}">
            <ctrl:SearchMenuControl DataContext="{Binding SearchMenu}" Name="SearchOverlay"/>
          </Panel>

          <!-- Command Palette overlay (Ctrl+K) -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0"
                 IsVisible="{ReflectionBinding DataContext.CommandPalette.IsVisible, ElementName=RootWindow}">
            <ctrl:CommandPaletteControl DataContext="{ReflectionBinding DataContext.CommandPalette, ElementName=RootWindow}" Name="CommandPaletteOverlay"/>
          </Panel>

          <!-- Benchmark overlay -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="20"
                 IsVisible="{Binding Benchmark.IsVisible}">
            <ctrl:BenchmarkOverlay DataContext="{Binding Benchmark}"
                                   Name="BenchmarkOverlayCtrl"/>
          </Panel>

          <!-- Explain Plan overlay (F4 / Explain button) -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="20"
                 IsVisible="{Binding ExplainPlan.IsVisible}">
            <ctrl:ExplainPlanOverlay DataContext="{Binding ExplainPlan}"
                                     Name="ExplainPlanOverlayCtrl"/>
          </Panel>

          <!-- SQL Importer overlay -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="20"
                 IsVisible="{Binding SqlImporter.IsVisible}">
            <ctrl:SqlImporterOverlay DataContext="{Binding SqlImporter}"
                                     Name="SqlImporterOverlayCtrl"/>
          </Panel>

          <!-- Flow Version History overlay (Ctrl+Shift+H) -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="20"
                 IsVisible="{Binding FlowVersions.IsVisible}">
            <ctrl:FlowVersionOverlay DataContext="{Binding FlowVersions}"
                                     Name="FlowVersionsOverlayCtrl"/>
          </Panel>

          <!-- File Save/Load Version History overlay (Ctrl+Alt+H) -->
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="20"
              IsVisible="{Binding FileHistory.IsVisible}">
            <ctrl:FileVersionHistoryOverlay DataContext="{Binding FileHistory}"
                          Name="FileHistoryOverlayCtrl"/>
          </Panel>

          <!-- Loading overlay (while connecting) -->
          <Panel HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            Background="{StaticResource MacroScrimBrush}" Opacity="0.4" ZIndex="30"
                 IsVisible="{Binding IsCanvasDisabled}"
                 IsHitTestVisible="True"/>

             <!-- View subcanvas dimmed state indicator -->
             <Panel HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
               Background="{StaticResource MacroScrimBrush}" Opacity="0.25" ZIndex="29"
               IsVisible="{Binding IsCanvasDimmedBySubcanvas}"
               IsHitTestVisible="False"/>

          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" ZIndex="31"
                      IsVisible="{Binding IsCanvasDisabled}">
            <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource MacroBorderSubtleBrush}"
                         Width="200" Height="6" CornerRadius="3"/>
            <TextBlock Text="{Binding [main.connectingDb], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}" Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>

          <!-- Empty canvas hint -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                      IsVisible="{Binding IsCanvasEmpty}">
            <TextBlock Text="{Binding [main.brand], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="30" FontWeight="Light" Foreground="{StaticResource MacroBorderSubtleBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding [main.emptyHint], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Mini zoom toolbar (bottom-right) -->
          <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,16,16" Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1"
                  CornerRadius="9" Padding="5,3" ZIndex="5">
            <StackPanel Orientation="Horizontal" Spacing="2">
              <Button Classes="tb" Content="−" Command="{Binding ZoomOutCommand}"
                      Width="26" Height="26" Padding="0" HorizontalContentAlignment="Center"
                      ToolTip.Tip="{Binding [tooltip.zoomOut], Source={x:Static loc:LocalizationService.Instance}}"
                      AutomationProperties.Name="{Binding [zoom.out], Source={x:Static loc:LocalizationService.Instance}}"/>
              <Border Width="38" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ZoomPercent}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding [zoom.level], Source={x:Static loc:LocalizationService.Instance}}"/>
              </Border>
              <Button Classes="tb" Content="+" Command="{Binding ZoomInCommand}"
                      Width="26" Height="26" Padding="0" HorizontalContentAlignment="Center"
                      ToolTip.Tip="{Binding [tooltip.zoomIn], Source={x:Static loc:LocalizationService.Instance}}"
                      AutomationProperties.Name="{Binding [zoom.in], Source={x:Static loc:LocalizationService.Instance}}"/>
              <Border Width="1" Height="14" Background="{StaticResource MacroBorderSubtleBrush}" Margin="2,0"/>
              <Button Classes="tb" Content="⊡" Command="{Binding FitToScreenCommand}"
                      Width="26" Height="26" Padding="0" HorizontalContentAlignment="Center"
                      ToolTip.Tip="{Binding [tooltip.fitToScreen], Source={x:Static loc:LocalizationService.Instance}}"
                      AutomationProperties.Name="{Binding [zoom.fit], Source={x:Static loc:LocalizationService.Instance}}"/>
            </StackPanel>
          </Border>

        </Panel>
      </Grid>

      <!-- ╠═ LEFT: Floating Sidebar ═══════════════════════════════════════════╣ -->
      <Border x:Name="LeftSidebarHost"
              Grid.Column="0"
              Margin="8,8,0,8"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="12"
              BoxShadow="{StaticResource PanelShadow}"
              ClipToBounds="True">
        <Grid>
          <ctrl:SidebarControl DataContext="{Binding Sidebar}"/>
        </Grid>
      </Border>

      <Button x:Name="LeftSidebarHideBtn"
              Grid.Column="0"
              Classes="sidebar-toggle-fab"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              ZIndex="10"
              Margin="0,8,-12,8"
              Click="LeftSidebarHideBtn_Click"
              ToolTip.Tip="{Binding [sidebar.left.close], Source={x:Static loc:LocalizationService.Instance}}"
              Content="">
        <mi:MaterialIcon Kind="ChevronLeft" Width="12" Height="12"/>
      </Button>

      <!-- Vertical splitters (floating over canvas background) -->
      <GridSplitter Grid.Column="1" Width="3" VerticalAlignment="Stretch"
                    Margin="0"
                    ResizeDirection="Columns" Cursor="SizeWestEast" Name="LeftSplitter"
                    />
      <GridSplitter Grid.Column="3" Width="3" VerticalAlignment="Stretch"
                    Margin="0"
                    ResizeDirection="Columns" Cursor="SizeWestEast" Name="RightSplitter"
                    />

      <!-- ╠═ RIGHT: Floating Property Panel ══════════════════════════════════╣ -->
            <Border x:Name="RightSidebarHost"
              Grid.Column="4"
              Margin="0,8,8,8"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="12"
              BoxShadow="{StaticResource PanelShadow}"
              ClipToBounds="True">
        <Grid>
          <ctrl:PropertyPanelControl DataContext="{Binding PropertyPanel}"
                   Name="PropPanel"/>
        </Grid>
      </Border>

      <Button x:Name="RightSidebarHideBtn"
              Grid.Column="4"
              Classes="sidebar-toggle-fab"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              ZIndex="10"
              Margin="-12,8,0,8"
              Click="RightSidebarHideBtn_Click"
              ToolTip.Tip="{Binding [sidebar.right.close], Source={x:Static loc:LocalizationService.Instance}}"
              Content="">
        <mi:MaterialIcon Kind="ChevronRight" Width="12" Height="12"/>
      </Button>

      <!-- Reopen rails (real drawer borders when collapsed) -->
      <Border x:Name="LeftSidebarRail"
              Grid.Column="0"
              Margin="8,8,0,8"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="12"
              IsVisible="False"
              ClipToBounds="True">
        <Grid/>
      </Border>

      <Button x:Name="LeftSidebarShowBtn"
              Grid.Column="0"
              Classes="sidebar-toggle-fab"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              ZIndex="10"
              Margin="0,8,-12,8"
              IsVisible="False"
              Click="LeftSidebarShowBtn_Click"
              ToolTip.Tip="{Binding [sidebar.left.open], Source={x:Static loc:LocalizationService.Instance}}"
              Content="">
        <mi:MaterialIcon Kind="ChevronRight" Width="12" Height="12"/>
      </Button>

      <Border x:Name="RightSidebarRail"
              Grid.Column="4"
              Margin="0,8,8,8"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="12"
              IsVisible="False"
              ClipToBounds="True">
        <Grid/>
      </Border>

      <Button x:Name="RightSidebarShowBtn"
              Grid.Column="4"
              Classes="sidebar-toggle-fab"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              ZIndex="10"
              Margin="-12,8,0,8"
              IsVisible="False"
              Click="RightSidebarShowBtn_Click"
              ToolTip.Tip="{Binding [sidebar.right.open], Source={x:Static loc:LocalizationService.Instance}}"
              Content="">
        <mi:MaterialIcon Kind="ChevronLeft" Width="12" Height="12"/>
      </Button>

    </Grid>

    <!-- ╔══ STATUS BAR ════════════════════════════════════════════════════╗ -->
    <Border Grid.Row="4" Background="{StaticResource MacroBg1Brush}"
          BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="12,0">

      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="4">
            <Ellipse Width="5" Height="5"
                     Fill="{Binding ConnectionManager.ConnectionIndicatorColor}"/>
            <TextBlock Text="{Binding ConnectionManager.ActiveConnectionLabel}"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
          </StackPanel>

          <Border Width="1" Height="12" Background="{StaticResource MacroBorderSubtleBrush}"/>

          <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
            <Run Text="{Binding Nodes.Count}"/>
            <Run Text="{Binding [status.nodesSeparator], Source={x:Static loc:LocalizationService.Instance}}"/>
            <Run Text="{Binding Connections.Count}"/>
            <Run Text="{Binding [status.connectionsSuffix], Source={x:Static loc:LocalizationService.Instance}}"/>
          </TextBlock>

          <Border Width="1" Height="12" Background="{StaticResource MacroBorderSubtleBrush}"/>

          <!-- Undo history depth indicator -->
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
              <Run Text="{Binding [status.undo], Source={x:Static loc:LocalizationService.Instance}}"/>
              <Run Text="{Binding UndoRedo.UndoDescription}"/>
            </TextBlock>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
          <Button Classes="tb"
                  Command="{Binding ZoomOutCommand}"
                  Width="22"
                  Height="20"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  ToolTip.Tip="{Binding [tooltip.zoomOut], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [zoom.out], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="MagnifyMinus" Width="12" Height="12"/>
          </Button>
          <Border Background="{StaticResource MacroBg2Brush}"
                  CornerRadius="4"
                  Padding="6,2"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding ZoomPercent}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </Border>
          <Button Classes="tb"
                  Command="{Binding ZoomInCommand}"
                  Width="22"
                  Height="20"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  ToolTip.Tip="{Binding [tooltip.zoomIn], Source={x:Static loc:LocalizationService.Instance}}"
                  AutomationProperties.Name="{Binding [zoom.in], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="MagnifyPlus" Width="12" Height="12"/>
          </Button>
        </StackPanel>

        <TextBlock Grid.Column="2" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   Text="{Binding [status.shortcuts], Source={x:Static loc:LocalizationService.Instance}}"/>
      </Grid>
    </Border>

    <Panel Grid.RowSpan="5" ZIndex="80" x:CompileBindings="False">
      <ctrl:BottomSheetToast ZIndex="81"
                             DataContext="{Binding Toasts}"/>

            <Border IsVisible="{Binding Toasts.IsDetailsOpen}"
              DataContext="{Binding DataContext, ElementName=RootWindow}"
              Background="{StaticResource MacroScrimBrush}"
              ZIndex="82"
              IsHitTestVisible="True"
              PointerPressed="ToastDetailsBackdrop_PointerPressed">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="820"
                MaxHeight="560"
                Background="{StaticResource MacroBg1Brush}"
                BorderBrush="{StaticResource MacroBorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource StartRadiusCard}"
          Padding="14"
          PointerPressed="ToastDetailsDialog_PointerPressed">
          <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
              <TextBlock Grid.Column="0"
                         Text="{Binding Toasts.DetailsTitle}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{Binding Toasts.AccentColor}"/>
              <Button Grid.Column="1"
                      Command="{Binding Toasts.CloseDetailsCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Padding="2"
                      Cursor="Hand">
                <TextBlock Text="✕" FontSize="12"/>
              </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
              <TextBlock Text="{Binding Toasts.Details}"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="12"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
              <Button Command="{Binding Toasts.CloseDetailsCommand}"
                      Classes="secondary"
                      CornerRadius="{StaticResource StartRadiusButton}"
                      Padding="12,6"
                      Cursor="Hand"
                      Content="{Binding [common.close], Source={x:Static loc:LocalizationService.Instance}}"/>
            </StackPanel>
          </Grid>
        </Border>
      </Border>

      <ctrl:ManualJoinDialog DataContext="{Binding ManualJoinDialog}"
                             ZIndex="83"/>

      <Border IsVisible="{Binding ConnectionManager.IsClearCanvasPromptVisible}"
              Background="{StaticResource MacroScrimBrush}"
              IsHitTestVisible="True"
              PointerPressed="ClearCanvasPromptBackdrop_PointerPressed">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="500"
            Background="{StaticResource MacroBg1Brush}"
            BorderBrush="{StaticResource MacroBorderSubtleBrush}"
                BorderThickness="1"
            CornerRadius="{StaticResource StartRadiusCard}"
          Padding="16"
          PointerPressed="ClearCanvasPromptDialog_PointerPressed">
          <Grid RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0"
                       Text="{Binding [connection.completedTitle], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Text="{Binding [connection.clearCanvasPrompt], Source={x:Static loc:LocalizationService.Instance}}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
              <Button Command="{Binding ConnectionManager.KeepCanvasAfterConnectCommand}"
                      Classes="secondary"
                      CornerRadius="{StaticResource StartRadiusButton}"
                      Padding="12,6"
                      Cursor="Hand"
                      Content="{Binding [common.keep], Source={x:Static loc:LocalizationService.Instance}}"/>

              <Button Command="{Binding ConnectionManager.ClearCanvasAfterConnectCommand}"
                      Classes="info"
                      CornerRadius="{StaticResource StartRadiusButton}"
                      Padding="12,6"
                      Cursor="Hand"
                      Content="{Binding [common.clear], Source={x:Static loc:LocalizationService.Instance}}"/>
            </StackPanel>
          </Grid>
        </Border>
      </Border>
    </Panel>
  </Grid>
    </Grid>

    <Grid IsVisible="{Binding IsStartVisible}">
      <start:StartMenuControl DataContext="{Binding StartMenu}"
                              Name="StartMenu"/>
    </Grid>

    <Panel HorizontalAlignment="Center"
           VerticalAlignment="Center"
           ZIndex="50"
          IsVisible="{Binding IsConnectionManagerVisible}">
      <ctrl:ConnectionManagerControl DataContext="{Binding Canvas.ConnectionManager}"
                                     Name="ConnectionManagerOverlay"/>
    </Panel>

    <shell:OutputPreviewModalControl DataContext="{Binding OutputPreview}"/>

    <Border IsVisible="{Binding IsSettingsVisible}"
            Background="{StaticResource MacroScrimBrush}"
            ZIndex="60"
            IsHitTestVisible="True"
            PointerPressed="SettingsBackdrop_PointerPressed">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="1080"
              MaxWidth="1180"
              MinWidth="900"
              MinHeight="620"
              Background="{StaticResource MacroBg1Brush}"
              BorderBrush="{StaticResource MacroBorderSubtleBrush}"
              BorderThickness="1"
              CornerRadius="16"
              Padding="0"
              BoxShadow="{StaticResource PanelShadow}"
              ClipToBounds="True"
              PointerPressed="SettingsDialog_PointerPressed">
        <Grid ColumnDefinitions="280,*">
          <Border Grid.Column="0"
                  Background="{StaticResource MacroBg2Brush}"
                  BorderBrush="{StaticResource MacroBorderSubtleBrush}"
                  BorderThickness="0,0,1,0"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding [settings.section.default.title], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="34"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>

              <Border Background="{StaticResource MacroBg3Brush}"
                      BorderBrush="{StaticResource MacroBorderSubtleBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="10,8">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                  <mi:MaterialIcon Grid.Column="0" Kind="CogOutline" Width="14" Height="14" Foreground="{StaticResource AccentBlueBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding [settings.general], Source={x:Static loc:LocalizationService.Instance}}" Margin="8,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                  <mi:MaterialIcon Grid.Column="2" Kind="ChevronDown" Width="14" Height="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
              </Border>

              <StackPanel Spacing="10" Margin="8,0,0,0">
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsLanguageRegionSectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="LanguageRegion"
                  Content="{Binding [settings.section.languageRegion.title], Source={x:Static loc:LocalizationService.Instance}}"/>
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsAppearanceSectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="Appearance"
                  Content="{Binding [settings.nav.appearance], Source={x:Static loc:LocalizationService.Instance}}"/>
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsDateTimeSectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="DateTime"
                  Content="{Binding [settings.section.dateTime.title], Source={x:Static loc:LocalizationService.Instance}}"/>
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsKeyboardShortcutsSectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="KeyboardShortcuts"
                  Content="{Binding [settings.section.keyboard.title], Source={x:Static loc:LocalizationService.Instance}}"/>
              </StackPanel>

              <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" Margin="0,4"/>

              <StackPanel Spacing="10">
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsPrivacySectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="Privacy"
                  Content="{Binding [settings.section.privacy.title], Source={x:Static loc:LocalizationService.Instance}}"/>
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsNotificationSectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="Notification"
                  Content="{Binding [settings.section.notification.title], Source={x:Static loc:LocalizationService.Instance}}"/>
                <Button Classes="settings-nav"
                  Classes.active="{Binding IsAccessibilitySectionSelected}"
                  Click="SettingsNavBtn_Click"
                  Tag="Accessibility"
                  Content="{Binding [settings.section.accessibility.title], Source={x:Static loc:LocalizationService.Instance}}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Padding="18">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding SettingsSectionTitle}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SettingsSectionSubtitle}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppVersionLabel, StringFormat=v{0}}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
                <Button Name="SettingsCloseBtn"
                        Click="SettingsCloseBtn_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Padding="4"
                        Content="✕"/>
              </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="14">
                <StackPanel Spacing="8" IsVisible="{Binding IsAppearanceSectionSelected}">
                  <TextBlock Text="{Binding [settings.theme.mode], Source={x:Static loc:LocalizationService.Instance}}"
                             IsVisible="{Binding IsAppearanceSectionSelected}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <Grid ColumnDefinitions="*,*,*">
                    <Border Grid.Column="0" Background="{StaticResource MacroBg3Brush}" BorderBrush="{StaticResource BorderActiveBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                      <StackPanel Spacing="8">
                        <Border Height="64" CornerRadius="8" Background="{StaticResource BtnPrimaryFgBrush}"/>
                        <Button Content="{Binding [settings.theme.light], Source={x:Static loc:LocalizationService.Instance}}"
                                Classes="secondary"
                                Click="SettingsThemeLightBtn_Click"
                                HorizontalAlignment="Stretch"
                                Padding="10,6"
                                CornerRadius="8"/>
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="10,0,0,0" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                      <StackPanel Spacing="8">
                        <Border Height="64" CornerRadius="8" Background="{StaticResource Surface2Brush}"/>
                        <Button Content="{Binding [settings.theme.dark], Source={x:Static loc:LocalizationService.Instance}}"
                                Classes="secondary"
                                Click="SettingsThemeDarkBtn_Click"
                                HorizontalAlignment="Stretch"
                                Padding="10,6"
                                CornerRadius="8"/>
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="10,0,0,0" Background="{StaticResource MacroBg1Brush}" BorderBrush="{StaticResource MacroBorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                      <StackPanel Spacing="8">
                        <Border Height="64" CornerRadius="8" Background="{StaticResource Surface3Brush}"/>
                        <TextBlock Text="{Binding [settings.theme.system], Source={x:Static loc:LocalizationService.Instance}}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsAppearanceSectionSelected}"/>

                <StackPanel Spacing="8" IsVisible="{Binding IsAppearanceSectionSelected}">
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding [settings.gridSnap.title], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding [settings.gridSnap.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="secondary"
                            Click="SettingsToggleSnapBtn_Click"
                            ToolTip.Tip="{Binding [tooltip.snapToGrid], Source={x:Static loc:LocalizationService.Instance}}"
                            Padding="10,6"
                            CornerRadius="8">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="GridLarge" Width="14" Height="14"/>
                        <TextBlock Text="{Binding Canvas.SnapToGridLabel, FallbackValue=Snap OFF}"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsAppearanceSectionSelected}"/>

                <StackPanel Spacing="8" IsVisible="{Binding IsLanguageRegionSectionSelected}">
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding [settings.section.languageRegion.title], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding [settings.language.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              x:Name="SettingsLanguageCombo"
                              Classes="param-combo"
                              Width="220"
                              SelectionChanged="SettingsLanguageCombo_SelectionChanged">
                      <ComboBoxItem Tag="pt-BR" Content="{Binding [settings.language.option.ptBR], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <ComboBoxItem Tag="en-US" Content="{Binding [settings.language.option.enUS], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <ComboBoxItem Tag="es-ES" Content="{Binding [settings.language.option.esES], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <ComboBoxItem Tag="ru-RU" Content="{Binding [settings.language.option.ruRU], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <ComboBoxItem Tag="ja-JP" Content="{Binding [settings.language.option.jaJP], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <ComboBoxItem Tag="zh-TW" Content="{Binding [settings.language.option.zhTW], Source={x:Static loc:LocalizationService.Instance}}"/>
                    </ComboBox>
                  </Grid>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsAppearanceSectionSelected}"/>

                <StackPanel Spacing="8" IsVisible="{Binding IsAppearanceSectionSelected}">
                  <TextBlock Text="{Binding [settings.themeJson.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.themeJson.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>

                  <TextBox x:Name="SettingsThemeJsonTextBox"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           MinHeight="140"
                           MaxHeight="260"/>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                    <Button Grid.Column="0"
                            Content="{Binding [settings.themeJson.apply], Source={x:Static loc:LocalizationService.Instance}}"
                            Classes="info"
                            Click="SettingsApplyThemeJsonBtn_Click"
                            Padding="10,6"
                            CornerRadius="8"/>
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="{Binding [settings.themeJson.restoreDefault], Source={x:Static loc:LocalizationService.Instance}}"
                            Classes="secondary"
                            Click="SettingsRestoreDefaultThemeBtn_Click"
                            Padding="10,6"
                            CornerRadius="8"/>
                    <TextBlock Grid.Column="2"
                               x:Name="SettingsThemeStatusText"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text=""/>
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Content="{Binding [common.close], Source={x:Static loc:LocalizationService.Instance}}"
                            Classes="secondary"
                            Click="SettingsCloseBtn_Click"
                            Padding="10,6"
                            CornerRadius="8"/>
                  </Grid>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsDateTimeSectionSelected}"/>
                <StackPanel Spacing="6" IsVisible="{Binding IsDateTimeSectionSelected}">
                  <TextBlock Text="{Binding [settings.section.dateTime.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.section.wip.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsKeyboardShortcutsSectionSelected}"/>
                <StackPanel Spacing="6" IsVisible="{Binding IsKeyboardShortcutsSectionSelected}">
                  <TextBlock Text="{Binding [settings.section.keyboard.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.section.wip.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsPrivacySectionSelected}"/>
                <StackPanel Spacing="6" IsVisible="{Binding IsPrivacySectionSelected}">
                  <TextBlock Text="{Binding [settings.section.privacy.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.section.wip.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsNotificationSectionSelected}"/>
                <StackPanel Spacing="6" IsVisible="{Binding IsNotificationSectionSelected}">
                  <TextBlock Text="{Binding [settings.section.notification.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.section.wip.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <Border Height="1" Background="{StaticResource MacroBorderSubtleBrush}" IsVisible="{Binding IsAccessibilitySectionSelected}"/>
                <StackPanel Spacing="6" IsVisible="{Binding IsAccessibilitySectionSelected}">
                  <TextBlock Text="{Binding [settings.section.accessibility.title], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding [settings.section.wip.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Grid>
          </Border>
        </Grid>
      </Border>
    </Border>
    </Grid>
</Window>
